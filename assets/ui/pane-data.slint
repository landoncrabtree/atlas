// Per-pane light data and split-handle descriptors for the N-pane workspace.
//
// `PaneSlintData` carries the layout geometry and AppShell-managed lightweight
// fields for each pane.  Heavy per-pane data (details rows, thumbnails, tree
// nodes, etc.) lives in per-slot top-level properties on `AtlasWindow`
// (`pane0-*` / `pane1-*`) until Phase 4.1 migrates the view controllers to
// the N-pane parallel-array model.

/// Light data for a single pane; pushed by `project_workspace_to_slint`.
///
/// Geometry fields (x/y/width/height) are computed by
/// `SplitLayout::layout_rects` on the Rust side and reflect the pane's
/// absolute position within the workspace content area.
export struct PaneSlintData {
    /// Stable pane identifier вҖ” matches the Rust `PaneId(u32)`.  All
    /// per-pane callbacks use this id as their first argument.
    id: int,

    // в”Җв”Җ Layout в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    x: length,
    y: length,
    width: length,
    height: length,

    // в”Җв”Җ AppShell-managed light data в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

    /// Current directory path (display string, not necessarily valid UTF-8).
    path: string,

    /// Active view mode: "Details" | "Grid" | "Gallery" | "Miller" | "Tree".
    view-mode: string,

    /// Index of the active tab within the pane's tab list.
    active-tab: int,

    /// Backend glyph (`рҹ”җ` / `рҹ“Ў` / `рҹҢҗ` / `вҳҒпёҸ` / empty for local). Pushed by
    /// `project_workspace_to_slint`. Rendered as a small prefix on the
    /// address bar and inside the first breadcrumb chip for remote panes.
    backend-glyph: string,
}

/// Describes a draggable resize handle between two split children.
///
/// Pushed by `project_workspace_to_slint` alongside `panes`.  Each `Split`
/// node in the binary layout tree produces exactly one `SplitHandle`.
export struct SplitHandle {
    /// Index into the DFS-ordered split node list; stable within a session.
    /// Passed back via the `resize-split` callback.
    node-index: int,

    // в”Җв”Җ Grab-area geometry в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    x: length,
    y: length,
    width: length,
    height: length,

    /// `true` when the split stacks children horizontally (handle dragged
    /// vertically to resize top/bottom halves).
    horizontal: bool,
}
