import { Theme } from "theme.slint";
// Embed Symbols Nerd Font Mono for filetype icons. Registered process-wide
// by the Slint compiler; family name is "Symbols Nerd Font Mono". Consumers
// bind `font-family: Theme.icon-font-family` on Text elements displaying
// PUA icon glyphs. See assets/fonts/README.md for attribution.
import "../fonts/SymbolsNerdFontMono-Regular.ttf";
import { Titlebar } from "components/titlebar.slint";
import { Pane } from "components/pane.slint";
// StatusBar was moved per-pane (see components/pane.slint → PaneStatusBar).
// The whole-window component is no longer used from atlas.slint.
import { ShortcutFooter, ShortcutHint } from "components/shortcut-footer.slint";
import { CommandPalette, PaletteEntry } from "components/command-palette.slint";
import { SearchPanel, SearchRow } from "components/search-panel.slint";
import { OpsPanel, OpRow } from "components/ops-panel.slint";
import { OperationProgress } from "components/operation-progress.slint";
import { BulkRenameModal, RenamePreview } from "components/bulk-rename.slint";
import { ConnectServerModal, SavedServerRow } from "components/connect-server.slint";
import { TabEntry } from "components/tab-bar.slint";
import { EntryRowItem, ColumnSpec } from "views/details/column.slint";
import { MillerColData } from "views/miller/miller-state.slint";
import { MetadataFields } from "views/gallery/gallery-metadata.slint";
import { PaneSlintData, SplitHandle } from "pane-data.slint";

// Entry-point component for the Atlas application window.
//
// Key-map stop-gap (Slint-level): Esc, Cmd/Ctrl-Shift-P, Cmd/Ctrl-P, Tab are
// handled here via a FocusScope. This is intentionally minimal — a full
// chord-sequence resolver integrating atlas-keymap is a follow-up todo.
export component AtlasWindow inherits Window {
    title: "Atlas";
    // Sensible default and lower bound; content clips/scrolls beyond this
    // rather than forcing the window to grow with adding tabs, breadcrumbs,
    // or long paths.
    preferred-width: 1280px;
    preferred-height: 800px;
    min-width: 720px;
    min-height: 480px;
    background: Theme.bg;
    default-font-family: Theme.font-family;
    default-font-size: Theme.font-size;

    in property <bool> dark: true;

    in-out property <color> theme-bg: #0f1115;
    in-out property <color> theme-panel-bg: #171a20;
    in-out property <color> theme-panel-bg-elevated: #1e232b;
    in-out property <color> theme-fg: #e6ebf4;
    in-out property <color> theme-fg-muted: #8b95a7;
    in-out property <color> theme-fg-faint: #5a6478;
    in-out property <color> theme-border: #20262f;
    in-out property <color> theme-border-strong: #2b3341;
    in-out property <color> theme-accent: #4a9eff;
    in-out property <color> theme-accent-fg: #ffffff;
    in-out property <color> theme-accent-soft: #4a9eff26;
    in-out property <color> theme-selection-bg: #3d7ac9;
    in-out property <color> theme-selection-fg: #ffffff;
    in-out property <color> theme-hover-bg: #ffffff0d;
    in-out property <color> theme-error: #ff6b6b;
    in-out property <color> theme-success: #5bd18a;
    in-out property <color> theme-warning: #f5c274;

    in-out property <string> theme-font-family: "";
    in-out property <length> theme-font-size: 13px;
    in-out property <string> theme-monospace: "";

    in-out property <length> theme-radius-xs: 4px;
    in-out property <length> theme-radius-sm: 6px;
    in-out property <length> theme-radius-md: 8px;
    in-out property <length> theme-radius-lg: 10px;
    in-out property <length> theme-radius-xl: 14px;
    in-out property <length> theme-space-1: 4px;
    in-out property <length> theme-space-2: 8px;
    in-out property <length> theme-space-3: 12px;
    in-out property <length> theme-space-4: 16px;
    in-out property <length> theme-space-5: 20px;
    in-out property <length> theme-space-6: 24px;
    in-out property <length> theme-space-8: 32px;
    in-out property <length> theme-space-10: 40px;
    in-out property <length> theme-spacing-xs: 4px;
    in-out property <length> theme-spacing-sm: 8px;
    in-out property <length> theme-spacing-md: 12px;
    in-out property <length> theme-spacing-lg: 16px;
    in-out property <length> theme-titlebar-h: 36px;
    in-out property <length> theme-statusbar-h: 24px;
    in-out property <length> theme-tab-h: 32px;
    in-out property <length> theme-addressbar-h: 30px;
    in-out property <length> theme-row-h-default: 30px;
    in-out property <length> theme-row-h-compact: 24px;
    in-out property <length> theme-row-h-spacious: 38px;
    /// When false every animate{} duration collapses to 0ms. Wired from
    /// config.ui.animations.
    in-out property <bool> theme-animations: true;

    // ── N-pane workspace ─────────────────────────────────────────────────────

    /// All live panes in DFS layout order; pushed by project_workspace_to_slint.
    in property <[PaneSlintData]> panes;

    /// Stable id of the currently focused pane.
    in property <int> focused-pane-id: -1;

    /// DFS position of the focused pane within `panes` (convenience index for
    /// Slint-side array access such as `panes[focus-index].path`).
    in property <int> focus-index: 0;

    // ── Chrome visibility toggles (wired from config `ui.show_*`) ─────────────
    in property <bool> show-status-bar: true;
    in property <bool> show-breadcrumbs: true;
    /// Show the bottom shortcut-footer strip. Wired from `ui.show_shortcuts`.
    in property <bool> show-shortcut-footer: true;

    /// Resize handles for every internal split node; pushed alongside `panes`.
    in property <[SplitHandle]> split-handles;

    // ── Per-pane heavy data (nested arrays, indexed by DFS position) ─────────
    //
    // The Rust `AppShell` maintains a `PaneRenderCache` keyed by PaneId and,
    // whenever a controller publishes new data, rebuilds these outer arrays
    // in DFS-leaf order and pushes the entire nested VecModel here.
    // The `for pane[i] in panes` loop below reads slot `i` from every array
    // in tandem so any number of panes is supported.

    in property <[[TabEntry]]> panes-tabs: [];
    in property <[[string]]> panes-segments: [];
    in property <[int]> panes-active-tab: [];

    in property <[[EntryRowItem]]> panes-details-rows: [];
    in property <[[ColumnSpec]]> panes-details-columns: [];
    in property <[[bool]]> panes-details-selected-mask: [];
    in property <[int]> panes-details-selected-anchor: [];
    in property <[int]> panes-details-focused-index: [];

    in property <[[image]]> panes-grid-thumbnails: [];
    in property <[[bool]]> panes-grid-has-thumbs: [];
    in property <[[bool]]> panes-grid-selected-mask: [];
    in property <[int]> panes-grid-focused-index: [];

    in property <[[image]]> panes-gallery-strip-thumbnails: [];
    in property <[image]> panes-gallery-preview-image: [];
    in property <[bool]> panes-gallery-preview-loading: [];
    in property <[string]> panes-gallery-preview-fallback-glyph: [];
    in property <[int]> panes-gallery-focused-index: [];
    in property <[MetadataFields]> panes-gallery-metadata: [];

    in property <[[MillerColData]]> panes-miller-columns: [];
    in property <[int]> panes-miller-focused-col: [];

    // ── Per-pane status bar (folder/file counts, size, free-space) ───────
    //
    // Each entry indexed by DFS position mirrors `panes[i]`. Pushed by
    // `AppShell::push_pane_status_to_slint`; consumed by every `Pane`
    // instance's own PaneStatusBar. Empty defaults leave the chips blank
    // until the first vm event fires.
    in property <[int]> panes-status-folder-count: [];
    in property <[int]> panes-status-file-count: [];
    in property <[string]> panes-status-total-size-text: [];
    in property <[string]> panes-status-free-space-text: [];
    /// One entry per pane (DFS-indexed) describing the connection
    /// health. Values: `"local"`, `"ok"`, `"reconnecting"`, `"failed"`.
    /// Pushed by `AppShell::push_pane_connection_status_to_slint`.
    in property <[string]> panes-connection-status: [];
    /// Companion accessibility / hover-tooltip strings, per-pane.
    in property <[string]> panes-connection-tooltip: [];
    /// One entry per pane: ephemeral warning banner text shown in the
    /// status bar (currently used for "file too large to preview"
    /// toasts). Empty string hides the chip. Auto-cleared by Rust
    /// after a short window. Pushed by
    /// `AppShell::push_pane_warning`.
    in property <[string]> panes-status-warning-text: [];

    // ── Status bar ───────────────────────────────────────────────────────────

    in property <int> total-entries: 0;
    in property <int> folder-count: 0;
    in property <int> file-count: 0;
    in property <string> total-size-text: "";
    in property <int> selected-entries: 0;
    in property <string> selected-size-text: "";
    /// Free-space string for the focused pane's volume (e.g. "312 GB free of 1 TB").
    /// Empty string hides the chip entirely.
    in property <string> free-space-text: "";

    /// Rendered shortcut chips for the footer. Populated by Rust from the
    /// live atlas-keymap Keymap so user rebindings appear automatically.
    in property <[ShortcutHint]> shortcut-hints: [];

    // When true, the `hjkl` keys navigate (vim style). When false, only
    // arrow keys / Enter / Backspace navigate; letter keys pass through
    // to focused controls. Driven by `config.general.vim_mode`.
    in property <bool> vim-mode: false;

    /// Border thickness (in logical pixels) drawn inside the focused pane so
    /// users can tell which pane will receive keystrokes. Wired from
    /// `config.ui.active_pane_border_px`; set to 0 to disable.
    in property <length> active-pane-border-px: 2px;

    /// Bumped by Rust whenever the root FocusScope must re-grab focus (after
    /// a TextInput steals it, after a modal closes, etc.). The FocusScope
    /// watches this via a `changed` handler and calls `self.focus()`.
    in property <int> refocus-tick: 0;

    in property <bool> palette-visible: false;
    in-out property <string> palette-query: "";
    in property <[PaletteEntry]> palette-results: [];
    in property <int> palette-selected: 0;

    in property <bool> search-panel-visible: false;
    in-out property <string> search-panel-query: "";
    in property <[SearchRow]> search-panel-rows: [];
    in property <int> search-panel-selected: 0;
    in property <string> search-panel-status: "";

    /// Whether the confirm-quit modal is shown. Toggled by Rust on the OS
    /// close-window event when `config.general.confirm_on_quit = true`.
    in property <bool> confirm-quit-visible: false;

    /// Whether the bulk-rename modal is shown.
    in property <bool> bulk-rename-visible: false;
    /// Current find pattern (regex or literal) — pushed from Rust.
    in-out property <string> bulk-rename-pattern: "";
    /// Current replacement string — pushed from Rust.
    in-out property <string> bulk-rename-replacement: "";
    /// Whether regex mode is active.
    in property <bool> bulk-rename-use-regex: false;
    /// Whether matching is case-insensitive.
    in property <bool> bulk-rename-case-insensitive: false;
    /// Computed preview rows.
    in property <[RenamePreview]> bulk-rename-preview-rows: [];
    /// Number of conflicting rows in the preview.
    in property <int> bulk-rename-conflict-count: 0;
    /// Number of rows that will actually be renamed.
    in property <int> bulk-rename-change-count: 0;
    /// Non-empty when the regex pattern failed to compile.
    in property <string> bulk-rename-error-text: "";

    // ── Connect-to-Server modal (Cmd+K) ────────────────────────────────────
    //
    // See `assets/ui/components/connect-server.slint` for the modal's own
    // property/callback surface. Rust owns every field; the modal is a
    // dumb view. `connect-modal-input-focused` bubbles up from the modal's
    // internal `input-focused` property so the outer FocusScope's
    // `keymap-bypass-active` covers Cmd+A / Cmd+C / Cmd+V while the modal
    // is up. Same mechanism as the address-bar chord bypass from 269ab5a.
    in property <bool> connect-modal-visible: false;
    in-out property <int> connect-backend-index: 0;
    in-out property <int> connect-auth-index: 0;
    in-out property <string> connect-connection-string: "";
    in-out property <string> connect-host: "";
    in-out property <string> connect-port: "";
    in-out property <string> connect-path: "";
    in-out property <string> connect-username: "";
    in-out property <string> connect-password: "";
    in-out property <string> connect-ssh-key-path: "";
    in-out property <string> connect-iam-access-key: "";
    in-out property <string> connect-iam-secret-key: "";
    in-out property <string> connect-iam-session-token: "";
    in-out property <string> connect-s3-endpoint: "";
    in-out property <string> connect-label: "";
    in property <bool> connect-save-to-keychain: true;
    in property <bool> connect-connecting: false;
    in property <string> connect-status-text: "";
    in property <bool> connect-status-is-error: false;
    // ── TOFU host-key prompt (Phase 2.6) ──────────────────────────────
    //
    // Pushed by `ConnectController::push_to_ui` when the SFTP handshake
    // hits an unknown or mismatched host key. Non-empty
    // `host-key-mismatch-known-fingerprint` distinguishes the two:
    // empty ⇒ first-time host (accent banner);
    // non-empty ⇒ key changed (red warning banner).
    in property <bool> connect-host-key-prompt-visible: false;
    in property <string> connect-host-key-host: "";
    in property <string> connect-host-key-fingerprint: "";
    in property <string> connect-host-key-mismatch-known-fingerprint: "";
    /// The saved-servers list rendered inside the modal. Pushed by
    /// `ConnectController::push_saved_servers_to_ui` on modal open and
    /// after any add / delete / connect. Empty ⇒ modal renders the
    /// "No saved servers yet" empty state.
    in property <[SavedServerRow]> connect-saved-servers: [];
    /// Mirrors ConnectServerModal.input-focused. Read by the root FocusScope
    /// to enable keymap bypass while a TextInput in the modal has focus.
    property <bool> connect-modal-input-focused: false;

    /// Whether the file-operations tray is shown.
    in property <bool> ops-panel-visible: false;
    /// Operation rows shown in the ops tray.
    in property <[OpRow]> ops-rows: [];

    // ── Progress modal (Finder-style, per-foreground-op) ──────────────────
    //
    // Pushed by `OpsController::push_modal_state` when an op has been
    // running for more than 250ms. Trivial fast ops never surface here.
    // The modal has two dismissal paths:
    //   `op-modal-cancel`     — aborts the op via the cancellation token.
    //   `op-modal-background` — hides the modal; op keeps running in the
    //                            Cmd+J operations panel.
    // Click-outside, Escape, and Enter all route to Background.
    in property <bool> op-modal-visible: false;
    in property <string> op-modal-title: "";
    in property <string> op-modal-subtitle: "";
    in property <string> op-modal-detail: "";
    in property <string> op-modal-icon: "";
    in property <float> op-modal-progress: 0.0;
    in property <bool> op-modal-indeterminate: false;

    // ── Global callbacks ──────────────────────────────────────────────────────

    callback palette-query-changed(string);
    callback palette-confirm(string);
    callback palette-dismiss();
    callback search-query-changed(string);
    callback search-confirm(int);
    callback search-close();
    callback toggle-search-panel();
    callback open-search-panel();

    /// Bulk-rename callbacks — dispatched by [`BulkRenameModal`].
    callback bulk-rename-pattern-changed(string);
    callback bulk-rename-replacement-changed(string);
    callback bulk-rename-toggle-regex();
    callback bulk-rename-toggle-case();
    callback bulk-rename-confirm();
    callback bulk-rename-cancel();
    /// Open the bulk-rename modal with the current pane's selection.
    /// Triggered by Cmd/Ctrl+Shift+F2.
    callback open-bulk-rename();

    // ── Connect-to-Server modal callbacks ─────────────────────────────────
    callback connect-backend-changed(int);
    callback connect-auth-changed(int);
    callback connect-connection-string-changed(string);
    callback connect-host-changed(string);
    callback connect-port-changed(string);
    callback connect-path-changed(string);
    callback connect-username-changed(string);
    callback connect-password-changed(string);
    callback connect-ssh-key-path-changed(string);
    callback connect-iam-access-key-changed(string);
    callback connect-iam-secret-key-changed(string);
    callback connect-iam-session-token-changed(string);
    callback connect-s3-endpoint-changed(string);
    callback connect-label-changed(string);
    callback connect-toggle-save-to-keychain();
    callback connect-browse-ssh-key();
    callback connect-cancel();
    callback connect-dry-run();
    callback connect-save-and-connect();
    /// Saved-server row clicked → populate modal fields with that server.
    callback connect-saved-server-selected(string /* id */);
    /// First-stage delete arm — flips `delete-pending` on the row.
    callback connect-saved-server-delete-requested(string /* id */);
    /// Confirmed delete — Rust removes servers.toml + keychain entry.
    callback connect-saved-server-delete-confirmed(string /* id */);
    /// Cancel any pending delete arm.
    callback connect-saved-server-delete-cancelled();
    // ── TOFU host-key prompt (Phase 2.6) ──────────────────────────────
    /// User clicked "Trust once" — accept this handshake but don't
    /// persist the key.
    callback connect-host-key-trust-once();
    /// User clicked "Trust always" — accept and write the offered key
    /// to `~/.config/atlas/known_hosts` so future connects skip the
    /// prompt.
    callback connect-host-key-trust-always();
    /// User clicked "Cancel" — reject the offered key; the handshake
    /// aborts.
    callback connect-host-key-cancel();

    /// Confirm the pending quit. Rust hides the window immediately.
    callback confirm-quit-accept();
    /// Cancel the pending quit. Rust dismisses the modal.
    callback confirm-quit-cancel();

    // ── Context menu ─────────────────────────────────────────────────────
    //
    // Right-click / Menu-key on any entry fires
    // `open-entry-context-menu(pane-id, index, x, y)` which Rust translates
    // into an action-menu shown at (x, y). The menu itself lives in the
    // Slint tree as a ContextMenuArea + Menu so Slint's native popup
    // machinery handles placement, escape-to-dismiss, arrow-key nav, etc.
    //
    // Each MenuItem's `activated` callback dispatches the corresponding
    // action id via `handle-key-chord` — same dispatcher every keyboard
    // chord uses — so context-menu items automatically show the currently
    // bound shortcut alongside their labels.
    callback ctx-open();
    callback ctx-open-with();
    callback ctx-copy();
    callback ctx-cut();
    callback ctx-paste();
    callback ctx-duplicate();
    callback ctx-rename();
    callback ctx-trash();
    callback ctx-reveal();
    callback ctx-get-info();
    callback ctx-copy-remote-uri();
    callback ctx-copy-shell-path();
    callback ctx-reveal-in-new-pane();

    /// Cancel the operation at `index` in `ops-rows`.
    callback ops-cancel(int);
    /// Remove a terminal row at `index` from the ops panel.
    callback ops-dismiss(int);
    /// Hide the ops panel (rows are retained on the Rust side).
    callback ops-close();
    /// Drop every terminal row from the ops panel (Clear-completed button).
    callback ops-clear-completed();
    /// Toggle the ops panel open/closed (Ctrl/Cmd+J).
    callback toggle-ops-panel();
    /// Modal `Cancel` — aborts the current foreground op.
    callback op-modal-cancel();
    /// Modal `Background` — hides the modal, op keeps running in the panel.
    callback op-modal-background();
    /// Trigger deletion (to trash) of the current pane's selection.
    callback fs-delete();
    /// Trigger rename of the focused entry (F2 by default).
    callback fs-rename();
    /// Trigger mkdir in the current pane.
    callback fs-mkdir();

    // ── Per-pane callbacks (all take pane-id as first argument) ──────────────

    /// User submitted an address-bar path.
    callback address-submitted(int /*pane-id*/, string);
    /// User cancelled the address-bar edit.
    callback address-cancelled(int /*pane-id*/);
    /// User clicked a breadcrumb segment.
    callback breadcrumb-clicked(int /*pane-id*/, int /*segment*/);
    /// User selected tab at index.
    callback tab-selected(int /*pane-id*/, int /*tab*/);
    /// User closed tab at index.
    callback tab-closed(int /*pane-id*/, int /*tab*/);
    /// User opened a new tab.
    callback new-tab(int /*pane-id*/);
    /// User clicked within the pane (focus request).
    callback pane-focused(int /*pane-id*/);

    callback details-row-clicked(int /*pane-id*/, int, bool, bool);
    callback details-row-double-clicked(int /*pane-id*/, int);
    callback details-row-context-menu(int /*pane-id*/, int, length, length);
    callback details-header-clicked(int /*pane-id*/, int);
    callback details-header-resize(int /*pane-id*/, int, float);

    callback grid-entry-clicked(int /*pane-id*/, int, bool, bool);
    callback grid-entry-double-clicked(int /*pane-id*/, int);
    callback grid-entry-context-menu(int /*pane-id*/, int, length, length);
    callback grid-thumbnail-visible(int /*pane-id*/, int);
    callback grid-columns-changed(int /*pane-id*/, int);

    callback gallery-entry-clicked(int /*pane-id*/, int);
    callback gallery-entry-context-menu(int /*pane-id*/, int, length, length);
    callback gallery-strip-visible(int /*pane-id*/, int);
    callback gallery-preview-visible(int /*pane-id*/, int);
    callback gallery-prev-image(int /*pane-id*/);
    callback gallery-next-image(int /*pane-id*/);

    callback miller-row-clicked(int /*pane-id*/, int /*col*/, int /*row*/);
    callback miller-row-double-clicked(int /*pane-id*/, int /*col*/, int /*row*/);
    callback miller-row-context-menu(int /*pane-id*/, int /*col*/, int /*row*/, length, length);

    /// Drag a split handle; `delta-fraction` is normalised to the split axis.
    /// MVP: fires on click with 0.0 (drag computation is a Phase 4.1 follow-up
    /// pending investigation of TouchArea pressed-x/y availability).
    callback resize-split(int /*node-index*/, float /*delta-fraction*/);

    // ── Cross-pane drag-and-drop ──────────────────────────────────────────────
    //
    // Primitive: TouchArea::moved (same as Phase 5 tab reorder).  No native
    // DragArea / DropArea in Slint 1.17.
    //
    // Flow:
    //   1. A view row/cell detects ≥ 4 px movement while pressed → fires
    //      `drag-start(pane-id, entry-index)`.
    //   2. Rust `begin_drag` resolves paths + sets `is-dragging = true`.
    //   3. The overlay TouchArea (enabled only while `is-dragging`) intercepts
    //      all pointer moves and fires `drag-move` / `drag-end`.
    //   4. Escape → `drag-cancel`.

    /// Emitted when a view row/cell exceeds the 4-px drag threshold.
    callback drag-start(int /*pane-id*/, int /*entry-index*/);
    /// Emitted continuously by the overlay while the pointer moves during drag.
    callback drag-move(length /*x*/, length /*y*/);
    /// Emitted by the overlay on pointer release.
    callback drag-end(length /*x*/, length /*y*/, bool /*alt-held*/);
    /// Emitted on Escape while a drag is in flight.
    callback drag-cancel();

    /// True while a cross-pane drag is in flight (past the 4-px threshold).
    in property <bool> is-dragging: false;
    /// PaneId of the pane currently under the drag pointer; -1 when none.
    in property <int> drag-hover-pane-id: -1;
    /// Number of entries being dragged (shown in the count badge).
    in property <int> drag-count: 0;
    /// Badge position in pane-container-relative coordinates (updated by drag-move).
    in-out property <length> drag-badge-x: 0px;
    in-out property <length> drag-badge-y: 0px;

    // ── Workspace-level callbacks ─────────────────────────────────────────────

    callback toggle-palette();
    callback toggle-dual-pane();
    callback open-goto();
    callback cycle-pane-focus();
    // Focused-pane view navigation.
    callback pane-move-focus(int);          // delta rows (-1 up, +1 down)
    callback pane-activate-focused();       // Enter: cd into or open focused entry
    callback pane-go-up();                  // Backspace / left arrow: parent dir
    callback palette-selection-delta(int);  // arrow up/down while palette open
    // Tab switching — pane-id indexed.
    callback select-tab(int /*pane-id*/, int /*tab*/);
    callback cycle-tab(int /*pane-id*/, int /*delta*/);

    // ── Keymap dispatcher bridge ──────────────────────────────────────────
    //
    // Forward every key event through the atlas-keymap Dispatcher on the
    // Rust side, which resolves the chord against `~/.config/atlas/keymaps/
    // default.toml` + built-in defaults and invokes the registered action
    // handler. Returns true when a handler was called (Slint then swallows
    // the event so it doesn't bubble to a TextInput).
    //
    // `key` is the physical key name — a single lowercase character for
    // letters/digits/punctuation, or a NamedKey token ("escape", "enter",
    // "tab", "backspace", "delete", "space", "up", "down", "left", "right",
    // "home", "end", "pageup", "pagedown", "insert"), or "f1".."f24".
    //
    // Modifier bools are already normalised by Rust to physical semantics:
    //   cmd  = ⌘ (macOS) or Meta/Super (Linux/Windows)
    //   ctrl = ⌃ Control (physical, on every platform)
    //   alt  = ⌥ Option / Alt
    //   shift = ⇧
    //
    // `modal-active` tells the dispatcher a text-input-owning modal (palette,
    // goto, search panel, bulk rename, ops progress) currently has focus.
    // When true, Rust restricts the context stack to `[Global]` — Pane-scoped
    // chords like Cmd+A / Cmd+C fall through to the TextInput natively rather
    // than firing pane operations against a background list the user can't
    // even see.
    callback handle-key-chord(string /*key*/, bool /*ctrl*/, bool /*alt*/, bool /*shift*/, bool /*cmd*/, bool /*modal-active*/) -> bool;

    // ── Theme bridges ─────────────────────────────────────────────────────────

    init => {
        Theme.dark = dark;
        Theme.bg = theme-bg;
        Theme.panel-bg = theme-panel-bg;
        Theme.panel-bg-elevated = theme-panel-bg-elevated;
        Theme.fg = theme-fg;
        Theme.fg-muted = theme-fg-muted;
        Theme.fg-faint = theme-fg-faint;
        Theme.border = theme-border;
        Theme.border-strong = theme-border-strong;
        Theme.accent = theme-accent;
        Theme.accent-fg = theme-accent-fg;
        Theme.accent-soft = theme-accent-soft;
        Theme.selection-bg = theme-selection-bg;
        Theme.selection-fg = theme-selection-fg;
        Theme.hover-bg = theme-hover-bg;
        Theme.error = theme-error;
        Theme.success = theme-success;
        Theme.warning = theme-warning;
        Theme.font-family = theme-font-family;
        Theme.font-size = theme-font-size;
        Theme.monospace = theme-monospace;
        Theme.radius-xs = theme-radius-xs;
        Theme.radius-sm = theme-radius-sm;
        Theme.radius-md = theme-radius-md;
        Theme.radius-lg = theme-radius-lg;
        Theme.radius-xl = theme-radius-xl;
        Theme.space-1 = theme-space-1;
        Theme.space-2 = theme-space-2;
        Theme.space-3 = theme-space-3;
        Theme.space-4 = theme-space-4;
        Theme.space-5 = theme-space-5;
        Theme.space-6 = theme-space-6;
        Theme.space-8 = theme-space-8;
        Theme.space-10 = theme-space-10;
        Theme.spacing-xs = theme-spacing-xs;
        Theme.spacing-sm = theme-spacing-sm;
        Theme.spacing-md = theme-spacing-md;
        Theme.spacing-lg = theme-spacing-lg;
        Theme.titlebar-h = theme-titlebar-h;
        Theme.statusbar-h = theme-statusbar-h;
        Theme.tab-h = theme-tab-h;
        Theme.addressbar-h = theme-addressbar-h;
        Theme.row-h-default = theme-row-h-default;
        Theme.row-h-compact = theme-row-h-compact;
        Theme.row-h-spacious = theme-row-h-spacious;
        Theme.animations = theme-animations;
    }

    changed dark => { Theme.dark = dark; }
    changed theme-bg => { Theme.bg = theme-bg; }
    changed theme-panel-bg => { Theme.panel-bg = theme-panel-bg; }
    changed theme-panel-bg-elevated => { Theme.panel-bg-elevated = theme-panel-bg-elevated; }
    changed theme-fg => { Theme.fg = theme-fg; }
    changed theme-fg-muted => { Theme.fg-muted = theme-fg-muted; }
    changed theme-fg-faint => { Theme.fg-faint = theme-fg-faint; }
    changed theme-border => { Theme.border = theme-border; }
    changed theme-border-strong => { Theme.border-strong = theme-border-strong; }
    changed theme-accent => { Theme.accent = theme-accent; }
    changed theme-accent-fg => { Theme.accent-fg = theme-accent-fg; }
    changed theme-accent-soft => { Theme.accent-soft = theme-accent-soft; }
    changed theme-selection-bg => { Theme.selection-bg = theme-selection-bg; }
    changed theme-selection-fg => { Theme.selection-fg = theme-selection-fg; }
    changed theme-hover-bg => { Theme.hover-bg = theme-hover-bg; }
    changed theme-error => { Theme.error = theme-error; }
    changed theme-success => { Theme.success = theme-success; }
    changed theme-warning => { Theme.warning = theme-warning; }
    changed theme-font-family => { Theme.font-family = theme-font-family; }
    changed theme-font-size => { Theme.font-size = theme-font-size; }
    changed theme-monospace => { Theme.monospace = theme-monospace; }
    changed theme-radius-xs => { Theme.radius-xs = theme-radius-xs; }
    changed theme-radius-sm => { Theme.radius-sm = theme-radius-sm; }
    changed theme-radius-md => { Theme.radius-md = theme-radius-md; }
    changed theme-radius-lg => { Theme.radius-lg = theme-radius-lg; }
    changed theme-radius-xl => { Theme.radius-xl = theme-radius-xl; }
    changed theme-space-1 => { Theme.space-1 = theme-space-1; }
    changed theme-space-2 => { Theme.space-2 = theme-space-2; }
    changed theme-space-3 => { Theme.space-3 = theme-space-3; }
    changed theme-space-4 => { Theme.space-4 = theme-space-4; }
    changed theme-space-5 => { Theme.space-5 = theme-space-5; }
    changed theme-space-6 => { Theme.space-6 = theme-space-6; }
    changed theme-space-8 => { Theme.space-8 = theme-space-8; }
    changed theme-space-10 => { Theme.space-10 = theme-space-10; }
    changed theme-spacing-xs => { Theme.spacing-xs = theme-spacing-xs; }
    changed theme-spacing-sm => { Theme.spacing-sm = theme-spacing-sm; }
    changed theme-spacing-md => { Theme.spacing-md = theme-spacing-md; }
    changed theme-spacing-lg => { Theme.spacing-lg = theme-spacing-lg; }
    changed theme-titlebar-h => { Theme.titlebar-h = theme-titlebar-h; }
    changed theme-statusbar-h => { Theme.statusbar-h = theme-statusbar-h; }
    changed theme-tab-h => { Theme.tab-h = theme-tab-h; }
    changed theme-addressbar-h => { Theme.addressbar-h = theme-addressbar-h; }
    changed theme-row-h-default => { Theme.row-h-default = theme-row-h-default; }
    changed theme-row-h-compact => { Theme.row-h-compact = theme-row-h-compact; }
    changed theme-row-h-spacious => { Theme.row-h-spacious = theme-row-h-spacious; }
    changed theme-animations => { Theme.animations = theme-animations; }

    // ── Context menu ─────────────────────────────────────────────────────
    //
    // Empty by default; `context-menu-visible` and (x,y) are managed
    // by Rust which calls `context-menu.show({ x, y })`. Menu items
    // dispatch through the atlas-keymap dispatcher so shortcut labels
    // stay in sync with the live keymap.
    //
    // Bumped whenever Rust wants the context menu to open. The `changed`
    // handler on the ContextMenuArea reads context-menu-x/y and calls
    // `.show()` at that position. This detour is necessary because
    // ContextMenuArea::show is a Slint function, not a settable property.
    in property <int> context-menu-tick: 0;
    in property <length> context-menu-x: 0px;
    in property <length> context-menu-y: 0px;
    /// Legacy visibility gates. `context-menu-has-clipboard` predates the
    /// full capability model below but is still consulted for the Paste
    /// item, which only depends on clipboard state (never on the target).
    /// The `context-menu-can-*` flags are the current capability system:
    /// pushed from `AppShell::open_context_menu` before the menu opens,
    /// gated 1:1 against MenuItem visibility via `if …` blocks. To add a
    /// new item, add a flag here, mirror it in
    /// `crates/atlas-ui/src/context/capabilities.rs`, push it from
    /// `AppShell::open_context_menu`, and add a matching
    /// `if root.context-menu-can-<flag>: MenuItem { … }` below.
    in property <bool> context-menu-has-clipboard: true;
    in property <bool> context-menu-can-open: true;
    in property <bool> context-menu-can-open-with: true;
    in property <bool> context-menu-can-copy: true;
    in property <bool> context-menu-can-cut: true;
    in property <bool> context-menu-can-paste: true;
    in property <bool> context-menu-can-rename: true;
    in property <bool> context-menu-can-trash: true;
    in property <bool> context-menu-can-duplicate: true;
    in property <bool> context-menu-can-show-in-native-manager: true;
    in property <bool> context-menu-can-copy-remote-uri: false;
    in property <bool> context-menu-can-copy-shell-path: true;
    in property <bool> context-menu-can-reveal-in-new-pane: true;
    in property <bool> context-menu-can-get-info: true;
    /// OS-specific label for the "reveal in native file manager" item.
    /// "Show in Finder" (macOS), "Show in Explorer" (Windows), "Show in
    /// Files" (Linux). Pushed by Rust in `AppShell::open_context_menu`
    /// via `#[cfg(target_os = …)]`.
    in property <string> context-menu-native-manager-label: "⌕  Show in Finder";
    /// "Move to Trash" (local) / "Delete permanently" (remote). Pushed
    /// from Rust when the target changes: remote backends have no OS
    /// trash concept, so we surface the destructive nature clearly.
    in property <string> context-menu-trash-label: "⌫  Move to Trash";

    context-menu := ContextMenuArea {
        // Mirror the root tick into a local property so `changed` can
        // observe it — Slint's `changed` handlers only fire for
        // properties declared on the current element.
        property <int> tick: root.context-menu-tick;
        changed tick => {
            self.show({ x: root.context-menu-x, y: root.context-menu-y });
        }
        // MenuItem in Slint 1.17 has no `visible` property, so we gate
        // each item via a surrounding `if …: MenuItem { … }` block —
        // the item is only instantiated when the capability is true.
        Menu {
            if root.context-menu-can-open: MenuItem {
                title: "▸  Open";
                activated => { root.ctx-open(); }
            }
            if root.context-menu-can-open-with: MenuItem {
                title: "⇱  Open With…";
                activated => { root.ctx-open-with(); }
            }
            MenuSeparator {}
            if root.context-menu-can-copy: MenuItem {
                title: "⌘  Copy";
                activated => { root.ctx-copy(); }
            }
            if root.context-menu-can-cut: MenuItem {
                title: "✂  Cut";
                activated => { root.ctx-cut(); }
            }
            if root.context-menu-can-paste: MenuItem {
                title: "⎘  Paste";
                enabled: root.context-menu-has-clipboard;
                activated => { root.ctx-paste(); }
            }
            if root.context-menu-can-duplicate: MenuItem {
                title: "⧉  Duplicate";
                activated => { root.ctx-duplicate(); }
            }
            MenuSeparator {}
            if root.context-menu-can-rename: MenuItem {
                title: "✎  Rename";
                activated => { root.ctx-rename(); }
            }
            if root.context-menu-can-trash: MenuItem {
                title: root.context-menu-trash-label;
                activated => { root.ctx-trash(); }
            }
            MenuSeparator {}
            if root.context-menu-can-copy-shell-path: MenuItem {
                title: "⧗  Copy Path";
                activated => { root.ctx-copy-shell-path(); }
            }
            if root.context-menu-can-copy-remote-uri: MenuItem {
                title: "🔗  Copy Remote URI";
                activated => { root.ctx-copy-remote-uri(); }
            }
            if root.context-menu-can-reveal-in-new-pane: MenuItem {
                title: "⇱  Reveal in New Pane";
                activated => { root.ctx-reveal-in-new-pane(); }
            }
            if root.context-menu-can-show-in-native-manager: MenuItem {
                title: root.context-menu-native-manager-label;
                activated => { root.ctx-reveal(); }
            }
            if root.context-menu-can-get-info: MenuItem {
                title: "ⓘ  Get Info";
                activated => { root.ctx-get-info(); }
            }
        }
    }

    FocusScope {
        root-focus := Rectangle {
            // Zero-size focus anchor: whenever a modal (palette / search /
            // bulk-rename) closes we call `root-focus.focus()` via a changed
            // handler so the FocusScope regains keyboard input. Without this
            // the app becomes unresponsive to shortcuts the moment any modal
            // is dismissed until the user clicks somewhere.
            width: 0px;
            height: 0px;
        }

        // Force initial focus so the first Cmd+P works before any click.
        init => { self.focus(); }

        // Track whether any modal is open so we can re-focus this scope
        // as soon as the last modal closes (Slint's `changed` handler only
        // works on properties in the current element, so we mirror the
        // root properties into a local one first).
        property <bool> any-modal-visible: root.palette-visible || root.search-panel-visible || root.bulk-rename-visible || root.op-modal-visible || root.connect-modal-visible;
        changed any-modal-visible => {
            if !any-modal-visible { self.focus(); }
        }

        // Tracks which pane's address-bar TextInput currently owns focus,
        // or `-1` when none. Populated by the `changed text-input-focused`
        // handler on each pane iteration below and read by
        // `keymap-bypass-active` so Cmd+A / Cmd+C / Cmd+V route to the
        // TextInput's native edit shortcuts instead of the pane keymap
        // when the user is typing a path. Mirrors the modal-focus fix from
        // `a3830bc`, extended to per-pane text inputs.
        //
        // Anti-drift: an incoming focus event sets the id; a blur only
        // clears it when the id matches, so cross-pane focus jumps
        // (blur A then focus B fires in either order) never leave the
        // gate stuck open.
        property <int> text-focus-pane-id: -1;

        // Composite gate passed to the Rust dispatcher: `true` restricts
        // context to `[Global]` so Pane bindings return false and the
        // key falls through to whatever TextInput currently owns focus.
        property <bool> keymap-bypass-active: any-modal-visible || text-focus-pane-id != -1 || root.connect-modal-input-focused;

        // Ticks up whenever Rust wants the root FocusScope to re-grab focus
        // (e.g. after the AddressBar's TextInput cancels or submits). We rely
        // on the `changed` handler so we don't need a Slint-side callback.
        property <int> refocus-tick: root.refocus-tick;
        changed refocus-tick => { self.focus(); }

        // Route every key press through the atlas-keymap Dispatcher on the
        // Rust side. This is the SINGLE source of truth for keyboard shortcuts:
        // atlas-keymap resolves the physical chord against the user's
        // `~/.config/atlas/keymaps/default.toml` (layered over defaults) and
        // invokes the registered handler. The `handle-key-chord` callback
        // returns true when a handler ran, so we can `return accept` and stop
        // propagation.
        //
        // We use `capture-key-pressed` so shortcuts fire BEFORE any child
        // TextInput (address bar, palette, bulk-rename) can consume the key.
        // Modal-specific keys (Escape → dismiss palette, Tab → cycle panes)
        // are still handled here so they beat both text inputs and the
        // dispatcher's global bindings.
        capture-key-pressed(event) => {
            // ── Modal-specific Escape / drag-cancel ────────────────────────
            //
            // These MUST run before the dispatcher; otherwise typing Escape
            // in the palette query field would fall through to whatever the
            // user bound to `escape` globally.
            if event.text == Key.Escape {
                if is-dragging          { root.drag-cancel();          return accept; }
                if palette-visible      { root.palette-dismiss();      return accept; }
                if search-panel-visible { root.search-close();         return accept; }
                if bulk-rename-visible  { root.bulk-rename-cancel();   return accept; }
                if connect-modal-visible{ root.connect-cancel();       return accept; }
                if op-modal-visible     { root.op-modal-background();  return accept; }
            }

            // Enter defaults to "Background" for the progress modal so a
            // reflex Return keystroke never cancels an in-flight op.
            if op-modal-visible && (event.text == Key.Return || event.text == "\n") {
                root.op-modal-background();
                return accept;
            }

            // Tab cycles pane focus when a workspace has 2+ panes. Handled
            // outside the keymap because Tab in a TextInput has native
            // meaning (focus-nav / autocomplete).
            if event.text == Key.Tab && panes.length > 1 && !palette-visible
                && !search-panel-visible && !bulk-rename-visible && !connect-modal-visible {
                root.cycle-pane-focus();
                return accept;
            }

            // ── Keymap dispatcher ──────────────────────────────────────────
            //
            // Only fire when at least one modifier is held OR the key is a
            // named/function key. Plain letters go straight to text inputs
            // (address bar, palette query) so users can type. Vim `hjkl`
            // for file navigation lives in the fallback `key-pressed`
            // handler below, gated on `vim-mode`, so it doesn't collide
            // with typing in a TextInput.
            //
            // When any modal (palette, goto, search, bulk rename, ops
            // progress) is visible OR a per-pane text input (address bar)
            // owns focus, we still call the dispatcher but pass
            // `modal-active = true` (see `keymap-bypass-active` above) —
            // Rust restricts the context stack to `[Global]` so Pane-scoped
            // chords (Cmd+A / Cmd+C / arrows) fall through to the focused
            // TextInput natively.
            if event.modifiers.control || event.modifiers.meta
                || event.modifiers.alt || event.modifiers.shift
                || event.text == Key.F1 || event.text == Key.F2
                || event.text == Key.F3 || event.text == Key.F4
                || event.text == Key.F5 || event.text == Key.F6
                || event.text == Key.F7 || event.text == Key.F8
                || event.text == Key.F9 || event.text == Key.F10
                || event.text == Key.F11 || event.text == Key.F12 {
                if root.handle-key-chord(event.text,
                                         event.modifiers.control,
                                         event.modifiers.alt,
                                         event.modifiers.shift,
                                         event.modifiers.meta,
                                         keymap-bypass-active) {
                    return accept;
                }
            }

            reject;
        }

        // Fallback for keys the dispatcher didn't consume and that no child
        // TextInput handled either. This is the file-list navigation path:
        //
        //   - Arrow keys / Enter / Backspace / vim `hjkl`: forwarded to the
        //     dispatcher under Pane context, so user rebindings apply. The
        //     `vim-mode` flag gates hjkl at the dispatcher-lookup layer
        //     (see main.rs) — if disabled, those chords resolve to nothing
        //     and the reject path lets TextInputs claim the letters.
        //
        // Note: this fires only AFTER children have had a chance to handle
        // the key (Slint's regular key-pressed is bubble-phase). So typing
        // in the AddressBar TextInput consumes 'j'/'k'/'h'/'l' before the
        // dispatcher ever sees them.
        key-pressed(event) => {
            if palette-visible || search-panel-visible || bulk-rename-visible || op-modal-visible || connect-modal-visible {
                return reject;
            }
            // Gate vim letters on the vim-mode flag so users who don't want
            // hjkl hijacked can turn it off. Named keys (arrows, Enter,
            // Backspace) always fall through to the dispatcher.
            if event.text == "j" || event.text == "k" || event.text == "h" || event.text == "l" {
                if !vim-mode { return reject; }
            }
            if root.handle-key-chord(event.text,
                                     event.modifiers.control,
                                     event.modifiers.alt,
                                     event.modifiers.shift,
                                     event.modifiers.meta,
                                     keymap-bypass-active) {
                return accept;
            }
            reject;
        }

        VerticalLayout {
            spacing: 0px;

            // NOTE(whitespace-fix): the previous custom `Titlebar { … }` here
            // was a 36-px empty band that duplicated the OS-native title
            // bar (traffic lights + window title). It caused a large gap
            // between the macOS titlebar and the pane's address bar.
            // Since we don't set `no-frame: true`, the OS always draws its
            // own titlebar; ours added no content. Removed cross-platform.

            // ── Pane container ────────────────────────────────────────────────
            // All panes are absolutely positioned within this Rectangle; their
            // x/y/width/height come from PaneSlintData computed by
            // `SplitLayout::layout_rects` on the Rust side.
            Rectangle {
                vertical-stretch: 1;
                clip: true;

                for pane[i] in panes: Pane {
                    x: pane.x;
                    y: pane.y;
                    width: pane.width;
                    height: pane.height;

                    pane-id: pane.id;
                    focused: pane.id == focused-pane-id;
                    path: pane.path;
                    backend-glyph: pane.backend-glyph;
                    view-mode: pane.view-mode;
                    show-breadcrumbs: root.show-breadcrumbs;
                    focused-border-px: root.active-pane-border-px;

                    // Per-pane heavy data — routed by DFS position `i` from
                    // the parallel nested arrays. AppShell rebuilds these in
                    // DFS-leaf order whenever the pane cache updates.
                    path-segments: panes-segments[i];
                    tabs: panes-tabs[i];
                    active-tab: panes-active-tab[i];

                    details-rows: panes-details-rows[i];
                    details-columns: panes-details-columns[i];
                    details-selected-mask: panes-details-selected-mask[i];
                    details-selected-anchor: panes-details-selected-anchor[i];
                    details-focused-index: panes-details-focused-index[i];

                    grid-thumbnails: panes-grid-thumbnails[i];
                    grid-has-thumbs: panes-grid-has-thumbs[i];
                    grid-selected-mask: panes-grid-selected-mask[i];
                    grid-focused-index: panes-grid-focused-index[i];

                    gallery-strip-thumbnails: panes-gallery-strip-thumbnails[i];
                    gallery-preview-image: panes-gallery-preview-image[i];
                    gallery-preview-loading: panes-gallery-preview-loading[i];
                    gallery-preview-fallback-glyph: panes-gallery-preview-fallback-glyph[i];
                    gallery-focused-index: panes-gallery-focused-index[i];
                    gallery-metadata: panes-gallery-metadata[i];

                    miller-columns: panes-miller-columns[i];
                    miller-focused-col: panes-miller-focused-col[i];

                    // Per-pane status bar (renders inside the pane frame,
                    // gated on `ui.show_status_bar` via `show-status-bar`).
                    show-status-bar: root.show-status-bar;
                    status-folder-count: panes-status-folder-count[i];
                    status-file-count: panes-status-file-count[i];
                    status-total-size-text: panes-status-total-size-text[i];
                    status-free-space-text: panes-status-free-space-text[i];
                    connection-status: panes-connection-status[i];
                    connection-tooltip: panes-connection-tooltip[i];
                    status-warning-text: panes-status-warning-text[i];

                    // Unified callbacks — all route through pane.id.
                    address-submitted(p) => { root.address-submitted(pane.id, p); }
                    address-cancelled => { root.address-cancelled(pane.id); }
                    breadcrumb-clicked(seg) => { root.breadcrumb-clicked(pane.id, seg); }
                    tab-selected(t) => { root.tab-selected(pane.id, t); }
                    tab-closed(t) => { root.tab-closed(pane.id, t); }
                    new-tab => { root.new-tab(pane.id); }
                    pane-clicked => { root.pane-focused(pane.id); }
                    // Drag-and-drop: forward with pane-id prefix so the root callback
                    // carries both source pane and entry index.
                    drag-start(entry-idx) => { root.drag-start(pane.id, entry-idx); }
                    // Drop-target highlight: show on any pane other than the source
                    // that is under the pointer while dragging.
                    drag-target: root.is-dragging && pane.id == root.drag-hover-pane-id;

                    details-row-clicked(idx, ctrl, shift) => { root.details-row-clicked(pane.id, idx, ctrl, shift); }
                    details-row-double-clicked(idx) => { root.details-row-double-clicked(pane.id, idx); }
                    details-row-context-menu(idx, x, y) => { root.details-row-context-menu(pane.id, idx, x, y); }
                    details-header-clicked(col) => { root.details-header-clicked(pane.id, col); }
                    details-header-resize(col, w) => { root.details-header-resize(pane.id, col, w); }

                    grid-entry-clicked(idx, ctrl, shift) => { root.grid-entry-clicked(pane.id, idx, ctrl, shift); }
                    grid-entry-double-clicked(idx) => { root.grid-entry-double-clicked(pane.id, idx); }
                    grid-entry-context-menu(idx, x, y) => { root.grid-entry-context-menu(pane.id, idx, x, y); }
                    grid-thumbnail-visible(idx) => { root.grid-thumbnail-visible(pane.id, idx); }
                    grid-columns-changed(c) => { root.grid-columns-changed(pane.id, c); }

                    gallery-entry-clicked(idx) => { root.gallery-entry-clicked(pane.id, idx); }
                    gallery-entry-context-menu(idx, x, y) => { root.gallery-entry-context-menu(pane.id, idx, x, y); }
                    gallery-strip-visible(idx) => { root.gallery-strip-visible(pane.id, idx); }
                    gallery-preview-visible(idx) => { root.gallery-preview-visible(pane.id, idx); }
                    gallery-prev-image => { root.gallery-prev-image(pane.id); }
                    gallery-next-image => { root.gallery-next-image(pane.id); }

                    miller-row-clicked(col, row) => { root.miller-row-clicked(pane.id, col, row); }
                    miller-row-double-clicked(col, row) => { root.miller-row-double-clicked(pane.id, col, row); }
                    miller-row-context-menu(col, row, x, y) => { root.miller-row-context-menu(pane.id, col, row, x, y); }

                    // Bubble per-pane text-input focus (currently the
                    // address bar; future inline-rename inputs bubble via
                    // the same out property) into the root FocusScope's
                    // `text-focus-pane-id`. When any pane's TextInput has
                    // focus, `keymap-bypass-active` becomes true and the
                    // Rust dispatcher restricts to [Global] so Cmd+A /
                    // Cmd+C / Cmd+V route to the TextInput's edit
                    // shortcuts. Anti-drift: a blur only clears the id
                    // when it matches, so cross-pane focus jumps (focus B
                    // fires before blur A) never leave the gate stuck.
                    changed text-input-focused => {
                        if self.text-input-focused {
                            text-focus-pane-id = pane.id;
                        } else if text-focus-pane-id == pane.id {
                            text-focus-pane-id = -1;
                        }
                    }
                }

                // Split-handle drag areas — rendered above panes.
                // MVP: emits resize-split with delta 0.0 on click.
                // Phase 4.1: compute real delta from TouchArea pressed-x/y.
                for handle[_j] in split-handles: TouchArea {
                    x: handle.x;
                    y: handle.y;
                    width: handle.horizontal ? handle.width : 4px;
                    height: handle.horizontal ? 4px : handle.height;
                    mouse-cursor: handle.horizontal ? MouseCursor.row-resize : MouseCursor.col-resize;
                    clicked => {
                        root.resize-split(handle.node-index, 0.0);
                    }
                }

                // ── Drag-and-drop overlay ─────────────────────────────────────
                // Enabled only while a drag is in flight (`is-dragging = true`)
                // so it never steals clicks during normal operation.
                // Intercepts all pointer moves to update hover-pane highlight
                // and fires drag-end on pointer release.
                TouchArea {
                    enabled: root.is-dragging;
                    width: 100%;
                    height: 100%;
                    mouse-cursor: root.is-dragging ? MouseCursor.copy : MouseCursor.default;

                    moved => {
                        root.drag-badge-x = self.mouse-x;
                        root.drag-badge-y = self.mouse-y;
                        root.drag-move(self.mouse-x, self.mouse-y);
                    }

                    pointer-event(pe) => {
                        if pe.button == PointerEventButton.left && pe.kind == PointerEventKind.up {
                            root.drag-end(self.mouse-x, self.mouse-y, pe.modifiers.alt);
                        }
                    }
                }

                // ── Drag-count badge ──────────────────────────────────────────
                // Small pill that follows the pointer during drag to indicate
                // how many items are being dragged.
                if root.is-dragging && root.drag-count > 0 : Rectangle {
                    x: root.drag-badge-x + 14px;
                    y: root.drag-badge-y - 14px;
                    width: 60px;
                    height: 22px;
                    background: Theme.accent;
                    border-radius: Theme.radius-sm;

                    Text {
                        width: parent.width;
                        height: parent.height;
                        text: root.drag-count == 1 ? "1 item" : (root.drag-count + " items");
                        color: Theme.accent-fg;
                        font-size: 11px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }
                }
            }

            // Window-level StatusBar was removed in favour of a per-pane
            // status bar rendered inside each Pane's frame (see pane.slint
            // → PaneStatusBar). The `show-status-bar` root property is now
            // forwarded per-pane so `ui.show_status_bar = false` still
            // hides every pane's status bar.

            if root.show-shortcut-footer : ShortcutFooter { hints: root.shortcut-hints; }
        }

        // File-operations tray — auto-shown by Rust when ops are queued.
        OpsPanel {
            x: 0px;
            y: parent.height - self.height;
            width: parent.width;
            visible-panel: root.ops-panel-visible;
            rows: root.ops-rows;
            cancel(i) => { root.ops-cancel(i); }
            dismiss(i) => { root.ops-dismiss(i); }
            close => { root.ops-close(); }
            clear-completed => { root.ops-clear-completed(); }
        }

        // Foreground progress modal — surfaces only for ops that outlive
        // the ~250ms defer in the OpsController. Click-outside, Escape,
        // and Enter all route to Background (op continues in the panel).
        OperationProgress {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            visible-modal: root.op-modal-visible;
            title-text: root.op-modal-title;
            subtitle-text: root.op-modal-subtitle;
            detail-text: root.op-modal-detail;
            icon-glyph: root.op-modal-icon;
            progress: root.op-modal-progress;
            indeterminate: root.op-modal-indeterminate;
            cancel => { root.op-modal-cancel(); }
            send-to-background => { root.op-modal-background(); }
        }

        CommandPalette {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            visible: root.palette-visible;
            query <=> root.palette-query;
            results: root.palette-results;
            selected-index: root.palette-selected;
            query-changed(q) => { root.palette-query-changed(q); }
            confirm(id) => { root.palette-confirm(id); }
            dismiss => { root.palette-dismiss(); }
            select-delta(d) => { root.palette-selection-delta(d); }
        }

        SearchPanel {
            x: parent.width * 0.6;
            y: 0px;
            width: parent.width * 0.4;
            height: parent.height;
            visible-panel: root.search-panel-visible;
            query: root.search-panel-query;
            rows: root.search-panel-rows;
            selected-index: root.search-panel-selected;
            status-text: root.search-panel-status;
            query-changed(q) => { root.search-query-changed(q); }
            confirm(i) => { root.search-confirm(i); }
            close => { root.search-close(); }
        }

        BulkRenameModal {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            visible-modal: root.bulk-rename-visible;
            pattern <=> root.bulk-rename-pattern;
            replacement <=> root.bulk-rename-replacement;
            use-regex: root.bulk-rename-use-regex;
            case-insensitive: root.bulk-rename-case-insensitive;
            preview-rows: root.bulk-rename-preview-rows;
            conflict-count: root.bulk-rename-conflict-count;
            change-count: root.bulk-rename-change-count;
            error-text: root.bulk-rename-error-text;
            pattern-changed(q) => { root.bulk-rename-pattern-changed(q); }
            replacement-changed(q) => { root.bulk-rename-replacement-changed(q); }
            toggle-regex => { root.bulk-rename-toggle-regex(); }
            toggle-case => { root.bulk-rename-toggle-case(); }
            confirm => { root.bulk-rename-confirm(); }
            cancel => { root.bulk-rename-cancel(); }
        }

        // ── Connect-to-Server modal (Cmd+K) ────────────────────────────────
        connect-modal := ConnectServerModal {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            visible-modal: root.connect-modal-visible;
            backend-index <=> root.connect-backend-index;
            auth-index <=> root.connect-auth-index;
            connection-string <=> root.connect-connection-string;
            host <=> root.connect-host;
            port <=> root.connect-port;
            path <=> root.connect-path;
            username <=> root.connect-username;
            password <=> root.connect-password;
            ssh-key-path <=> root.connect-ssh-key-path;
            iam-access-key <=> root.connect-iam-access-key;
            iam-secret-key <=> root.connect-iam-secret-key;
            iam-session-token <=> root.connect-iam-session-token;
            s3-endpoint <=> root.connect-s3-endpoint;
            label-text <=> root.connect-label;
            save-to-keychain: root.connect-save-to-keychain;
            connecting: root.connect-connecting;
            status-text: root.connect-status-text;
            status-is-error: root.connect-status-is-error;
            saved-servers: root.connect-saved-servers;
            host-key-prompt-visible: root.connect-host-key-prompt-visible;
            host-key-host: root.connect-host-key-host;
            host-key-fingerprint: root.connect-host-key-fingerprint;
            host-key-mismatch-known-fingerprint: root.connect-host-key-mismatch-known-fingerprint;

            backend-changed(i) => { root.connect-backend-changed(i); }
            auth-changed(i) => { root.connect-auth-changed(i); }
            connection-string-changed(s) => { root.connect-connection-string-changed(s); }
            host-changed(s) => { root.connect-host-changed(s); }
            port-changed(s) => { root.connect-port-changed(s); }
            path-changed(s) => { root.connect-path-changed(s); }
            username-changed(s) => { root.connect-username-changed(s); }
            password-changed(s) => { root.connect-password-changed(s); }
            ssh-key-path-changed(s) => { root.connect-ssh-key-path-changed(s); }
            iam-access-key-changed(s) => { root.connect-iam-access-key-changed(s); }
            iam-secret-key-changed(s) => { root.connect-iam-secret-key-changed(s); }
            iam-session-token-changed(s) => { root.connect-iam-session-token-changed(s); }
            s3-endpoint-changed(s) => { root.connect-s3-endpoint-changed(s); }
            label-changed(s) => { root.connect-label-changed(s); }
            toggle-save-to-keychain => { root.connect-toggle-save-to-keychain(); }
            browse-ssh-key => { root.connect-browse-ssh-key(); }
            cancel => { root.connect-cancel(); }
            connect => { root.connect-dry-run(); }
            save-and-connect => { root.connect-save-and-connect(); }
            saved-server-selected(id) => { root.connect-saved-server-selected(id); }
            saved-server-delete-requested(id) => { root.connect-saved-server-delete-requested(id); }
            saved-server-delete-confirmed(id) => { root.connect-saved-server-delete-confirmed(id); }
            saved-server-delete-cancelled => { root.connect-saved-server-delete-cancelled(); }
            host-key-trust-once => { root.connect-host-key-trust-once(); }
            host-key-trust-always => { root.connect-host-key-trust-always(); }
            host-key-cancel => { root.connect-host-key-cancel(); }

            // Bubble the child's `input-focused` up so the outer FocusScope's
            // `keymap-bypass-active` gates Cmd+A/C/V past pane bindings.
            changed input-focused => {
                root.connect-modal-input-focused = self.input-focused;
            }
        }

        // Quit-confirmation modal — shown when the user tries to close the
        // window and `general.confirm_on_quit = true`. Rust returns
        // KeepWindowShown from the OS close callback, sets
        // `confirm-quit-visible` to true, then honours accept/cancel here.
        if root.confirm-quit-visible : Rectangle {
            width: parent.width;
            height: parent.height;
            background: #00000099;

            // Swallow clicks on the backdrop.
            TouchArea { width: 100%; height: 100%; }

            Rectangle {
                x: parent.width / 2 - self.width / 2;
                y: parent.height / 2 - self.height / 2;
                width: 360px;
                height: 140px;
                background: Theme.panel-bg-elevated;
                border-radius: Theme.radius-lg;
                border-width: 1px;
                border-color: Theme.border-strong;

                VerticalLayout {
                    padding: Theme.space-4;
                    spacing: Theme.space-3;

                    Text {
                        text: "Quit Atlas?";
                        color: Theme.fg;
                        font-size: Theme.font-size + 2px;
                        font-weight: 600;
                    }

                    Text {
                        text: "Are you sure you want to quit? Any in-flight file operations will be cancelled.";
                        color: Theme.fg-muted;
                        font-size: Theme.font-size;
                        wrap: word-wrap;
                    }

                    HorizontalLayout {
                        alignment: end;
                        spacing: Theme.space-2;

                        Rectangle {
                            width: 90px;
                            height: 28px;
                            background: Theme.hover-bg;
                            border-radius: Theme.radius-sm;
                            cancel-ta := TouchArea {
                                clicked => { root.confirm-quit-cancel(); }
                            }
                            Text {
                                text: "Cancel";
                                color: Theme.fg;
                                font-size: Theme.font-size;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        Rectangle {
                            width: 90px;
                            height: 28px;
                            background: Theme.accent;
                            border-radius: Theme.radius-sm;
                            quit-ta := TouchArea {
                                clicked => { root.confirm-quit-accept(); }
                            }
                            Text {
                                text: "Quit";
                                color: Theme.accent-fg;
                                font-size: Theme.font-size;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }
        }
    }
}
