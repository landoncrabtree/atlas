import { Theme } from "theme.slint";
import { Titlebar } from "components/titlebar.slint";
import { Workspace } from "components/workspace.slint";
import { StatusBar } from "components/status-bar.slint";
import { CommandPalette, PaletteEntry } from "components/command-palette.slint";
import { SearchPanel, SearchRow } from "components/search-panel.slint";
import { OpsPanel, OpRow } from "components/ops-panel.slint";
import { BulkRenameModal, RenamePreview } from "components/bulk-rename.slint";
import { TabEntry } from "components/tab-bar.slint";
import { EntryRowItem, ColumnSpec } from "views/details/column.slint";
import { MillerColData } from "views/miller/miller-state.slint";
import { TreeNode } from "views/tree/tree-view.slint";
import { MetadataFields } from "views/gallery/gallery-metadata.slint";

// Entry-point component for the Atlas application window.
//
// Key-map stop-gap (Slint-level): Esc, Cmd/Ctrl-Shift-P, Cmd/Ctrl-P, Tab are
// handled here via a FocusScope. This is intentionally minimal — a full
// chord-sequence resolver integrating atlas-keymap is a follow-up todo.
export component AtlasWindow inherits Window {
    title: "Atlas";
    preferred-width: 1280px;
    preferred-height: 800px;
    background: Theme.bg;
    default-font-family: Theme.font-family;
    default-font-size: Theme.font-size;

    in property <bool> dark: true;

    in-out property <color> theme-bg: #0f1115;
    in-out property <color> theme-panel-bg: #171a20;
    in-out property <color> theme-panel-bg-elevated: #1e232b;
    in-out property <color> theme-fg: #e6ebf4;
    in-out property <color> theme-fg-muted: #8b95a7;
    in-out property <color> theme-fg-faint: #5a6478;
    in-out property <color> theme-border: #20262f;
    in-out property <color> theme-border-strong: #2b3341;
    in-out property <color> theme-accent: #4a9eff;
    in-out property <color> theme-accent-fg: #ffffff;
    in-out property <color> theme-accent-soft: #4a9eff26;
    in-out property <color> theme-selection-bg: #3d7ac9;
    in-out property <color> theme-selection-fg: #ffffff;
    in-out property <color> theme-hover-bg: #ffffff0d;
    in-out property <color> theme-error: #ff6b6b;
    in-out property <color> theme-success: #5bd18a;
    in-out property <color> theme-warning: #f5c274;

    in-out property <string> theme-font-family: "SF Pro Text, Inter, system-ui, sans-serif";
    in-out property <length> theme-font-size: 13px;
    in-out property <string> theme-monospace: "SF Mono, JetBrains Mono, Menlo, monospace";

    in-out property <length> theme-radius-xs: 4px;
    in-out property <length> theme-radius-sm: 6px;
    in-out property <length> theme-radius-md: 8px;
    in-out property <length> theme-radius-lg: 10px;
    in-out property <length> theme-radius-xl: 14px;
    in-out property <length> theme-space-1: 4px;
    in-out property <length> theme-space-2: 8px;
    in-out property <length> theme-space-3: 12px;
    in-out property <length> theme-space-4: 16px;
    in-out property <length> theme-space-5: 20px;
    in-out property <length> theme-space-6: 24px;
    in-out property <length> theme-space-8: 32px;
    in-out property <length> theme-space-10: 40px;
    in-out property <length> theme-spacing-xs: 4px;
    in-out property <length> theme-spacing-sm: 8px;
    in-out property <length> theme-spacing-md: 12px;
    in-out property <length> theme-spacing-lg: 16px;
    in-out property <length> theme-titlebar-h: 36px;
    in-out property <length> theme-statusbar-h: 24px;
    in-out property <length> theme-tab-h: 32px;
    in-out property <length> theme-addressbar-h: 30px;
    in-out property <length> theme-row-h-default: 30px;
    in-out property <length> theme-row-h-compact: 24px;
    in-out property <length> theme-row-h-spacious: 38px;

    in property <bool> dual-pane: false;
    in property <int> focus-index: 0;

    in property <string> pane0-path: "";
    in property <[string]> pane0-segments: [];
    in property <string> pane0-view-mode: "Details";
    in property <[TabEntry]> pane0-tabs: [{ title: "Home", dirty: false }];
    in property <int> pane0-active-tab: 0;
    in property <[EntryRowItem]> pane0-details-rows: [];
    in property <[ColumnSpec]> pane0-details-columns: [];
    in property <[bool]> pane0-details-selected-mask: [];
    in property <int> pane0-details-selected-anchor: -1;
    in property <int> pane0-details-focused-index: -1;
    in property <[image]> pane0-grid-thumbnails: [];
    in property <[bool]> pane0-grid-has-thumbs: [];
    in property <[bool]> pane0-grid-selected-mask: [];
    in property <int> pane0-grid-focused-index: -1;
    in property <[image]> pane0-gallery-strip-thumbnails: [];
    in property <image> pane0-gallery-preview-image;
    in property <bool> pane0-gallery-preview-loading: false;
    in property <string> pane0-gallery-preview-fallback-glyph: "";
    in property <int> pane0-gallery-focused-index: -1;
    in property <MetadataFields> pane0-gallery-metadata: {
        name: "",
        path: "",
        size-text: "",
        modified-text: "",
        kind: "",
        dimensions: "",
    };
    in property <[TreeNode]> pane0-tree-nodes: [];
    in property <int> pane0-tree-focused-index: -1;
    in property <int> pane0-tree-selected-index: -1;
    in property <[MillerColData]> pane0-miller-columns: [];
    in property <int> pane0-miller-focused-col: 0;

    in property <string> pane1-path: "";
    in property <[string]> pane1-segments: [];
    in property <string> pane1-view-mode: "Details";
    in property <[TabEntry]> pane1-tabs: [];
    in property <int> pane1-active-tab: 0;
    in property <[EntryRowItem]> pane1-details-rows: [];
    in property <[ColumnSpec]> pane1-details-columns: [];
    in property <[bool]> pane1-details-selected-mask: [];
    in property <int> pane1-details-selected-anchor: -1;
    in property <int> pane1-details-focused-index: -1;
    in property <[image]> pane1-grid-thumbnails: [];
    in property <[bool]> pane1-grid-has-thumbs: [];
    in property <[bool]> pane1-grid-selected-mask: [];
    in property <int> pane1-grid-focused-index: -1;
    in property <[image]> pane1-gallery-strip-thumbnails: [];
    in property <image> pane1-gallery-preview-image;
    in property <bool> pane1-gallery-preview-loading: false;
    in property <string> pane1-gallery-preview-fallback-glyph: "";
    in property <int> pane1-gallery-focused-index: -1;
    in property <MetadataFields> pane1-gallery-metadata: {
        name: "",
        path: "",
        size-text: "",
        modified-text: "",
        kind: "",
        dimensions: "",
    };
    in property <[TreeNode]> pane1-tree-nodes: [];
    in property <int> pane1-tree-focused-index: -1;
    in property <int> pane1-tree-selected-index: -1;
    in property <[MillerColData]> pane1-miller-columns: [];
    in property <int> pane1-miller-focused-col: 0;

    in property <int> total-entries: 0;
    in property <int> selected-entries: 0;
    in property <string> status-view-mode: "Details";
    in property <string> sort-by: "Name";
    in property <string> indexer-status: "Stopped";

    in property <bool> palette-visible: false;
    in-out property <string> palette-query: "";
    in property <[PaletteEntry]> palette-results: [];
    in property <int> palette-selected: 0;

    in property <bool> search-panel-visible: false;
    in-out property <string> search-panel-query: "";
    in property <[SearchRow]> search-panel-rows: [];
    in property <int> search-panel-selected: 0;
    in property <string> search-panel-status: "";

    /// Whether the bulk-rename modal is shown.
    in property <bool> bulk-rename-visible: false;
    /// Current find pattern (regex or literal) — pushed from Rust.
    in-out property <string> bulk-rename-pattern: "";
    /// Current replacement string — pushed from Rust.
    in-out property <string> bulk-rename-replacement: "";
    /// Whether regex mode is active.
    in property <bool> bulk-rename-use-regex: false;
    /// Whether matching is case-insensitive.
    in property <bool> bulk-rename-case-insensitive: false;
    /// Computed preview rows.
    in property <[RenamePreview]> bulk-rename-preview-rows: [];
    /// Number of conflicting rows in the preview.
    in property <int> bulk-rename-conflict-count: 0;
    /// Number of rows that will actually be renamed.
    in property <int> bulk-rename-change-count: 0;
    /// Non-empty when the regex pattern failed to compile.
    in property <string> bulk-rename-error-text: "";

    /// Whether the file-operations tray is shown.
    in property <bool> ops-panel-visible: false;
    /// Operation rows shown in the ops tray.
    in property <[OpRow]> ops-rows: [];

    callback palette-query-changed(string);
    callback palette-confirm(string);
    callback palette-dismiss();
    callback search-query-changed(string);
    callback search-confirm(int);
    callback search-close();
    callback toggle-search-panel();
    callback open-search-panel();

    /// Bulk-rename callbacks — dispatched by [`BulkRenameModal`].
    callback bulk-rename-pattern-changed(string);
    callback bulk-rename-replacement-changed(string);
    callback bulk-rename-toggle-regex();
    callback bulk-rename-toggle-case();
    callback bulk-rename-confirm();
    callback bulk-rename-cancel();
    /// Open the bulk-rename modal with the current pane's selection.
    /// Triggered by Cmd/Ctrl+Shift+F2.
    callback open-bulk-rename();

    /// Cancel the operation at `index` in `ops-rows`.
    callback ops-cancel(int);
    /// Remove a terminal row at `index` from the ops panel.
    callback ops-dismiss(int);
    /// Hide the ops panel (rows are retained on the Rust side).
    callback ops-close();
    /// Toggle the ops panel open/closed (Ctrl/Cmd+J).
    callback toggle-ops-panel();
    /// Trigger copy of the current pane's selection to the other pane (F5).
    callback fs-copy();
    /// Trigger move of the current pane's selection to the other pane (F6).
    callback fs-move();
    /// Trigger deletion (to trash) of the current pane's selection (F8).
    callback fs-delete();
    /// Trigger rename of the focused entry (F2).
    callback fs-rename();
    /// Trigger mkdir in the current pane (F7).
    callback fs-mkdir();

    callback pane0-address-submitted(string);
    callback pane0-address-cancelled();
    callback pane0-breadcrumb-clicked(int);
    callback pane0-tab-selected(int);
    callback pane0-tab-closed(int);
    callback pane0-new-tab();
    callback pane0-focused();
    callback pane0-details-row-clicked(int, bool, bool);
    callback pane0-details-row-double-clicked(int);
    callback pane0-details-row-context-menu(int, length, length);
    callback pane0-details-header-clicked(int);
    callback pane0-details-header-resize(int, float);
    callback pane0-grid-entry-clicked(int, bool, bool);
    callback pane0-grid-entry-double-clicked(int);
    callback pane0-grid-entry-context-menu(int, length, length);
    callback pane0-grid-thumbnail-visible(int);
    callback pane0-grid-columns-changed(int);
    callback pane0-gallery-entry-clicked(int);
    callback pane0-gallery-strip-visible(int);
    callback pane0-gallery-preview-visible(int);
    callback pane0-gallery-prev-image();
    callback pane0-gallery-next-image();
    callback pane0-tree-row-clicked(int, bool, bool);
    callback pane0-tree-row-double-clicked(int);
    callback pane0-tree-chevron-clicked(int);
    callback pane0-miller-row-clicked(int, int);
    callback pane0-miller-row-double-clicked(int, int);

    callback pane1-address-submitted(string);
    callback pane1-address-cancelled();
    callback pane1-breadcrumb-clicked(int);
    callback pane1-tab-selected(int);
    callback pane1-tab-closed(int);
    callback pane1-new-tab();
    callback pane1-focused();
    callback pane1-details-row-clicked(int, bool, bool);
    callback pane1-details-row-double-clicked(int);
    callback pane1-details-row-context-menu(int, length, length);
    callback pane1-details-header-clicked(int);
    callback pane1-details-header-resize(int, float);
    callback pane1-grid-entry-clicked(int, bool, bool);
    callback pane1-grid-entry-double-clicked(int);
    callback pane1-grid-entry-context-menu(int, length, length);
    callback pane1-grid-thumbnail-visible(int);
    callback pane1-grid-columns-changed(int);
    callback pane1-gallery-entry-clicked(int);
    callback pane1-gallery-strip-visible(int);
    callback pane1-gallery-preview-visible(int);
    callback pane1-gallery-prev-image();
    callback pane1-gallery-next-image();
    callback pane1-tree-row-clicked(int, bool, bool);
    callback pane1-tree-row-double-clicked(int);
    callback pane1-tree-chevron-clicked(int);
    callback pane1-miller-row-clicked(int, int);
    callback pane1-miller-row-double-clicked(int, int);

    callback toggle-palette();
    callback toggle-dual-pane();
    callback open-goto();
    callback cycle-pane-focus();

    pure function location-str() -> string {
        dual-pane
            ? (focus-index == 0 ? pane0-path : pane1-path)
            : pane0-path
    }

    init => {
        Theme.dark = dark;
        Theme.bg = theme-bg;
        Theme.panel-bg = theme-panel-bg;
        Theme.panel-bg-elevated = theme-panel-bg-elevated;
        Theme.fg = theme-fg;
        Theme.fg-muted = theme-fg-muted;
        Theme.fg-faint = theme-fg-faint;
        Theme.border = theme-border;
        Theme.border-strong = theme-border-strong;
        Theme.accent = theme-accent;
        Theme.accent-fg = theme-accent-fg;
        Theme.accent-soft = theme-accent-soft;
        Theme.selection-bg = theme-selection-bg;
        Theme.selection-fg = theme-selection-fg;
        Theme.hover-bg = theme-hover-bg;
        Theme.error = theme-error;
        Theme.success = theme-success;
        Theme.warning = theme-warning;
        Theme.font-family = theme-font-family;
        Theme.font-size = theme-font-size;
        Theme.monospace = theme-monospace;
        Theme.radius-xs = theme-radius-xs;
        Theme.radius-sm = theme-radius-sm;
        Theme.radius-md = theme-radius-md;
        Theme.radius-lg = theme-radius-lg;
        Theme.radius-xl = theme-radius-xl;
        Theme.space-1 = theme-space-1;
        Theme.space-2 = theme-space-2;
        Theme.space-3 = theme-space-3;
        Theme.space-4 = theme-space-4;
        Theme.space-5 = theme-space-5;
        Theme.space-6 = theme-space-6;
        Theme.space-8 = theme-space-8;
        Theme.space-10 = theme-space-10;
        Theme.spacing-xs = theme-spacing-xs;
        Theme.spacing-sm = theme-spacing-sm;
        Theme.spacing-md = theme-spacing-md;
        Theme.spacing-lg = theme-spacing-lg;
        Theme.titlebar-h = theme-titlebar-h;
        Theme.statusbar-h = theme-statusbar-h;
        Theme.tab-h = theme-tab-h;
        Theme.addressbar-h = theme-addressbar-h;
        Theme.row-h-default = theme-row-h-default;
        Theme.row-h-compact = theme-row-h-compact;
        Theme.row-h-spacious = theme-row-h-spacious;
    }

    changed dark => { Theme.dark = dark; }
    changed theme-bg => { Theme.bg = theme-bg; }
    changed theme-panel-bg => { Theme.panel-bg = theme-panel-bg; }
    changed theme-panel-bg-elevated => { Theme.panel-bg-elevated = theme-panel-bg-elevated; }
    changed theme-fg => { Theme.fg = theme-fg; }
    changed theme-fg-muted => { Theme.fg-muted = theme-fg-muted; }
    changed theme-fg-faint => { Theme.fg-faint = theme-fg-faint; }
    changed theme-border => { Theme.border = theme-border; }
    changed theme-border-strong => { Theme.border-strong = theme-border-strong; }
    changed theme-accent => { Theme.accent = theme-accent; }
    changed theme-accent-fg => { Theme.accent-fg = theme-accent-fg; }
    changed theme-accent-soft => { Theme.accent-soft = theme-accent-soft; }
    changed theme-selection-bg => { Theme.selection-bg = theme-selection-bg; }
    changed theme-selection-fg => { Theme.selection-fg = theme-selection-fg; }
    changed theme-hover-bg => { Theme.hover-bg = theme-hover-bg; }
    changed theme-error => { Theme.error = theme-error; }
    changed theme-success => { Theme.success = theme-success; }
    changed theme-warning => { Theme.warning = theme-warning; }
    changed theme-font-family => { Theme.font-family = theme-font-family; }
    changed theme-font-size => { Theme.font-size = theme-font-size; }
    changed theme-monospace => { Theme.monospace = theme-monospace; }
    changed theme-radius-xs => { Theme.radius-xs = theme-radius-xs; }
    changed theme-radius-sm => { Theme.radius-sm = theme-radius-sm; }
    changed theme-radius-md => { Theme.radius-md = theme-radius-md; }
    changed theme-radius-lg => { Theme.radius-lg = theme-radius-lg; }
    changed theme-radius-xl => { Theme.radius-xl = theme-radius-xl; }
    changed theme-space-1 => { Theme.space-1 = theme-space-1; }
    changed theme-space-2 => { Theme.space-2 = theme-space-2; }
    changed theme-space-3 => { Theme.space-3 = theme-space-3; }
    changed theme-space-4 => { Theme.space-4 = theme-space-4; }
    changed theme-space-5 => { Theme.space-5 = theme-space-5; }
    changed theme-space-6 => { Theme.space-6 = theme-space-6; }
    changed theme-space-8 => { Theme.space-8 = theme-space-8; }
    changed theme-space-10 => { Theme.space-10 = theme-space-10; }
    changed theme-spacing-xs => { Theme.spacing-xs = theme-spacing-xs; }
    changed theme-spacing-sm => { Theme.spacing-sm = theme-spacing-sm; }
    changed theme-spacing-md => { Theme.spacing-md = theme-spacing-md; }
    changed theme-spacing-lg => { Theme.spacing-lg = theme-spacing-lg; }
    changed theme-titlebar-h => { Theme.titlebar-h = theme-titlebar-h; }
    changed theme-statusbar-h => { Theme.statusbar-h = theme-statusbar-h; }
    changed theme-tab-h => { Theme.tab-h = theme-tab-h; }
    changed theme-addressbar-h => { Theme.addressbar-h = theme-addressbar-h; }
    changed theme-row-h-default => { Theme.row-h-default = theme-row-h-default; }
    changed theme-row-h-compact => { Theme.row-h-compact = theme-row-h-compact; }
    changed theme-row-h-spacious => { Theme.row-h-spacious = theme-row-h-spacious; }

    FocusScope {
        key-pressed(event) => {
            if event.text == Key.Escape && palette-visible {
                root.palette-dismiss();
                return accept;
            }
            if (event.modifiers.meta || event.modifiers.control) && event.modifiers.shift && (event.text == "P" || event.text == "p") {
                root.toggle-palette();
                return accept;
            }
            if (event.modifiers.meta || event.modifiers.control) && !event.modifiers.shift && event.text == "p" {
                root.open-goto();
                return accept;
            }
            if event.text == Key.Tab && dual-pane && !palette-visible {
                root.cycle-pane-focus();
                return accept;
            }
            if event.text == Key.Escape && search-panel-visible {
                root.search-close();
                return accept;
            }
            if event.text == Key.Escape && bulk-rename-visible {
                root.bulk-rename-cancel();
                return accept;
            }
            if (event.modifiers.meta || event.modifiers.control) && !event.modifiers.shift && (event.text == "f" || event.text == "F") {
                root.toggle-search-panel();
                return accept;
            }
            if (event.modifiers.meta || event.modifiers.control) && event.modifiers.shift && (event.text == "f" || event.text == "F") {
                root.open-search-panel();
                return accept;
            }
            // Toggle ops panel with Ctrl/Cmd+J.
            if (event.modifiers.meta || event.modifiers.control) && !event.modifiers.shift && (event.text == "j" || event.text == "J") {
                root.toggle-ops-panel();
                return accept;
            }
            // File-operation F-keys (NC/Midnight Commander convention).
            // Cmd/Ctrl+Shift+F2 opens the Bulk Rename modal.
            if event.text == Key.F2 && (event.modifiers.meta || event.modifiers.control) && event.modifiers.shift && !palette-visible {
                root.open-bulk-rename();
                return accept;
            }
            if event.text == Key.F2 && !palette-visible && !bulk-rename-visible {
                root.fs-rename();
                return accept;
            }
            if event.text == Key.F5 && !palette-visible {
                root.fs-copy();
                return accept;
            }
            if event.text == Key.F6 && !palette-visible {
                root.fs-move();
                return accept;
            }
            if event.text == Key.F7 && !palette-visible {
                root.fs-mkdir();
                return accept;
            }
            if event.text == Key.F8 && !palette-visible {
                root.fs-delete();
                return accept;
            }
            // Cmd/Ctrl+Backslash — toggle dual-pane mode.
            if (event.modifiers.meta || event.modifiers.control) && event.text == "\\" && !palette-visible && !search-panel-visible && !bulk-rename-visible {
                root.toggle-dual-pane();
                return accept;
            }
            reject;
        }

        VerticalLayout {
            spacing: 0px;

            Titlebar {
                location: location-str();
            }

            Workspace {
                vertical-stretch: 1;
                dual-pane: root.dual-pane;
                focus-index: root.focus-index;

                pane0-path: root.pane0-path;
                pane0-segments: root.pane0-segments;
                pane0-view-mode: root.pane0-view-mode;
                pane0-tabs: root.pane0-tabs;
                pane0-active-tab: root.pane0-active-tab;
                pane0-details-rows: root.pane0-details-rows;
                pane0-details-columns: root.pane0-details-columns;
                pane0-details-selected-mask: root.pane0-details-selected-mask;
                pane0-details-selected-anchor: root.pane0-details-selected-anchor;
                pane0-details-focused-index: root.pane0-details-focused-index;
                pane0-grid-thumbnails: root.pane0-grid-thumbnails;
                pane0-grid-has-thumbs: root.pane0-grid-has-thumbs;
                pane0-grid-selected-mask: root.pane0-grid-selected-mask;
                pane0-grid-focused-index: root.pane0-grid-focused-index;
                pane0-gallery-strip-thumbnails: root.pane0-gallery-strip-thumbnails;
                pane0-gallery-preview-image: root.pane0-gallery-preview-image;
                pane0-gallery-preview-loading: root.pane0-gallery-preview-loading;
                pane0-gallery-preview-fallback-glyph: root.pane0-gallery-preview-fallback-glyph;
                pane0-gallery-focused-index: root.pane0-gallery-focused-index;
                pane0-gallery-metadata: root.pane0-gallery-metadata;
                pane0-tree-nodes: root.pane0-tree-nodes;
                pane0-tree-focused-index: root.pane0-tree-focused-index;
                pane0-tree-selected-index: root.pane0-tree-selected-index;
                pane0-miller-columns: root.pane0-miller-columns;
                pane0-miller-focused-col: root.pane0-miller-focused-col;

                pane1-path: root.pane1-path;
                pane1-segments: root.pane1-segments;
                pane1-view-mode: root.pane1-view-mode;
                pane1-tabs: root.pane1-tabs;
                pane1-active-tab: root.pane1-active-tab;
                pane1-details-rows: root.pane1-details-rows;
                pane1-details-columns: root.pane1-details-columns;
                pane1-details-selected-mask: root.pane1-details-selected-mask;
                pane1-details-selected-anchor: root.pane1-details-selected-anchor;
                pane1-details-focused-index: root.pane1-details-focused-index;
                pane1-grid-thumbnails: root.pane1-grid-thumbnails;
                pane1-grid-has-thumbs: root.pane1-grid-has-thumbs;
                pane1-grid-selected-mask: root.pane1-grid-selected-mask;
                pane1-grid-focused-index: root.pane1-grid-focused-index;
                pane1-gallery-strip-thumbnails: root.pane1-gallery-strip-thumbnails;
                pane1-gallery-preview-image: root.pane1-gallery-preview-image;
                pane1-gallery-preview-loading: root.pane1-gallery-preview-loading;
                pane1-gallery-preview-fallback-glyph: root.pane1-gallery-preview-fallback-glyph;
                pane1-gallery-focused-index: root.pane1-gallery-focused-index;
                pane1-gallery-metadata: root.pane1-gallery-metadata;
                pane1-tree-nodes: root.pane1-tree-nodes;
                pane1-tree-focused-index: root.pane1-tree-focused-index;
                pane1-tree-selected-index: root.pane1-tree-selected-index;
                pane1-miller-columns: root.pane1-miller-columns;
                pane1-miller-focused-col: root.pane1-miller-focused-col;

                pane0-address-submitted(p) => { root.pane0-address-submitted(p); }
                pane0-address-cancelled => { root.pane0-address-cancelled(); }
                pane0-breadcrumb-clicked(i) => { root.pane0-breadcrumb-clicked(i); }
                pane0-tab-selected(i) => { root.pane0-tab-selected(i); }
                pane0-tab-closed(i) => { root.pane0-tab-closed(i); }
                pane0-new-tab => { root.pane0-new-tab(); }
                pane0-clicked => { root.pane0-focused(); }
                pane0-details-row-clicked(i, ctrl, shift) => { root.pane0-details-row-clicked(i, ctrl, shift); }
                pane0-details-row-double-clicked(i) => { root.pane0-details-row-double-clicked(i); }
                pane0-details-row-context-menu(i, x, y) => { root.pane0-details-row-context-menu(i, x, y); }
                pane0-details-header-clicked(i) => { root.pane0-details-header-clicked(i); }
                pane0-details-header-resize(i, w) => { root.pane0-details-header-resize(i, w); }
                pane0-grid-entry-clicked(i, ctrl, shift) => { root.pane0-grid-entry-clicked(i, ctrl, shift); }
                pane0-grid-entry-double-clicked(i) => { root.pane0-grid-entry-double-clicked(i); }
                pane0-grid-entry-context-menu(i, x, y) => { root.pane0-grid-entry-context-menu(i, x, y); }
                pane0-grid-thumbnail-visible(i) => { root.pane0-grid-thumbnail-visible(i); }
                pane0-grid-columns-changed(c) => { root.pane0-grid-columns-changed(c); }
                pane0-gallery-entry-clicked(i) => { root.pane0-gallery-entry-clicked(i); }
                pane0-gallery-strip-visible(i) => { root.pane0-gallery-strip-visible(i); }
                pane0-gallery-preview-visible(i) => { root.pane0-gallery-preview-visible(i); }
                pane0-gallery-prev-image => { root.pane0-gallery-prev-image(); }
                pane0-gallery-next-image => { root.pane0-gallery-next-image(); }
                pane0-tree-row-clicked(i, ctrl, shift) => { root.pane0-tree-row-clicked(i, ctrl, shift); }
                pane0-tree-row-double-clicked(i) => { root.pane0-tree-row-double-clicked(i); }
                pane0-tree-chevron-clicked(i) => { root.pane0-tree-chevron-clicked(i); }
                pane0-miller-row-clicked(col, row) => { root.pane0-miller-row-clicked(col, row); }
                pane0-miller-row-double-clicked(col, row) => { root.pane0-miller-row-double-clicked(col, row); }

                pane1-address-submitted(p) => { root.pane1-address-submitted(p); }
                pane1-address-cancelled => { root.pane1-address-cancelled(); }
                pane1-breadcrumb-clicked(i) => { root.pane1-breadcrumb-clicked(i); }
                pane1-tab-selected(i) => { root.pane1-tab-selected(i); }
                pane1-tab-closed(i) => { root.pane1-tab-closed(i); }
                pane1-new-tab => { root.pane1-new-tab(); }
                pane1-clicked => { root.pane1-focused(); }
                pane1-details-row-clicked(i, ctrl, shift) => { root.pane1-details-row-clicked(i, ctrl, shift); }
                pane1-details-row-double-clicked(i) => { root.pane1-details-row-double-clicked(i); }
                pane1-details-row-context-menu(i, x, y) => { root.pane1-details-row-context-menu(i, x, y); }
                pane1-details-header-clicked(i) => { root.pane1-details-header-clicked(i); }
                pane1-details-header-resize(i, w) => { root.pane1-details-header-resize(i, w); }
                pane1-grid-entry-clicked(i, ctrl, shift) => { root.pane1-grid-entry-clicked(i, ctrl, shift); }
                pane1-grid-entry-double-clicked(i) => { root.pane1-grid-entry-double-clicked(i); }
                pane1-grid-entry-context-menu(i, x, y) => { root.pane1-grid-entry-context-menu(i, x, y); }
                pane1-grid-thumbnail-visible(i) => { root.pane1-grid-thumbnail-visible(i); }
                pane1-grid-columns-changed(c) => { root.pane1-grid-columns-changed(c); }
                pane1-gallery-entry-clicked(i) => { root.pane1-gallery-entry-clicked(i); }
                pane1-gallery-strip-visible(i) => { root.pane1-gallery-strip-visible(i); }
                pane1-gallery-preview-visible(i) => { root.pane1-gallery-preview-visible(i); }
                pane1-gallery-prev-image => { root.pane1-gallery-prev-image(); }
                pane1-gallery-next-image => { root.pane1-gallery-next-image(); }
                pane1-tree-row-clicked(i, ctrl, shift) => { root.pane1-tree-row-clicked(i, ctrl, shift); }
                pane1-tree-row-double-clicked(i) => { root.pane1-tree-row-double-clicked(i); }
                pane1-tree-chevron-clicked(i) => { root.pane1-tree-chevron-clicked(i); }
                pane1-miller-row-clicked(col, row) => { root.pane1-miller-row-clicked(col, row); }
                pane1-miller-row-double-clicked(col, row) => { root.pane1-miller-row-double-clicked(col, row); }
            }

            StatusBar {
                total-entries: root.total-entries;
                selected-entries: root.selected-entries;
                view-mode: root.status-view-mode;
                sort-by: root.sort-by;
                indexer-status: root.indexer-status;
            }
        }

        // File-operations tray — auto-shown by Rust when ops are queued.
        OpsPanel {
            x: 0px;
            y: parent.height - self.height;
            width: parent.width;
            visible-panel: root.ops-panel-visible;
            rows: root.ops-rows;
            cancel(i) => { root.ops-cancel(i); }
            dismiss(i) => { root.ops-dismiss(i); }
            close => { root.ops-close(); }
        }

        CommandPalette {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            visible: root.palette-visible;
            query <=> root.palette-query;
            results: root.palette-results;
            selected-index: root.palette-selected;
            query-changed(q) => { root.palette-query-changed(q); }
            confirm(id) => { root.palette-confirm(id); }
            dismiss => { root.palette-dismiss(); }
        }

        SearchPanel {
            x: parent.width * 0.6;
            y: 0px;
            width: parent.width * 0.4;
            height: parent.height;
            visible-panel: root.search-panel-visible;
            query: root.search-panel-query;
            rows: root.search-panel-rows;
            selected-index: root.search-panel-selected;
            status-text: root.search-panel-status;
            query-changed(q) => { root.search-query-changed(q); }
            confirm(i) => { root.search-confirm(i); }
            close => { root.search-close(); }
        }

        BulkRenameModal {
            x: 0px;
            y: 0px;
            width: parent.width;
            height: parent.height;
            visible-modal: root.bulk-rename-visible;
            pattern <=> root.bulk-rename-pattern;
            replacement <=> root.bulk-rename-replacement;
            use-regex: root.bulk-rename-use-regex;
            case-insensitive: root.bulk-rename-case-insensitive;
            preview-rows: root.bulk-rename-preview-rows;
            conflict-count: root.bulk-rename-conflict-count;
            change-count: root.bulk-rename-change-count;
            error-text: root.bulk-rename-error-text;
            pattern-changed(q) => { root.bulk-rename-pattern-changed(q); }
            replacement-changed(q) => { root.bulk-rename-replacement-changed(q); }
            toggle-regex => { root.bulk-rename-toggle-regex(); }
            toggle-case => { root.bulk-rename-toggle-case(); }
            confirm => { root.bulk-rename-confirm(); }
            cancel => { root.bulk-rename-cancel(); }
        }
    }
}
