// Design tokens for Atlas. Single source of truth for colors, spacing,
// typography, and geometry. All properties are in-out so they can be
// pushed from Rust via AppShell::apply_theme.

export global Theme {
    in-out property <bool> dark: true;

    in-out property <color> bg: #0e1116;
    in-out property <color> panel-bg: #161b22;
    in-out property <color> fg: #e6edf3;
    in-out property <color> fg-muted: #7d8590;
    in-out property <color> border: #30363d;
    in-out property <color> accent: #2f81f7;
    in-out property <color> accent-fg: #ffffff;
    in-out property <color> selection-bg: #1f6feb;
    in-out property <color> selection-fg: #ffffff;
    in-out property <color> error: #f85149;
    in-out property <color> success: #3fb950;
    in-out property <color> warning: #d29922;

    in-out property <string> font-family: "Inter";
    in-out property <length> font-size: 14px;
    in-out property <string> monospace: "JetBrains Mono";

    in-out property <length> radius-sm: 4px;
    in-out property <length> radius-md: 8px;

    in-out property <length> spacing-xs: 4px;
    in-out property <length> spacing-sm: 8px;
    in-out property <length> spacing-md: 12px;
    in-out property <length> spacing-lg: 16px;

    in-out property <length> titlebar-h: 36px;
    in-out property <length> statusbar-h: 24px;
    in-out property <length> tab-h: 28px;
}
