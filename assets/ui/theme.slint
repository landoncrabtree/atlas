// Design tokens for Atlas. Single source of truth for colors, spacing,
// typography, and geometry. Base properties are in-out so they can be
// pushed from Rust via AppShell::apply_theme; semantic aliases are derived.

export global Theme {
    in-out property <bool> dark: true;

    // ── Palette ──────────────────────────────────────────────────────────────
    in-out property <color> bg: #0f1115;
    in-out property <color> panel-bg: #171a20;
    in-out property <color> panel-bg-elevated: #1e232b;
    in-out property <color> fg: #e6ebf4;
    in-out property <color> fg-muted: #8b95a7;
    in-out property <color> fg-faint: #5a6478;
    in-out property <color> border: #20262f;
    in-out property <color> border-strong: #2b3341;
    in-out property <color> accent: #4a9eff;
    in-out property <color> accent-fg: #ffffff;
    in-out property <color> accent-soft: #4a9eff26;
    in-out property <color> selection-bg: #3d7ac9;
    in-out property <color> selection-fg: #ffffff;
    in-out property <color> hover-bg: #ffffff0d;
    in-out property <color> error: #ff6b6b;
    in-out property <color> success: #5bd18a;
    in-out property <color> warning: #f5c274;

    // ── Typography ────────────────────────────────────────────────────────────
    //
    // Slint 1.17's FontRequest.family (i-slint-core/graphics.rs) is a
    // single family name, not a CSS-style comma-separated stack. Leave
    // this empty to fall back to Slint's built-in per-platform default
    // (SF Pro on macOS, Segoe UI on Windows, system-ui on Linux). Set
    // it from Rust via AppShell::apply_theme, which reads
    // `config.ui.font_family` — see `apply_font_overrides` in
    // crates/atlas-app/src/main.rs.
    in-out property <string> font-family: "";
    in-out property <length> font-size: 13px;
    in-out property <string> monospace: "";

    // Icon font: the bundled Symbols Nerd Font Mono TTF (import in
    // atlas.slint) registers this family process-wide. Bind Text
    // elements displaying PUA icon glyphs to `Theme.icon-font-family`
    // so they render Nerd Font icons instead of the user's text font's
    // fallback tofu. Since Slint's font-family is a single family and
    // does NOT accept a CSS-style fallback list, this MUST point at
    // the bundled family alone. Any user override would defeat the
    // fallback for icon glyphs.
    in-out property <string> icon-font-family: "Symbols Nerd Font Mono";

    // ── Icon pack toggle (Phase 2.11) ─────────────────────────────────────────
    //
    // `icon-pack-is-ascii` is written from Rust (AppShell::set_icon_pack) at
    // startup + on config hot-reload. It controls both which font the icon
    // Text elements bind to (via `icon-family-for-pack` below) and — through
    // the Rust-side row rebuild — which glyph string ends up in each row's
    // `kind-icon` field. When `false` (default), icon cells render Nerd Font
    // PUA glyphs in `icon-font-family`. When `true`, they render `[D]`/`[c]`/
    // `[i]`/… fallback tokens in the user's normal text font.
    //
    // Views bind icon Text elements to `Theme.icon-family-for-pack` instead
    // of `Theme.icon-font-family` so the same Text node handles both cases
    // — no duplicate widget trees, no `if`-branch in every view row.
    in-out property <bool> icon-pack-is-ascii: false;
    out property <string> icon-family-for-pack: icon-pack-is-ascii ? font-family : icon-font-family;

    // ── Radii ─────────────────────────────────────────────────────────────────
    in-out property <length> radius-xs: 4px;
    in-out property <length> radius-sm: 6px;
    in-out property <length> radius-md: 8px;
    in-out property <length> radius-lg: 10px;
    in-out property <length> radius-xl: 14px;

    // ── Spacing (8pt grid) ────────────────────────────────────────────────────
    in-out property <length> space-1: 4px;
    in-out property <length> space-2: 8px;
    in-out property <length> space-3: 12px;
    in-out property <length> space-4: 16px;
    in-out property <length> space-5: 20px;
    in-out property <length> space-6: 24px;
    in-out property <length> space-8: 32px;
    in-out property <length> space-10: 40px;

    // ── Legacy spacing aliases (kept for compat) ──────────────────────────────
    in-out property <length> spacing-xs: 4px;
    in-out property <length> spacing-sm: 8px;
    in-out property <length> spacing-md: 12px;
    in-out property <length> spacing-lg: 16px;

    // ── Chrome heights ────────────────────────────────────────────────────────
    in-out property <length> titlebar-h: 36px;
    in-out property <length> statusbar-h: 24px;
    in-out property <length> tab-h: 32px;
    in-out property <length> addressbar-h: 30px;
    in-out property <length> row-h-default: 30px;
    in-out property <length> row-h-compact: 24px;
    in-out property <length> row-h-spacious: 38px;

    // ── Motion ────────────────────────────────────────────────────────────────
    // When `animations` is false every `animate {}` block resolves to 0ms and
    // becomes an instant transition. Wired from `config.ui.animations`.
    in-out property <bool> animations: true;
    // Standard hover/highlight easing duration; use `animate x { duration: Theme.motion-quick; }`.
    in-out property <duration> motion-quick: animations ? 120ms : 0ms;
    // Faster transition (list-row hover backgrounds).
    in-out property <duration> motion-fast: animations ? 100ms : 0ms;

    // ── macOS-native surface semantics ────────────────────────────────────────
    // These semantic aliases keep modal/menu composition aligned with Apple HIG:
    // compact controls, varied radii, soft borders, hierarchy over nested boxes,
    // and a restrained accent color.
    // `modal-radius` matches `radius-xl` (14 px) so every top-level sheet —
    // conflict prompt, progress modal, palette panel, connect modal, bulk
    // rename — reads with the same soft macOS Sequoia curvature. See
    // design.instructions.md §Radii: modal chrome uses `radius_xl`; interior
    // buttons/inputs/lists keep the smaller varied radii (6/5/8).
    out property <color> modal-scrim: #00000066;
    out property <color> modal-bg: panel-bg-elevated;
    out property <color> modal-border: border.with-alpha(0.72);
    out property <color> modal-shadow-color: #00000040;
    out property <length> modal-radius: radius-xl;
    out property <length> modal-shadow-blur: 40px;
    out property <length> modal-shadow-y: 10px;
    out property <length> modal-title-size: 15px;

    out property <length> control-height: 29px;
    out property <length> field-radius: 5px;
    out property <length> button-radius: 6px;
    out property <length> segmented-radius: 6px;
    out property <length> segmented-selected-radius: 5px;
    out property <length> list-radius: 8px;
    out property <length> list-row-height: 38px;
    out property <length> progress-height: 4px;

    out property <length> section-label-size: 12px;
    out property <length> field-label-size: 12px;
    out property <length> button-font-size: 12px;
    out property <color> section-label-color: fg-muted.with-alpha(0.82);
    out property <color> field-label-color: fg-muted.with-alpha(0.88);
    out property <color> placeholder-color: fg-faint.with-alpha(0.74);

    out property <color> field-bg: dark ? #ffffff0a : #ffffffcc;
    out property <color> field-bg-focus: dark ? #ffffff0d : #ffffff;
    out property <color> field-border: border.with-alpha(0.80);
    out property <color> field-border-focus: border-strong.with-alpha(0.92);

    out property <color> secondary-button-bg: dark ? #ffffff10 : #ffffffd9;
    out property <color> secondary-button-bg-hover: dark ? #ffffff18 : #ffffff;
    out property <color> secondary-button-border: border.with-alpha(0.80);
    out property <color> secondary-button-border-hover: border-strong.with-alpha(0.88);
    out property <color> accent-hover: accent.mix(fg, 0.10);
    out property <color> button-shadow-color: #00000024;

    out property <color> segmented-bg: dark ? #00000026 : #00000010;
    out property <color> segmented-border: border.with-alpha(0.78);
    out property <color> segmented-divider: border.with-alpha(0.72);
    out property <color> segmented-selected-bg: dark ? #ffffff18 : #ffffff;
    out property <color> segmented-selected-border: dark ? #ffffff18 : #00000014;
    out property <color> segmented-shadow-color: #00000022;

    out property <color> list-bg: dark ? #00000016 : #00000008;
    out property <color> list-border: border.with-alpha(0.70);
    out property <color> progress-track: dark ? #00000036 : #00000018;
    out property <color> ops-panel-shadow-color: #00000038;
}
