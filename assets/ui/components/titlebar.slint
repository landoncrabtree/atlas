import { Theme } from "../theme.slint";

// Custom titlebar. On macOS with no-frame: true the OS draws traffic-light
// buttons at the left inset, so we leave a 78px spacer for them. The
// address bar + breadcrumbs below already show the current path, so the
// titlebar is intentionally minimal — no in-content branding, no path.
export component Titlebar {
    in property <string> location: "";  // reserved for future use (window title on tab-per-window mode)

    height: Theme.titlebar-h;

    Rectangle {
        background: Theme.panel-bg;

        // Bottom border
        Rectangle {
            y: parent.height - 1px;
            height: 1px;
            background: Theme.border;
        }
    }
}
