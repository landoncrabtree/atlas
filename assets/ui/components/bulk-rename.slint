import { Theme } from "../theme.slint";
import { ListView } from "std-widgets.slint";
import {
    AtlasModal, AtlasPrimaryButton, AtlasSecondaryButton,
    AtlasTextField, SectionLabel,
} from "atlas-controls.slint";

export struct RenamePreview {
    original: string,
    proposed: string,
    is-conflict: bool,
    is-unchanged: bool,
}

// Bulk rename modal (Shift+Cmd+F2 / Ctrl+Shift+F2). Migrated in the
// polish-2 pass to compose the shared `atlas-controls` primitives
// (AtlasModal, AtlasTextField, SectionLabel, primary/secondary
// buttons) so its visual grammar matches every other modal in the
// tree.
//
// Design refs (design.instructions.md):
// - §Bulk rename modal: 620 wide, up to 500 tall, Details-view grammar
//   for the preview table.
// - §Restrained accent: Confirm is the modal's single primary CTA —
//   it commits the rename, which is unambiguously the truly-primary
//   action.
export component BulkRenameModal inherits Rectangle {
    in property <bool> visible-modal: false;
    in-out property <string> pattern: "";
    in-out property <string> replacement: "";
    in property <bool> use-regex: false;
    in property <bool> case-insensitive: false;
    in property <[RenamePreview]> preview-rows: [];
    in property <int> conflict-count: 0;
    in property <int> change-count: 0;
    in property <string> error-text: "";
    // Bubbled to `atlas.slint` so the root chord dispatcher can switch
    // to Global context when a rename input owns focus. See
    // ui-composition.instructions.md §5.
    out property <bool> input-focused: find-field.focused || replace-field.focused;

    callback pattern-changed(string);
    callback replacement-changed(string);
    callback toggle-regex();
    callback toggle-case();
    callback confirm();
    callback cancel();

    width: 100%;
    height: 100%;

    property <bool> confirm-enabled:
        change-count > 0 && conflict-count == 0 && error-text == "";

    AtlasModal {
        width: 100%;
        height: 100%;
        visible-modal: root.visible-modal;
        title: "";
        // Bulk rename gets extra width because the preview table shows
        // two columns of file names side-by-side.
        modal-width: 620px;
        modal-height: 460px;
        dismissed => { root.cancel(); }

        // ── header ─────────────────────────────────────────────────────
        //
        // `title` style (15 px semibold) + a subdued count on the same
        // line. Sentence case; no all-caps.
        HorizontalLayout {
            spacing: Theme.space-2;
            alignment: start;

            Text {
                text: "Rename";
                color: Theme.fg;
                font-size: Theme.modal-title-size;
                font-weight: 600;
                vertical-alignment: center;
            }

            Text {
                text: preview-rows.length + " items";
                color: Theme.fg-muted;
                font-size: 12px;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }
        }

        // ── find + replace fields ──────────────────────────────────────
        //
        // Two AtlasFieldGroup-style rows. We compose SectionLabel +
        // AtlasTextField directly instead of using AtlasFieldGroup
        // because AtlasFieldGroup fixes its height at 47 px (control +
        // 18) — inside a modal we want a slightly tighter cadence.
        VerticalLayout {
            spacing: Theme.space-1 + 2px;

            SectionLabel { label: "Find"; }
            find-field := AtlasTextField {
                text <=> root.pattern;
                placeholder: "Text to match";
                auto-focus: true;
                edited(q) => { root.pattern-changed(q); }
                escape-pressed => { root.cancel(); }
            }
        }

        VerticalLayout {
            spacing: Theme.space-1 + 2px;

            SectionLabel { label: "Replace with"; }
            replace-field := AtlasTextField {
                text <=> root.replacement;
                placeholder: "Replacement text";
                edited(q) => { root.replacement-changed(q); }
                escape-pressed => { root.cancel(); }
            }
        }

        // ── toggles row ────────────────────────────────────────────────
        //
        // Neutral checkbox-style toggles per Finder — no accent
        // flooding. The 128-px width on "Case insensitive" is picked
        // so its right edge aligns with the Find/Replace fields.
        HorizontalLayout {
            spacing: Theme.space-2;
            alignment: start;

            regex-toggle := Rectangle {
                width: 80px;
                height: Theme.control-height;
                border-radius: Theme.button-radius;
                border-width: 1px;
                border-color: root.use-regex
                    ? Theme.border-strong.with-alpha(0.88)
                    : Theme.secondary-button-border;
                background: root.use-regex
                    ? Theme.segmented-selected-bg
                    : Theme.secondary-button-bg;
                animate background { duration: Theme.motion-fast; easing: ease-out; }

                TouchArea {
                    width: 100%; height: 100%;
                    clicked => { root.toggle-regex(); }
                }

                Text {
                    text: "Regex";
                    color: Theme.fg;
                    font-size: Theme.button-font-size;
                    font-weight: root.use-regex ? 600 : 400;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            case-toggle := Rectangle {
                width: 132px;
                height: Theme.control-height;
                border-radius: Theme.button-radius;
                border-width: 1px;
                border-color: root.case-insensitive
                    ? Theme.border-strong.with-alpha(0.88)
                    : Theme.secondary-button-border;
                background: root.case-insensitive
                    ? Theme.segmented-selected-bg
                    : Theme.secondary-button-bg;
                animate background { duration: Theme.motion-fast; easing: ease-out; }

                TouchArea {
                    width: 100%; height: 100%;
                    clicked => { root.toggle-case(); }
                }

                Text {
                    text: "Case insensitive";
                    color: Theme.fg;
                    font-size: Theme.button-font-size;
                    font-weight: root.case-insensitive ? 600 : 400;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }

        // ── inline error banner ────────────────────────────────────────
        if error-text != "": Rectangle {
            height: 24px;
            background: Theme.error.with-alpha(0.12);
            border-radius: Theme.radius-sm;

            HorizontalLayout {
                padding-left: Theme.space-3;
                padding-right: Theme.space-3;
                alignment: center;

                Text {
                    text: error-text;
                    color: Theme.error;
                    font-size: 12px;
                    overflow: elide;
                    horizontal-alignment: left;
                    vertical-alignment: center;
                }
            }
        }

        // ── preview column headers ─────────────────────────────────────
        //
        // Details-view grammar: `micro` style (10 px, semibold,
        // fg-muted), 28-px header row.
        Rectangle {
            height: 22px;

            HorizontalLayout {
                padding-left: Theme.space-2;
                padding-right: Theme.space-2;
                spacing: Theme.space-2;

                Text {
                    text: "Original";
                    color: Theme.fg-muted;
                    font-size: 10px;
                    font-weight: 600;
                    horizontal-stretch: 1;
                    vertical-alignment: center;
                }
                Text {
                    text: "";
                    width: 16px;
                }
                Text {
                    text: "Proposed";
                    color: Theme.fg-muted;
                    font-size: 10px;
                    font-weight: 600;
                    horizontal-stretch: 1;
                    vertical-alignment: center;
                }
            }
        }

        // ── preview table ──────────────────────────────────────────────
        //
        // Row grammar mirrors Details view: hover fill, conflict rows
        // tinted with `Theme.error` at low alpha, unchanged rows
        // dimmed to 45 %.
        Rectangle {
            vertical-stretch: 1;
            border-width: 1px;
            border-color: Theme.list-border;
            border-radius: Theme.list-radius;
            background: Theme.list-bg;
            clip: true;

            ListView {
                for row[i] in preview-rows: row-bg := Rectangle {
                    height: Theme.row-h-default;
                    background: row.is-conflict
                        ? Theme.error.with-alpha(0.10)
                        : (row-ta.has-hover ? Theme.hover-bg : transparent);
                    opacity: row.is-unchanged ? 0.45 : 1.0;
                    border-radius: Theme.radius-sm;

                    row-ta := TouchArea { width: 100%; height: 100%; }

                    HorizontalLayout {
                        padding-left: Theme.space-3;
                        padding-right: Theme.space-3;
                        spacing: Theme.space-2;
                        alignment: center;

                        Text {
                            text: row.original;
                            color: Theme.fg;
                            font-size: Theme.font-size;
                            overflow: elide;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }

                        Text {
                            text: "→";
                            color: Theme.fg-muted;
                            font-size: Theme.font-size;
                            vertical-alignment: center;
                            width: 16px;
                            horizontal-alignment: center;
                        }

                        Text {
                            text: row.proposed;
                            color: row.is-conflict ? Theme.error : Theme.fg;
                            font-size: Theme.font-size;
                            font-weight: row.is-conflict ? 500 : 400;
                            overflow: elide;
                            vertical-alignment: center;
                            horizontal-stretch: 1;
                        }
                    }
                }
            }
        }

        // ── footer buttons ─────────────────────────────────────────────
        //
        // Left: conflict summary in `error` colour if any conflicts
        // block confirmation. Right: Cancel + Confirm — Confirm is the
        // single AtlasPrimaryButton, because it commits the rename and
        // is unambiguously the truly-primary action per
        // design.instructions.md §Bulk rename modal.
        HorizontalLayout {
            spacing: Theme.space-2;
            alignment: end;

            if conflict-count > 0: Text {
                text: conflict-count + " conflict" + (conflict-count == 1 ? "" : "s");
                color: Theme.error;
                font-size: 12px;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            AtlasSecondaryButton {
                button-width: 80px;
                text: "Cancel";
                clicked => { root.cancel(); }
            }

            AtlasPrimaryButton {
                button-width: 140px;
                text: "Rename " + change-count + " file" + (change-count == 1 ? "" : "s");
                enabled: root.confirm-enabled;
                clicked => { root.confirm(); }
            }
        }
    }
}
