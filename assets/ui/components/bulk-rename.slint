import { Theme } from "../theme.slint";
import { ListView } from "std-widgets.slint";

// Preview row model: one entry in the live-rename table.
export struct RenamePreview {
    // Original file name (last path segment).
    original: string,
    // Proposed new file name after substitution.
    proposed: string,
    // True when the proposed name collides with another proposed name or with
    // an existing sibling that is not part of the rename set.
    is-conflict: bool,
    // True when the substitution produces no change.
    is-unchanged: bool,
}

// Full-screen overlay that hosts the Bulk Rename dialog.
//
// Visibility is controlled by `visible-modal`.  When hidden the component
// renders nothing.
export component BulkRenameModal inherits Rectangle {
    // ── Inputs (pushed from Rust) ─────────────────────────────────────────────
    in property <bool> visible-modal: false;
    /// Current find pattern (regex or literal).
    in-out property <string> pattern: "";
    /// Current replacement string.
    in-out property <string> replacement: "";
    /// Whether regex mode is active (false = literal find / replace).
    in property <bool> use-regex: false;
    /// Whether matching is case-insensitive.
    in property <bool> case-insensitive: false;
    /// Computed preview rows.
    in property <[RenamePreview]> preview-rows: [];
    /// Number of rows with `is-conflict = true`.
    in property <int> conflict-count: 0;
    /// Number of rows that will actually be renamed (not unchanged, not
    /// conflicted).
    in property <int> change-count: 0;
    /// Non-empty when the regex pattern failed to compile.
    in property <string> error-text: "";

    // ── Callbacks (dispatched to Rust) ────────────────────────────────────────
    /// User edited the find input.
    callback pattern-changed(string);
    /// User edited the replacement input.
    callback replacement-changed(string);
    /// User clicked the "Regex" toggle.
    callback toggle-regex();
    /// User clicked the "Case insensitive" toggle.
    callback toggle-case();
    /// User confirmed the rename operation.
    callback confirm();
    /// User dismissed the modal (Cancel button or Escape).
    callback cancel();

    // ── Layout ────────────────────────────────────────────────────────────────

    if visible-modal: Rectangle {
        width: 100%;
        height: 100%;
        background: #00000088;

        // Click on the dimmed backdrop to cancel.
        TouchArea {
            width: 100%;
            height: 100%;
            clicked => { root.cancel(); }
        }

        // Centered dialog box.
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(600px, parent.width - 48px);
            height: min(460px, parent.height - 96px);
            background: Theme.panel-bg;
            border-width: 1px;
            border-color: Theme.border;
            border-radius: Theme.radius-md;

            // Absorb clicks so they don't fall through to the backdrop.
            TouchArea {
                width: 100%;
                height: 100%;
            }

            VerticalLayout {
                padding: Theme.spacing-md;
                spacing: Theme.spacing-sm;

                // ── Header ────────────────────────────────────────────────────
                Text {
                    text: "Bulk Rename (" + preview-rows.length + " items)";
                    color: Theme.fg;
                    font-size: Theme.font-size;
                    font-weight: 600;
                    horizontal-alignment: left;
                }

                Rectangle { height: 1px; background: Theme.border; }

                // ── Find input ────────────────────────────────────────────────
                VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: "Find";
                        color: Theme.fg-muted;
                        font-size: 12px;
                    }
                    Rectangle {
                        height: 32px;
                        border-width: 1px;
                        border-color: Theme.border;
                        border-radius: Theme.radius-sm;
                        background: Theme.bg;

                        HorizontalLayout {
                            padding-left: Theme.spacing-sm;
                            padding-right: Theme.spacing-sm;
                            alignment: center;

                            TextInput {
                                text <=> root.pattern;
                                color: Theme.fg;
                                font-size: Theme.font-size;
                                vertical-alignment: center;
                                single-line: true;
                                edited => { root.pattern-changed(self.text); }
                                key-pressed(event) => {
                                    if event.text == Key.Escape {
                                        root.cancel();
                                        return accept;
                                    }
                                    reject;
                                }
                            }
                        }
                    }
                }

                // ── Replace-with input ────────────────────────────────────────
                VerticalLayout {
                    spacing: 4px;
                    Text {
                        text: "Replace with";
                        color: Theme.fg-muted;
                        font-size: 12px;
                    }
                    Rectangle {
                        height: 32px;
                        border-width: 1px;
                        border-color: Theme.border;
                        border-radius: Theme.radius-sm;
                        background: Theme.bg;

                        HorizontalLayout {
                            padding-left: Theme.spacing-sm;
                            padding-right: Theme.spacing-sm;
                            alignment: center;

                            TextInput {
                                text <=> root.replacement;
                                color: Theme.fg;
                                font-size: Theme.font-size;
                                vertical-alignment: center;
                                single-line: true;
                                edited => { root.replacement-changed(self.text); }
                                key-pressed(event) => {
                                    if event.text == Key.Escape {
                                        root.cancel();
                                        return accept;
                                    }
                                    reject;
                                }
                            }
                        }
                    }
                }

                // ── Mode toggles ──────────────────────────────────────────────
                HorizontalLayout {
                    spacing: Theme.spacing-sm;

                    // "Regex" toggle button.
                    Rectangle {
                        width: 72px;
                        height: 26px;
                        border-radius: Theme.radius-sm;
                        border-width: 1px;
                        background: use-regex ? Theme.accent : Theme.bg;
                        border-color: use-regex ? Theme.accent : Theme.border;

                        TouchArea {
                            width: 100%; height: 100%;
                            clicked => { root.toggle-regex(); }
                        }

                        Text {
                            text: "Regex";
                            color: use-regex ? Theme.accent-fg : Theme.fg;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    // "Case insensitive" toggle button.
                    Rectangle {
                        width: 128px;
                        height: 26px;
                        border-radius: Theme.radius-sm;
                        border-width: 1px;
                        background: case-insensitive ? Theme.accent : Theme.bg;
                        border-color: case-insensitive ? Theme.accent : Theme.border;

                        TouchArea {
                            width: 100%; height: 100%;
                            clicked => { root.toggle-case(); }
                        }

                        Text {
                            text: "Case insensitive";
                            color: case-insensitive ? Theme.accent-fg : Theme.fg;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                // ── Regex compile error ───────────────────────────────────────
                if error-text != "": Rectangle {
                    height: 24px;
                    background: Theme.error.with-alpha(0.12);
                    border-radius: Theme.radius-sm;

                    HorizontalLayout {
                        padding-left: Theme.spacing-sm;
                        padding-right: Theme.spacing-sm;
                        alignment: center;

                        Text {
                            text: error-text;
                            color: Theme.error;
                            font-size: 12px;
                            overflow: elide;
                            horizontal-alignment: left;
                            vertical-alignment: center;
                        }
                    }
                }

                // ── Preview table ─────────────────────────────────────────────
                Rectangle {
                    height: 1px; background: Theme.border;
                }

                // Column header row.
                HorizontalLayout {
                    padding-left: Theme.spacing-sm;
                    padding-right: Theme.spacing-sm;
                    spacing: Theme.spacing-sm;

                    Text {
                        text: "Original";
                        color: Theme.fg-muted;
                        font-size: 11px;
                        horizontal-stretch: 1;
                    }
                    Text {
                        text: " ";
                        color: Theme.fg-muted;
                        font-size: 11px;
                        width: 16px;
                    }
                    Text {
                        text: "Proposed";
                        color: Theme.fg-muted;
                        font-size: 11px;
                        horizontal-stretch: 1;
                    }
                }

                // Virtualized preview list.
                ListView {
                    vertical-stretch: 1;

                    for row[i] in preview-rows: Rectangle {
                        height: 26px;
                        background: row.is-conflict
                            ? Theme.error.with-alpha(0.10)
                            : (mod(i, 2) == 0 ? Theme.bg : Theme.panel-bg);
                        opacity: row.is-unchanged ? 0.45 : 1.0;
                        border-radius: 2px;

                        HorizontalLayout {
                            padding-left: Theme.spacing-sm;
                            padding-right: Theme.spacing-sm;
                            spacing: Theme.spacing-sm;
                            alignment: center;

                            Text {
                                text: row.original;
                                color: Theme.fg;
                                font-size: 12px;
                                overflow: elide;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }

                            Text {
                                text: "→";
                                color: Theme.fg-muted;
                                font-size: 12px;
                                vertical-alignment: center;
                                width: 16px;
                                horizontal-alignment: center;
                            }

                            Text {
                                text: row.proposed;
                                color: row.is-conflict ? Theme.error : Theme.fg;
                                font-size: 12px;
                                font-weight: row.is-conflict ? 600 : 400;
                                overflow: elide;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                        }
                    }
                }

                Rectangle { height: 1px; background: Theme.border; }

                // ── Footer: conflict hint + action buttons ────────────────────
                HorizontalLayout {
                    spacing: Theme.spacing-sm;
                    alignment: end;

                    // Conflict / error hint.
                    if conflict-count > 0: Text {
                        text: conflict-count + " conflict(s)";
                        color: Theme.error;
                        font-size: 12px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }

                    // Cancel button.
                    Rectangle {
                        width: 80px;
                        height: 30px;
                        border-radius: Theme.radius-sm;
                        border-width: 1px;
                        border-color: Theme.border;
                        background: Theme.bg;

                        TouchArea {
                            width: 100%; height: 100%;
                            clicked => { root.cancel(); }
                        }

                        Text {
                            text: "Cancel";
                            color: Theme.fg;
                            font-size: 13px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    // "Rename N files" primary button.
                    //
                    // Disabled when:
                    //   - change-count == 0  (nothing to rename)
                    //   - conflict-count > 0 (unresolved collisions)
                    //   - error-text != ""   (regex compile error)
                    property <bool> confirm-enabled:
                        change-count > 0 && conflict-count == 0 && error-text == "";

                    Rectangle {
                        width: 130px;
                        height: 30px;
                        border-radius: Theme.radius-sm;
                        background: confirm-enabled ? Theme.accent : Theme.border;
                        opacity: confirm-enabled ? 1.0 : 0.5;

                        TouchArea {
                            width: 100%; height: 100%;
                            clicked => {
                                if confirm-enabled {
                                    root.confirm();
                                }
                            }
                        }

                        Text {
                            text: "Rename " + change-count + " file(s)";
                            color: confirm-enabled ? Theme.accent-fg : Theme.fg-muted;
                            font-size: 13px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
