import { Theme } from "../theme.slint";
import { ListView } from "std-widgets.slint";

export struct RenamePreview {
    original: string,
    proposed: string,
    is-conflict: bool,
    is-unchanged: bool,
}

export component BulkRenameModal inherits Rectangle {
    in property <bool> visible-modal: false;
    in-out property <string> pattern: "";
    in-out property <string> replacement: "";
    in property <bool> use-regex: false;
    in property <bool> case-insensitive: false;
    in property <[RenamePreview]> preview-rows: [];
    in property <int> conflict-count: 0;
    in property <int> change-count: 0;
    in property <string> error-text: "";

    callback pattern-changed(string);
    callback replacement-changed(string);
    callback toggle-regex();
    callback toggle-case();
    callback confirm();
    callback cancel();

    if visible-modal: Rectangle {
        width: 100%;
        height: 100%;
        background: #00000066;

        TouchArea {
            width: 100%;
            height: 100%;
            clicked => { root.cancel(); }
        }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(620px, parent.width - 48px);
            height: min(460px, parent.height - 96px);
            background: Theme.panel-bg-elevated;
            border-width: 1px;
            border-color: Theme.border;
            border-radius: Theme.radius-lg;

            TouchArea {
                width: 100%;
                height: 100%;
            }

            VerticalLayout {
                padding: Theme.space-4;
                spacing: Theme.space-2;

                Text {
                    text: "Bulk Rename (" + preview-rows.length + " items)";
                    color: Theme.fg;
                    font-size: 17px;
                    font-weight: 600;
                    horizontal-alignment: left;
                }

                Rectangle { height: 1px; background: Theme.border; }

                VerticalLayout {
                    spacing: Theme.space-1;
                    Text {
                        text: "Find";
                        color: Theme.fg-muted;
                        font-size: 12px;
                    }
                    Rectangle {
                        height: 32px;
                        border-width: 1px;
                        border-color: Theme.border;
                        border-radius: Theme.radius-sm;
                        background: Theme.panel-bg-elevated;

                        HorizontalLayout {
                            padding-left: Theme.space-3;
                            padding-right: Theme.space-3;
                            alignment: center;

                            TextInput {
                                // Auto-focus the Find field every time the
                                // modal opens (the `if visible-modal`
                                // subtree is recreated per-open, so `init`
                                // fires per-open).
                                init => { self.focus(); }
                                text <=> root.pattern;
                                color: Theme.fg;
                                font-size: Theme.font-size;
                                vertical-alignment: center;
                                single-line: true;
                                edited => { root.pattern-changed(self.text); }
                                key-pressed(event) => {
                                    if event.text == Key.Escape {
                                        root.cancel();
                                        return accept;
                                    }
                                    reject;
                                }
                            }
                        }
                    }
                }

                VerticalLayout {
                    spacing: Theme.space-1;
                    Text {
                        text: "Replace with";
                        color: Theme.fg-muted;
                        font-size: 12px;
                    }
                    Rectangle {
                        height: 32px;
                        border-width: 1px;
                        border-color: Theme.border;
                        border-radius: Theme.radius-sm;
                        background: Theme.panel-bg-elevated;

                        HorizontalLayout {
                            padding-left: Theme.space-3;
                            padding-right: Theme.space-3;
                            alignment: center;

                            TextInput {
                                text <=> root.replacement;
                                color: Theme.fg;
                                font-size: Theme.font-size;
                                vertical-alignment: center;
                                single-line: true;
                                edited => { root.replacement-changed(self.text); }
                                key-pressed(event) => {
                                    if event.text == Key.Escape {
                                        root.cancel();
                                        return accept;
                                    }
                                    reject;
                                }
                            }
                        }
                    }
                }

                HorizontalLayout {
                    spacing: Theme.space-2;

                    Rectangle {
                        width: 72px;
                        height: 26px;
                        border-radius: Theme.radius-sm;
                        border-width: 1px;
                        background: use-regex ? Theme.accent : Theme.panel-bg;
                        border-color: use-regex ? Theme.accent : Theme.border;

                        TouchArea {
                            width: 100%; height: 100%;
                            clicked => { root.toggle-regex(); }
                        }

                        Text {
                            text: "Regex";
                            color: use-regex ? Theme.accent-fg : Theme.fg;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        width: 128px;
                        height: 26px;
                        border-radius: Theme.radius-sm;
                        border-width: 1px;
                        background: case-insensitive ? Theme.accent : Theme.panel-bg;
                        border-color: case-insensitive ? Theme.accent : Theme.border;

                        TouchArea {
                            width: 100%; height: 100%;
                            clicked => { root.toggle-case(); }
                        }

                        Text {
                            text: "Case insensitive";
                            color: case-insensitive ? Theme.accent-fg : Theme.fg;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }

                if error-text != "": Rectangle {
                    height: 24px;
                    background: Theme.error.with-alpha(0.12);
                    border-radius: Theme.radius-sm;

                    HorizontalLayout {
                        padding-left: Theme.space-3;
                        padding-right: Theme.space-3;
                        alignment: center;

                        Text {
                            text: error-text;
                            color: Theme.error;
                            font-size: 12px;
                            overflow: elide;
                            horizontal-alignment: left;
                            vertical-alignment: center;
                        }
                    }
                }

                Rectangle { height: 1px; background: Theme.border; }

                HorizontalLayout {
                    padding-left: Theme.space-2;
                    padding-right: Theme.space-2;
                    spacing: Theme.space-2;

                    Text {
                        text: "Original";
                        color: Theme.fg-muted;
                        font-size: 10px;
                        font-weight: 600;
                        horizontal-stretch: 1;
                    }
                    Text {
                        text: " ";
                        color: Theme.fg-muted;
                        font-size: 10px;
                        width: 16px;
                    }
                    Text {
                        text: "Proposed";
                        color: Theme.fg-muted;
                        font-size: 10px;
                        font-weight: 600;
                        horizontal-stretch: 1;
                    }
                }

                ListView {
                    vertical-stretch: 1;

                    for row[i] in preview-rows: row-bg := Rectangle {
                        height: 30px;
                        background: row.is-conflict
                            ? Theme.error.with-alpha(0.10)
                            : (row-ta.has-hover ? Theme.hover-bg : transparent);
                        opacity: row.is-unchanged ? 0.45 : 1.0;
                        border-radius: Theme.radius-sm;

                        row-ta := TouchArea { width: 100%; height: 100%; }

                        HorizontalLayout {
                            padding-left: Theme.space-2;
                            padding-right: Theme.space-2;
                            spacing: Theme.space-2;
                            alignment: center;

                            Text {
                                text: row.original;
                                color: Theme.fg;
                                font-size: 12px;
                                overflow: elide;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }

                            Text {
                                text: "→";
                                color: Theme.fg-muted;
                                font-size: 12px;
                                vertical-alignment: center;
                                width: 16px;
                                horizontal-alignment: center;
                            }

                            Text {
                                text: row.proposed;
                                color: row.is-conflict ? Theme.error : Theme.fg;
                                font-size: 12px;
                                font-weight: row.is-conflict ? 600 : 400;
                                overflow: elide;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                        }
                    }
                }

                Rectangle { height: 1px; background: Theme.border; }

                HorizontalLayout {
                    spacing: Theme.space-2;
                    alignment: end;

                    if conflict-count > 0: Text {
                        text: conflict-count + " conflict(s)";
                        color: Theme.error;
                        font-size: 12px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }

                    Rectangle {
                        width: 80px;
                        height: 30px;
                        border-radius: Theme.radius-sm;
                        border-width: 1px;
                        border-color: Theme.border;
                        background: Theme.panel-bg;

                        TouchArea {
                            width: 100%; height: 100%;
                            clicked => { root.cancel(); }
                        }

                        Text {
                            text: "Cancel";
                            color: Theme.fg;
                            font-size: 13px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    property <bool> confirm-enabled:
                        change-count > 0 && conflict-count == 0 && error-text == "";

                    Rectangle {
                        width: 130px;
                        height: 30px;
                        border-radius: Theme.radius-sm;
                        background: confirm-enabled ? Theme.accent : Theme.border;
                        opacity: confirm-enabled ? 1.0 : 0.5;

                        TouchArea {
                            width: 100%; height: 100%;
                            clicked => {
                                if confirm-enabled {
                                    root.confirm();
                                }
                            }
                        }

                        Text {
                            text: "Rename " + change-count + " file(s)";
                            color: confirm-enabled ? Theme.accent-fg : Theme.fg-muted;
                            font-size: 13px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
