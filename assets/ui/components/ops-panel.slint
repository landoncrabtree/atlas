import { Theme } from "../theme.slint";

export struct OpRow {
    id: string,
    title: string,
    status: string,
    progress: float,
    items-total: int,
    items-done: int,
    bytes-total: string,
    bytes-done: string,
    current-path: string,
    is-terminal: bool,
    is-error: bool,
}

export component OpsPanel inherits Rectangle {
    in property <bool> visible-panel;
    in property <[OpRow]> rows;

    callback cancel(int);
    callback dismiss(int);
    callback close();

    if visible-panel : Rectangle {
        background: Theme.panel-bg-elevated;

        VerticalLayout {
            spacing: 0px;

            Rectangle {
                height: 1px;
                background: Theme.border;
            }

            Rectangle {
                height: 32px;
                background: Theme.panel-bg-elevated;

                HorizontalLayout {
                    padding-left: Theme.space-4;
                    padding-right: Theme.space-4;
                    alignment: center;

                    Text {
                        text: "Operations (" + rows.length + ")";
                        color: Theme.fg;
                        font-size: 15px;
                        font-weight: 600;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }

                    header-close := TouchArea {
                        width: 24px;
                        height: 24px;
                        clicked => { root.close(); }

                        Rectangle {
                            border-radius: Theme.radius-sm;
                            background: header-close.has-hover ? Theme.hover-bg : transparent;
                            animate background { duration: 100ms; easing: ease-out; }

                            Text {
                                text: "×";
                                color: Theme.fg-muted;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                                font-size: 13px;
                            }
                        }
                    }
                }
            }

            Rectangle {
                height: 168px;
                background: Theme.panel-bg-elevated;
                clip: true;

                VerticalLayout {
                    spacing: 0px;

                    for row[i] in rows : row-bg := Rectangle {
                        height: 44px;
                        background: row-ta.has-hover ? Theme.hover-bg : Theme.panel-bg-elevated;
                        opacity: row.is-terminal ? 0.8 : 1.0;

                        Rectangle {
                            y: parent.height - 1px;
                            height: 1px;
                            background: Theme.border;
                        }

                        row-ta := TouchArea {
                            width: 100%;
                            height: 100%;
                        }

                        HorizontalLayout {
                            padding-left: Theme.space-3;
                            padding-right: Theme.space-3;
                            padding-top: Theme.space-1;
                            padding-bottom: Theme.space-1;
                            spacing: Theme.space-2;
                            alignment: center;

                            VerticalLayout {
                                horizontal-stretch: 1;
                                spacing: 2px;
                                alignment: center;

                                HorizontalLayout {
                                    spacing: Theme.space-2;

                                    Text {
                                        text: row.title;
                                        color: row.is-error ? Theme.error : Theme.fg;
                                        font-size: 12px;
                                        overflow: elide;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                    }

                                    Text {
                                        text: row.status;
                                        color: row.is-error ? Theme.error : Theme.fg-muted;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                }

                                Rectangle {
                                    height: 4px;
                                    border-radius: Theme.radius-xs;
                                    background: Theme.panel-bg;

                                    Rectangle {
                                        x: 0px;
                                        height: 4px;
                                        border-radius: Theme.radius-xs;
                                        width: parent.width * row.progress;
                                        background: row.is-error ? Theme.error : Theme.accent;
                                    }
                                }

                                Text {
                                    text: row.bytes-done == "" && row.bytes-total == ""
                                        ? (row.current-path == "" ? "" : row.current-path)
                                        : row.bytes-done + " / " + row.bytes-total + (row.current-path == "" ? "" : "  " + row.current-path);
                                    color: Theme.fg-muted;
                                    font-size: 10px;
                                    overflow: elide;
                                }
                            }

                            if row.is-terminal : dismiss-ta := TouchArea {
                                width: 24px;
                                height: 24px;
                                visible: row-ta.has-hover;
                                clicked => { root.dismiss(i); }

                                Rectangle {
                                    border-radius: Theme.radius-sm;
                                    background: dismiss-ta.has-hover ? Theme.border-strong : transparent;
                                    animate background { duration: 100ms; easing: ease-out; }

                                    Text {
                                        text: "×";
                                        color: Theme.fg-muted;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        width: parent.width;
                                        height: parent.height;
                                        font-size: 13px;
                                    }
                                }
                            }

                            if !row.is-terminal : cancel-ta := TouchArea {
                                width: 24px;
                                height: 24px;
                                visible: row-ta.has-hover;
                                clicked => { root.cancel(i); }

                                Rectangle {
                                    border-radius: Theme.radius-sm;
                                    background: cancel-ta.has-hover ? Theme.border-strong : transparent;
                                    animate background { duration: 100ms; easing: ease-out; }

                                    Text {
                                        text: "■";
                                        color: Theme.fg-muted;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        width: parent.width;
                                        height: parent.height;
                                        font-size: 10px;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
