// File-operations progress tray (bottom-docked panel).
//
// Shown automatically when `visible-panel` is true. Each row displays a single
// operation with a progress bar, byte counts, and Cancel (■) or Dismiss (×)
// buttons for active and terminal rows respectively.

import { Theme } from "../theme.slint";

/// One file-operation row shown in the ops panel.
export struct OpRow {
    /// Stable `OpId` stringified.
    id: string,
    /// Short title, e.g. "Copy: 3 items → Downloads".
    title: string,
    /// Human-readable status: "Queued" | "Running" | "Paused" | "Done" |
    /// "Failed: <msg>" | "Cancelled".
    status: string,
    /// Completion fraction 0.0–1.0.
    progress: float,
    /// Total logical items involved.
    items-total: int,
    /// Completed logical items.
    items-done: int,
    /// Total bytes formatted (e.g. "12.4 MiB").
    bytes-total: string,
    /// Done bytes formatted.
    bytes-done: string,
    /// Currently processing path (may be empty).
    current-path: string,
    /// `true` when the op has reached a terminal state (done / failed / cancelled).
    is-terminal: bool,
    /// `true` when the op finished with an error.
    is-error: bool,
}

/// Bottom-docked tray listing in-flight and recently finished file operations.
///
/// # Properties
/// - `visible-panel` — whether the tray is shown.
/// - `rows` — operation rows to display.
///
/// # Callbacks
/// - `cancel(index)` — request cancellation of row at *index* in `rows`.
/// - `dismiss(index)` — remove a terminal row from the panel.
/// - `close()` — hide the panel (rows are not discarded on the Rust side).
export component OpsPanel inherits Rectangle {
    in property <bool> visible-panel;
    in property <[OpRow]> rows;

    callback cancel(int);
    callback dismiss(int);
    callback close();

    if visible-panel : VerticalLayout {
        spacing: 0px;

        // Top border.
        Rectangle {
            height: 1px;
            background: Theme.border;
        }

        // Header bar.
        Rectangle {
            height: 32px;
            background: Theme.panel-bg;

            HorizontalLayout {
                padding-left: Theme.spacing-md;
                padding-right: Theme.spacing-md;
                alignment: center;

                Text {
                    text: "Operations (" + rows.length + ")";
                    color: Theme.fg;
                    font-size: Theme.font-size;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }

                // Close button.
                Rectangle {
                    width: 24px;
                    height: 24px;
                    border-radius: Theme.radius-sm;
                    border-width: 1px;
                    border-color: Theme.border;
                    background: Theme.bg;

                    TouchArea {
                        width: 100%;
                        height: 100%;
                        clicked => { root.close(); }
                    }

                    Text {
                        text: "×";
                        color: Theme.fg-muted;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        font-size: Theme.font-size;
                    }
                }
            }
        }

        // Scrollable rows area (~168 px so total panel ≈ 200 px).
        Rectangle {
            height: 168px;
            background: Theme.panel-bg;
            clip: true;

            VerticalLayout {
                spacing: 0px;

                for row[i] in rows : Rectangle {
                    height: 56px;
                    background: Theme.panel-bg;

                    // Row bottom border.
                    Rectangle {
                        y: parent.height - 1px;
                        height: 1px;
                        background: Theme.border;
                    }

                    HorizontalLayout {
                        padding-left: Theme.spacing-sm;
                        padding-right: Theme.spacing-sm;
                        padding-top: Theme.spacing-xs;
                        padding-bottom: Theme.spacing-xs;
                        spacing: Theme.spacing-sm;
                        alignment: center;

                        // Left: title, progress bar, byte counts.
                        VerticalLayout {
                            horizontal-stretch: 1;
                            spacing: 3px;
                            alignment: center;

                            HorizontalLayout {
                                spacing: Theme.spacing-xs;

                                Text {
                                    text: row.title;
                                    color: row.is-error ? Theme.error : Theme.fg;
                                    font-size: 12px;
                                    overflow: elide;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }

                                Text {
                                    text: row.status;
                                    color: row.is-error ? Theme.error : Theme.fg-muted;
                                    font-size: 11px;
                                    vertical-alignment: center;
                                }
                            }

                            // Progress bar.
                            Rectangle {
                                height: 4px;
                                border-radius: 2px;
                                background: Theme.border;

                                Rectangle {
                                    x: 0px;
                                    height: 4px;
                                    border-radius: 2px;
                                    width: parent.width * row.progress;
                                    background: row.is-error ? Theme.error : Theme.accent;
                                }
                            }

                            Text {
                                text: row.bytes-done == "" && row.bytes-total == ""
                                    ? (row.current-path == "" ? "" : row.current-path)
                                    : row.bytes-done + " / " + row.bytes-total + (row.current-path == "" ? "" : "  " + row.current-path);
                                color: Theme.fg-muted;
                                font-size: 10px;
                                overflow: elide;
                            }
                        }

                        // Right: action button (Dismiss for terminal, Cancel for active).
                        if row.is-terminal : Rectangle {
                            width: 24px;
                            height: 24px;
                            border-radius: Theme.radius-sm;
                            border-width: 1px;
                            border-color: Theme.border;
                            background: Theme.bg;

                            TouchArea {
                                width: 100%;
                                height: 100%;
                                clicked => { root.dismiss(i); }
                            }

                            Text {
                                text: "×";
                                color: Theme.fg-muted;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                font-size: Theme.font-size;
                            }
                        }

                        if !row.is-terminal : Rectangle {
                            width: 24px;
                            height: 24px;
                            border-radius: Theme.radius-sm;
                            border-width: 1px;
                            border-color: Theme.border;
                            background: Theme.bg;

                            TouchArea {
                                width: 100%;
                                height: 100%;
                                clicked => { root.cancel(i); }
                            }

                            Text {
                                text: "■";
                                color: Theme.fg-muted;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                font-size: 10px;
                            }
                        }
                    }
                }
            }
        }
    }
}
