import { Theme } from "../theme.slint";
import {
    AtlasList, AtlasListRow, AtlasProgressBar, AtlasSecondaryButton, SectionLabel,
} from "atlas-controls.slint";

// Row model consumed by the ops panel *and* the progress modal. Mirrors
// [`atlas_ui::ops::models::OpRow`] — keep the two in sync.
export struct OpRow {
    id: string,
    title: string,
    status: string,
    // Kind label ("Copy", "Move", "Trash", ...). Used for the small kind
    // badge in each panel row.
    kind: string,
    // Human-readable source summary ("3 items" or "/Users/x/file.txt").
    // Empty when the op has no natural source (mkdir).
    source-summary: string,
    // Human-readable destination directory. Empty for in-place ops.
    dest-summary: string,
    // ETA string ("15s", "1m 30s", ""). Empty until a meaningful estimate
    // is available.
    eta: string,
    progress: float,
    items-total: int,
    items-done: int,
    bytes-total: string,
    bytes-done: string,
    current-path: string,
    is-terminal: bool,
    is-error: bool,
}

// File-operations tray: one row per queued/running/terminal op with a
// source→dest summary, ETA, progress, and progressive cancel/dismiss controls.
export component OpsPanel inherits Rectangle {
    in property <bool> visible-panel;
    in property <[OpRow]> rows;

    callback cancel(int);
    callback dismiss(int);
    callback close();
    callback clear-completed();

    height: visible-panel ? 236px : 0px;
    background: transparent;

    if visible-panel : panel := Rectangle {
        x: parent.width - self.width - Theme.space-3;
        y: 0px;
        width: min(760px, parent.width - Theme.space-3 * 2);
        height: parent.height - Theme.space-2;
        background: Theme.modal-bg;
        border-width: 1px;
        border-color: Theme.modal-border;
        border-radius: Theme.modal-radius;
        drop-shadow-blur: 24px;
        drop-shadow-offset-y: -2px;
        drop-shadow-color: Theme.ops-panel-shadow-color;
        clip: true;

        VerticalLayout {
            width: parent.width;
            height: parent.height;
            spacing: 0px;

            // ── Header ──────────────────────────────────────────────────
            Rectangle {
                width: parent.width;
                height: 40px;
                background: transparent;

                HorizontalLayout {
                    padding-left: Theme.space-4;
                    padding-right: Theme.space-2;
                    spacing: Theme.space-2;
                    alignment: center;

                    SectionLabel { label: "Operations"; }

                    Text {
                        text: rows.length == 0 ? "" : rows.length + " items";
                        color: Theme.fg-faint;
                        font-size: 11px;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }

                    AtlasSecondaryButton {
                        visible: rows.length > 0;
                        button-width: 112px;
                        text: "Clear Completed";
                        clicked => { root.clear-completed(); }
                    }

                    header-close := TouchArea {
                        width: 24px;
                        height: 24px;
                        clicked => { root.close(); }

                        Rectangle {
                            border-radius: Theme.radius-sm;
                            background: header-close.has-hover ? Theme.hover-bg : transparent;
                            animate background { duration: Theme.motion-fast; easing: ease-out; }

                            Text {
                                text: "×";
                                color: Theme.fg-muted;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                                font-size: 14px;
                            }
                        }
                    }
                }
            }

            // ── Row list (or empty state) ───────────────────────────────
            AtlasList {
                height: 176px;
                x: Theme.space-3;
                width: panel.width - Theme.space-3 * 2;

                if rows.length == 0 : Rectangle {
                    width: 100%;
                    height: 100%;

                    VerticalLayout {
                        alignment: center;
                        spacing: Theme.space-1;

                        Text {
                            text: "No operations running";
                            color: Theme.fg-muted;
                            font-size: 13px;
                            horizontal-alignment: center;
                        }
                        Text {
                            text: "Copy, move, trash, and rename activity will appear here.";
                            color: Theme.placeholder-color;
                            font-size: 11px;
                            horizontal-alignment: center;
                        }
                    }
                }

                if rows.length > 0 : VerticalLayout {
                    width: parent.width;
                    spacing: 0px;
                    padding: Theme.space-1;

                    for row[i] in rows : row-bg := AtlasListRow {
                        height: 52px;
                        highlighted: row-ta.has-hover;
                        muted: row.is-terminal;

                        row-ta := TouchArea {
                            width: 100%;
                            height: 100%;
                        }

                        HorizontalLayout {
                            padding-left: Theme.space-2;
                            padding-right: Theme.space-2;
                            padding-top: Theme.space-1;
                            padding-bottom: Theme.space-1;
                            spacing: Theme.space-2;
                            alignment: center;

                            Rectangle {
                                width: 50px;
                                height: 20px;
                                border-radius: Theme.radius-xs;
                                background: row.is-error
                                    ? Theme.error.with-alpha(0.13)
                                    : Theme.field-bg;
                                border-width: 1px;
                                border-color: row.is-error
                                    ? Theme.error.with-alpha(0.45)
                                    : Theme.field-border;

                                Text {
                                    text: row.kind;
                                    color: row.is-error ? Theme.error : Theme.fg-muted;
                                    font-size: 10px;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    width: parent.width;
                                    height: parent.height;
                                }
                            }

                            VerticalLayout {
                                horizontal-stretch: 1;
                                spacing: 3px;
                                alignment: center;

                                HorizontalLayout {
                                    spacing: Theme.space-1;

                                    Text {
                                        text: row.source-summary == "" && row.dest-summary == ""
                                            ? row.title
                                            : (row.source-summary == ""
                                                ? row.dest-summary
                                                : (row.dest-summary == ""
                                                    ? row.source-summary
                                                    : row.source-summary + "  →  " + row.dest-summary));
                                        color: row.is-error ? Theme.error : Theme.fg;
                                        font-size: 12px;
                                        overflow: elide;
                                        vertical-alignment: center;
                                        horizontal-stretch: 1;
                                    }

                                    Text {
                                        text: row.is-terminal ? row.status : row.eta;
                                        color: row.is-error ? Theme.error : Theme.fg-muted;
                                        font-size: 11px;
                                        vertical-alignment: center;
                                    }
                                }

                                AtlasProgressBar {
                                    progress: row.progress;
                                    error: row.is-error;
                                }

                                Text {
                                    text: row.bytes-total == "0 B" || row.bytes-total == ""
                                        ? (row.items-total > 0
                                            ? (row.items-done + " of " + row.items-total + " items"
                                                + (row.current-path == "" ? "" : "  ·  " + row.current-path))
                                            : row.current-path)
                                        : row.bytes-done + " of " + row.bytes-total
                                            + (row.current-path == "" ? "" : "  ·  " + row.current-path);
                                    color: Theme.fg-faint;
                                    font-size: 10px;
                                    overflow: elide;
                                }
                            }

                            if row.is-terminal : dismiss-ta := TouchArea {
                                width: 26px;
                                height: 26px;
                                visible: row-ta.has-hover;
                                clicked => { root.dismiss(i); }

                                Rectangle {
                                    border-radius: Theme.radius-sm;
                                    background: dismiss-ta.has-hover ? Theme.hover-bg : transparent;
                                    animate background { duration: Theme.motion-fast; easing: ease-out; }

                                    Text {
                                        text: "×";
                                        color: Theme.fg-muted;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        width: parent.width;
                                        height: parent.height;
                                        font-size: 14px;
                                    }
                                }
                            }

                            if !row.is-terminal : cancel-ta := TouchArea {
                                width: 26px;
                                height: 26px;
                                visible: row-ta.has-hover;
                                clicked => { root.cancel(i); }

                                Rectangle {
                                    border-radius: Theme.radius-sm;
                                    background: cancel-ta.has-hover ? Theme.hover-bg : transparent;
                                    animate background { duration: Theme.motion-fast; easing: ease-out; }

                                    Text {
                                        text: "■";
                                        color: Theme.fg-muted;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                        width: parent.width;
                                        height: parent.height;
                                        font-size: 10px;
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}
