// Connect-to-Server modal — remote-fs backend picker (SFTP / FTP / WebDAV / S3).
// Keeps Rust-owned state and callbacks intact while composing macOS-style
// controls from atlas-controls.slint: compact fields, contiguous segmented
// controls, subtle lists, and a single accent primary action.

import { Theme } from "../theme.slint";
import { ScrollView } from "std-widgets.slint";
import {
    AtlasFieldGroup, AtlasList, AtlasListRow, AtlasModal, AtlasPrimaryButton,
    AtlasSecondaryButton, AtlasSegmentedControl, AtlasTextField, SectionLabel,
} from "atlas-controls.slint";

// A single row in the saved-servers list rendered beneath the modal's
// connection form. Populated by Rust (`ConnectController`) from
// `atlas_config::servers::list()`, sorted last-connected desc.
export struct SavedServerRow {
    /// Stable server id (matches `atlas_config::servers::SavedServer::id`).
    id: string,
    /// User-facing label ("prod", "home NAS", …), or `user@host` fallback.
    label: string,
    /// Display-ready subtitle — full URI (e.g. `sftp://landon@host:22/var`).
    address: string,
    /// Backend glyph used as the row's left icon (📁 🔐 ☁️ 🌐 📡).
    glyph: string,
    /// Preformatted relative-time string ("just now", "3 days ago", "never").
    last-connected-relative: string,
    /// True while this row is showing the inline "Delete?" confirm chip.
    delete-pending: bool,
}

export component ConnectServerModal inherits Rectangle {
    // ── Externally-controlled state ────────────────────────────────────────

    in property <bool> visible-modal: false;
    in-out property <int> backend-index: 0;
    in-out property <int> auth-index: 0;

    in-out property <string> host: "";
    in-out property <string> path: "";
    in-out property <string> username: "";
    in-out property <string> password: "";
    in-out property <string> ssh-key-path: "";
    in-out property <string> iam-access-key: "";
    in-out property <string> iam-secret-key: "";
    in-out property <string> iam-session-token: "";
    in-out property <string> s3-endpoint: "";
    in-out property <string> label-text: "";

    in property <bool> save-to-keychain: true;
    in property <bool> connecting: false;
    in property <string> status-text: "";
    in property <bool> status-is-error: false;

    // ── TOFU host-key prompt (Phase 2.6) ─────────────────────────────────
    in property <bool> host-key-prompt-visible: false;
    in property <string> host-key-host: "";
    in property <string> host-key-fingerprint: "";
    in property <string> host-key-mismatch-known-fingerprint: "";

    // ── Saved-servers viewer ──────────────────────────────────────────────
    in property <[SavedServerRow]> saved-servers: [];

    // Reflects "any TextInput in this modal has focus". Bubbles up to the
    // window's FocusScope so Cmd+A / Cmd+C / Cmd+V land in the input, not
    // the pane's keymap dispatcher.
    out property <bool> input-focused: host-focus || path-focus
        || username-focus || password-focus
        || ssh-key-focus || iam-access-focus
        || iam-secret-focus || iam-session-focus
        || s3-endpoint-focus || label-focus;

    // ── Callbacks fired at the Rust bridge ─────────────────────────────────

    callback backend-changed(int);
    callback auth-changed(int);
    callback host-changed(string);
    callback path-changed(string);
    callback username-changed(string);
    callback password-changed(string);
    callback ssh-key-path-changed(string);
    callback iam-access-key-changed(string);
    callback iam-secret-key-changed(string);
    callback iam-session-token-changed(string);
    callback s3-endpoint-changed(string);
    callback label-changed(string);
    callback toggle-save-to-keychain();
    callback browse-ssh-key();
    callback cancel();
    callback connect();
    callback save-and-connect();

    // ── Saved-servers callbacks ───────────────────────────────────────────
    callback saved-server-selected(string /* id */);
    callback saved-server-delete-requested(string /* id */);
    callback saved-server-delete-confirmed(string /* id */);
    callback saved-server-delete-cancelled();

    // ── TOFU host-key callbacks ─────────────────────────────────────────
    callback host-key-trust-once();
    callback host-key-trust-always();
    callback host-key-cancel();

    // ── Derived visibility flags ───────────────────────────────────────────
    // Backend indices: 0=SFTP, 1=FTP, 2=WebDAV, 3=S3.
    // Auth indices:    0=Password, 1=SSH Key, 2=IAM, 3=Anonymous.

    property <bool> is-sftp: backend-index == 0;
    property <bool> is-ftp: backend-index == 1;
    property <bool> is-webdav: backend-index == 2;
    property <bool> is-s3: backend-index == 3;

    property <bool> auth-password: auth-index == 0;
    property <bool> auth-ssh-key: auth-index == 1;
    property <bool> auth-iam: auth-index == 2;
    property <bool> auth-anon: auth-index == 3;

    property <bool> show-username: !auth-anon && !auth-iam;
    property <bool> show-password: auth-password;
    property <bool> show-ssh-key: auth-ssh-key;
    property <bool> show-iam: auth-iam;
    property <bool> show-s3-endpoint: is-s3;

    property <string> host-placeholder: is-s3 ? "my-bucket" : "files.example.com";
    property <int> sftp-auth-selected: auth-index == 0 ? 0 : (auth-index == 1 ? 1 : 2);
    property <int> password-anon-auth-selected: auth-index == 0 ? 0 : 1;
    property <int> s3-auth-selected: auth-index == 2 ? 0 : 1;
    property <length> field-group-h: Theme.control-height + 18px;
    property <length> credentials-h: show-iam
        ? field-group-h * 3 + Theme.space-3 * 2
        : ((show-username && (show-password || show-ssh-key))
            ? field-group-h * 2 + Theme.space-3
            : field-group-h);
    property <length> saved-list-h: saved-servers.length == 0
        ? 44px
        : min(5 * Theme.list-row-height, saved-servers.length * Theme.list-row-height);
    property <length> saved-block-h: 24px + saved-list-h;

    // ── Per-input focus mirrors (used by `input-focused` above) ───────────

    property <bool> host-focus: false;
    property <bool> path-focus: false;
    property <bool> username-focus: false;
    property <bool> password-focus: false;
    property <bool> ssh-key-focus: false;
    property <bool> iam-access-focus: false;
    property <bool> iam-secret-focus: false;
    property <bool> iam-session-focus: false;
    property <bool> s3-endpoint-focus: false;
    property <bool> label-focus: false;

    width: 100%;
    height: 100%;

    AtlasModal {
        width: 100%;
        height: 100%;
        visible-modal: root.visible-modal;
        title: "Connect to Server";
        modal-width: 560px;
        modal-height: min((root.show-s3-endpoint && root.show-iam) ? 720px : (root.saved-servers.length > 0 ? 620px : 540px), root.height - Theme.space-8 * 2);
        dismissed => { root.cancel(); }

        // ── Backend picker (segmented control) ───────────────────────────
        AtlasFieldGroup {
            SectionLabel { label: "Backend"; }

            AtlasSegmentedControl {
                segments: ["SFTP", "FTP", "WebDAV", "S3"];
                selected-index: root.backend-index;
                selected(index) => { root.backend-changed(index); }
            }
        }

        // ── TOFU host-key banner (Phase 2.6) ────────────────────────────
        if root.host-key-prompt-visible: Rectangle {
            property <bool> is-mismatch: root.host-key-mismatch-known-fingerprint != "";
            border-width: 1px;
            border-color: is-mismatch ? Theme.error : Theme.warning;
            border-radius: Theme.list-radius;
            background: is-mismatch ? Theme.error.with-alpha(0.12) : Theme.warning.with-alpha(0.12);

            VerticalLayout {
                padding: Theme.space-3;
                spacing: Theme.space-2;

                Text {
                    text: is-mismatch
                        ? "Server key changed"
                        : "The authenticity of this host can't be established.";
                    color: is-mismatch ? Theme.error : Theme.fg;
                    font-size: 12px;
                    font-weight: 600;
                    wrap: word-wrap;
                }

                Text {
                    text: is-mismatch
                        ? "Someone may be intercepting your connection, or this server's key legitimately rotated. Verify the new fingerprint before continuing."
                        : "Verify the fingerprint below matches what the server operator published, then trust it.";
                    color: Theme.fg-muted;
                    font-size: 11px;
                    wrap: word-wrap;
                }

                VerticalLayout {
                    spacing: Theme.space-1;

                    HorizontalLayout {
                        spacing: Theme.space-2;
                        Text {
                            text: "Host";
                            color: Theme.fg-faint;
                            font-size: 10px;
                            font-weight: 600;
                            width: 60px;
                        }
                        Text {
                            text: root.host-key-host;
                            color: Theme.fg;
                            font-family: Theme.monospace;
                            font-size: 12px;
                            horizontal-stretch: 1;
                            wrap: word-wrap;
                        }
                    }

                    HorizontalLayout {
                        spacing: Theme.space-2;
                        Text {
                            text: is-mismatch ? "Offered" : "Fingerprint";
                            color: Theme.fg-faint;
                            font-size: 10px;
                            font-weight: 600;
                            width: 60px;
                        }
                        Text {
                            text: root.host-key-fingerprint;
                            color: is-mismatch ? Theme.error : Theme.fg;
                            font-family: Theme.monospace;
                            font-size: 12px;
                            horizontal-stretch: 1;
                            wrap: word-wrap;
                        }
                    }

                    if is-mismatch: HorizontalLayout {
                        spacing: Theme.space-2;
                        Text {
                            text: "Known";
                            color: Theme.fg-faint;
                            font-size: 10px;
                            font-weight: 600;
                            width: 60px;
                        }
                        Text {
                            text: root.host-key-mismatch-known-fingerprint;
                            color: Theme.fg;
                            font-family: Theme.monospace;
                            font-size: 12px;
                            horizontal-stretch: 1;
                            wrap: word-wrap;
                        }
                    }
                }

                host-key-focus := FocusScope {
                    width: 100%;
                    height: Theme.control-height;
                    key-pressed(event) => {
                        if event.text == Key.Escape {
                            root.host-key-cancel();
                            return accept;
                        }
                        if event.text == Key.Return {
                            root.host-key-cancel();
                            return accept;
                        }
                        reject;
                    }
                    init => { self.focus(); }

                    HorizontalLayout {
                        spacing: Theme.space-2;

                        AtlasSecondaryButton {
                            horizontal-stretch: 1;
                            text: "Trust once";
                            clicked => { root.host-key-trust-once(); }
                        }

                        Rectangle {
                            horizontal-stretch: 1;
                            height: Theme.control-height;
                            background: is-mismatch ? Theme.error : Theme.secondary-button-bg-hover;
                            border-width: 1px;
                            border-color: is-mismatch ? Theme.error : Theme.secondary-button-border-hover;
                            border-radius: Theme.button-radius;
                            TouchArea {
                                width: 100%; height: 100%;
                                clicked => { root.host-key-trust-always(); }
                            }
                            Text {
                                text: is-mismatch ? "Replace and continue" : "Trust always";
                                color: is-mismatch ? Theme.accent-fg : Theme.fg;
                                font-size: Theme.button-font-size;
                                font-weight: 600;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        AtlasSecondaryButton {
                            horizontal-stretch: 1;
                            text: "Cancel";
                            clicked => { root.host-key-cancel(); }
                        }
                    }
                }
            }
        }

        // ── Host / Path row ──────────────────────────────────────────────
        HorizontalLayout {
            height: root.field-group-h;
            spacing: Theme.space-3;

            AtlasFieldGroup {
                horizontal-stretch: 3;

                SectionLabel { label: is-s3 ? "Bucket" : "Host"; }

                host-field := AtlasTextField {
                    auto-focus: true;
                    text <=> root.host;
                    placeholder: host-placeholder;
                    edited(value) => { root.host-changed(value); }
                    accepted => {
                        if !root.connecting { root.connect(); }
                    }
                    escape-pressed => { root.cancel(); }
                    changed focused => { host-focus = self.focused; }
                }
            }

            AtlasFieldGroup {
                horizontal-stretch: 2;

                SectionLabel { label: is-s3 ? "Prefix" : "Path"; }

                path-field := AtlasTextField {
                    text <=> root.path;
                    placeholder: is-s3 ? "prefix/optional" : "/home/user";
                    edited(value) => { root.path-changed(value); }
                    escape-pressed => { root.cancel(); }
                    changed focused => { path-focus = self.focused; }
                }
            }
        }

        // ── S3 endpoint (non-standard S3 buckets — minio, LocalStack) ────
        if show-s3-endpoint: AtlasFieldGroup {
            SectionLabel { label: "Endpoint URL"; }

            s3ep-field := AtlasTextField {
                text <=> root.s3-endpoint;
                placeholder: "https://s3.example.com";
                edited(value) => { root.s3-endpoint-changed(value); }
                escape-pressed => { root.cancel(); }
                changed focused => { s3-endpoint-focus = self.focused; }
            }
        }

        // ── Auth method picker (filtered per backend) ────────────────────
        AtlasFieldGroup {
            SectionLabel { label: "Authentication"; }

            if is-sftp: AtlasSegmentedControl {
                segments: ["Password", "SSH Key", "Anonymous"];
                selected-index: root.sftp-auth-selected;
                selected(index) => {
                    root.auth-changed(index == 0 ? 0 : (index == 1 ? 1 : 3));
                }
            }

            if is-ftp || is-webdav: AtlasSegmentedControl {
                segments: ["Password", "Anonymous"];
                selected-index: root.password-anon-auth-selected;
                selected(index) => { root.auth-changed(index == 0 ? 0 : 3); }
            }

            if is-s3: AtlasSegmentedControl {
                segments: ["IAM", "Anonymous"];
                selected-index: root.s3-auth-selected;
                selected(index) => { root.auth-changed(index == 0 ? 2 : 3); }
            }
        }

        // ── Credentials ──────────────────────────────────────────────────
        if show-username || show-password || show-ssh-key || show-iam: VerticalLayout {
            height: root.credentials-h;
            spacing: Theme.space-3;

            if show-username: AtlasFieldGroup {
                SectionLabel { label: "Username"; }

                user-field := AtlasTextField {
                    text <=> root.username;
                    placeholder: "user@example.com";
                    edited(value) => { root.username-changed(value); }
                    escape-pressed => { root.cancel(); }
                    changed focused => { username-focus = self.focused; }
                }
            }

            if show-password: AtlasFieldGroup {
                SectionLabel { label: "Password"; }

                pw-field := AtlasTextField {
                    text <=> root.password;
                    password: true;
                    placeholder: "Password";
                    edited(value) => { root.password-changed(value); }
                    accepted => {
                        if !root.connecting {
                            if root.save-to-keychain {
                                root.save-and-connect();
                            } else {
                                root.connect();
                            }
                        }
                    }
                    escape-pressed => { root.cancel(); }
                    changed focused => { password-focus = self.focused; }
                }
            }

            if show-ssh-key: AtlasFieldGroup {
                SectionLabel { label: "SSH private key"; }

                HorizontalLayout {
                    spacing: Theme.space-2;

                    ssh-field := AtlasTextField {
                        horizontal-stretch: 1;
                        text <=> root.ssh-key-path;
                        placeholder: "~/.ssh/id_ed25519";
                        edited(value) => { root.ssh-key-path-changed(value); }
                        escape-pressed => { root.cancel(); }
                        changed focused => { ssh-key-focus = self.focused; }
                    }

                    AtlasSecondaryButton {
                        button-width: 78px;
                        text: "Browse…";
                        clicked => { root.browse-ssh-key(); }
                    }
                }
            }

            if show-iam: VerticalLayout {
                height: root.credentials-h;
                spacing: Theme.space-3;

                AtlasFieldGroup {
                    SectionLabel { label: "Access key ID"; }
                    iam-key-field := AtlasTextField {
                        text <=> root.iam-access-key;
                        placeholder: "AKIA…";
                        edited(value) => { root.iam-access-key-changed(value); }
                        changed focused => { iam-access-focus = self.focused; }
                    }
                }

                AtlasFieldGroup {
                    SectionLabel { label: "Secret key"; }
                    iam-secret-field := AtlasTextField {
                        text <=> root.iam-secret-key;
                        password: true;
                        placeholder: "Secret key";
                        edited(value) => { root.iam-secret-key-changed(value); }
                        changed focused => { iam-secret-focus = self.focused; }
                    }
                }

                AtlasFieldGroup {
                    SectionLabel { label: "Session token"; }
                    iam-session-field := AtlasTextField {
                        text <=> root.iam-session-token;
                        placeholder: "Optional";
                        edited(value) => { root.iam-session-token-changed(value); }
                        changed focused => { iam-session-focus = self.focused; }
                    }
                }
            }
        }

        // ── Save-to-keychain checkbox + Label ────────────────────────────
        HorizontalLayout {
            height: Theme.control-height;
            spacing: Theme.space-3;
            alignment: center;

            keychain-box := Rectangle {
                width: 18px;
                height: 18px;
                border-width: 1px;
                border-color: keychain-ta.has-hover ? Theme.secondary-button-border-hover : Theme.field-border;
                border-radius: Theme.radius-xs;
                background: root.save-to-keychain ? Theme.segmented-selected-bg : Theme.field-bg;

                keychain-ta := TouchArea {
                    width: 100%; height: 100%;
                    clicked => { root.toggle-save-to-keychain(); }
                }

                if root.save-to-keychain: Text {
                    text: "✓";
                    color: Theme.fg;
                    font-size: 12px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }

            Text {
                text: "Save to keychain";
                color: Theme.field-label-color;
                font-size: Theme.field-label-size;
                vertical-alignment: center;
            }

            label-field := AtlasTextField {
                horizontal-stretch: 1;
                text <=> root.label-text;
                placeholder: "Label (Production)";
                edited(value) => { root.label-changed(value); }
                escape-pressed => { root.cancel(); }
                changed focused => { label-focus = self.focused; }
            }
        }

        // ── Status area (multi-line error / info) ────────────────────────
        if root.status-text != "": Rectangle {
            height: 32px;
            background: root.status-is-error
                ? Theme.error.with-alpha(0.12)
                : Theme.list-bg;
            border-width: 1px;
            border-color: root.status-is-error ? Theme.error.with-alpha(0.52) : Theme.list-border;
            border-radius: Theme.list-radius;

            HorizontalLayout {
                padding-left: Theme.space-3;
                padding-right: Theme.space-3;
                alignment: center;

                Text {
                    text: root.status-text;
                    color: root.status-is-error ? Theme.error : Theme.fg-muted;
                    font-size: 12px;
                    wrap: word-wrap;
                    vertical-alignment: center;
                    horizontal-alignment: left;
                    horizontal-stretch: 1;
                }
            }
        }

        // ── Saved servers list ───────────────────────────────────────────
        VerticalLayout {
            height: root.saved-block-h;
            spacing: Theme.space-1 + 2px;

            HorizontalLayout {
                spacing: Theme.space-2;
                alignment: space-between;

                SectionLabel { label: "Saved Servers"; }

                Text {
                    text: root.saved-servers.length > 0
                        ? root.saved-servers.length + " total"
                        : "";
                    color: Theme.fg-faint;
                    font-size: 10px;
                    vertical-alignment: center;
                }
            }

            if root.saved-servers.length == 0 : AtlasList {
                height: 44px;

                Text {
                    text: "No saved servers yet. Save a connection to reuse it here.";
                    color: Theme.placeholder-color;
                    font-size: 12px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    wrap: word-wrap;
                    width: parent.width - Theme.space-4 * 2;
                    x: Theme.space-4;
                }
            }

            if root.saved-servers.length > 0 : AtlasList {
                height: min(5 * Theme.list-row-height, root.saved-servers.length * Theme.list-row-height);

                saved-list := ScrollView {
                    x: 0px; y: 0px;
                    width: parent.width;
                    height: parent.height;
                    viewport-width: parent.width;

                    VerticalLayout {
                        width: parent.width;
                        spacing: 0px;
                        padding: Theme.space-1;

                        for entry[i] in root.saved-servers : saved-row := AtlasListRow {
                            highlighted: row-ta.has-hover;
                            muted: entry.delete-pending;

                            row-ta := TouchArea {
                                width: 100%; height: 100%;
                                clicked => { root.saved-server-selected(entry.id); }
                            }

                            HorizontalLayout {
                                padding-left: Theme.space-2;
                                padding-right: Theme.space-2;
                                spacing: Theme.space-3;
                                alignment: center;

                                Text {
                                    text: entry.glyph;
                                    font-size: 17px;
                                    vertical-alignment: center;
                                    width: 22px;
                                    horizontal-alignment: center;
                                }

                                VerticalLayout {
                                    horizontal-stretch: 1;
                                    spacing: 0px;
                                    alignment: center;

                                    Text {
                                        text: entry.label;
                                        color: Theme.fg;
                                        font-size: 12px;
                                        font-weight: 500;
                                        overflow: elide;
                                    }
                                    Text {
                                        text: entry.address;
                                        color: Theme.fg-muted;
                                        font-size: 10px;
                                        overflow: elide;
                                    }
                                }

                                Text {
                                    text: entry.last-connected-relative;
                                    color: Theme.fg-faint;
                                    font-size: 10px;
                                    vertical-alignment: center;
                                    width: 76px;
                                    horizontal-alignment: right;
                                }

                                AtlasSecondaryButton {
                                    button-width: entry.delete-pending ? 88px : 56px;
                                    text: entry.delete-pending ? "Confirm" : "Delete";
                                    clicked => {
                                        if entry.delete-pending {
                                            root.saved-server-delete-confirmed(entry.id);
                                        } else {
                                            root.saved-server-delete-requested(entry.id);
                                        }
                                    }
                                }

                                if entry.delete-pending : AtlasSecondaryButton {
                                    button-width: 56px;
                                    text: "Cancel";
                                    clicked => { root.saved-server-delete-cancelled(); }
                                }
                            }
                        }
                    }
                }
            }
        }

        Rectangle {
            vertical-stretch: 1;
            background: transparent;
        }

        // ── Buttons ──────────────────────────────────────────────────────
        HorizontalLayout {
            height: Theme.control-height;
            spacing: Theme.space-2;
            alignment: end;

            AtlasSecondaryButton {
                button-width: 78px;
                text: "Cancel";
                enabled: !root.connecting;
                clicked => { root.cancel(); }
            }

            AtlasSecondaryButton {
                button-width: 126px;
                text: "Save + Connect";
                enabled: !root.connecting;
                clicked => {
                    if !root.connecting { root.save-and-connect(); }
                }
            }

            AtlasPrimaryButton {
                button-width: 108px;
                text: root.connecting ? "Connecting…" : "Connect";
                enabled: !root.connecting;
                clicked => {
                    if !root.connecting { root.connect(); }
                }
            }
        }
    }
}
