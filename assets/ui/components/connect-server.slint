// Connect-to-Server modal — remote-fs backend picker (SFTP / FTP / WebDAV / S3).
// Mirrors the visual grammar of `bulk-rename.slint` and `command-palette.slint`:
// dim scrim backdrop → centered elevated panel → theme tokens for every
// colour, radius, and space. All field values live as `in-out` properties on
// the root component so Rust owns the state and pushes changes back via the
// per-field `*-changed` callbacks (see rename-modal for the same pattern).
//
// # Visibility gating
//
// Fields fade in and out based on the currently-selected backend and auth
// method. The rules match the phase-2.3 spec:
//
// | Backend | Ports              | Auth methods                       |
// |---------|--------------------|------------------------------------|
// | SFTP    | 22 (default)       | Password, SSH Key, Anonymous       |
// | FTP     | 21 (default)       | Password, Anonymous                |
// | WebDAV  | 443 (default)      | Password, Anonymous                |
// | S3      | endpoint URL       | IAM, Anonymous                     |
//
// The `auth-index` values are stable across backends (0=Password, 1=SSH Key,
// 2=IAM, 3=Anonymous). Rust re-normalises `auth-index` on backend change so a
// user swapping SFTP → S3 with "SSH Key" selected snaps to a valid choice.
//
// # Chord routing
//
// `input-focused` is exported as an `out` property so the outer atlas.slint
// FocusScope can gate its keymap dispatcher on it. Same mechanism as the
// address-bar TextInput chord bypass introduced in `269ab5a`.

import { Theme } from "../theme.slint";
import { ScrollView } from "std-widgets.slint";

// A single row in the saved-servers list rendered beneath the modal's
// connection form. Populated by Rust (`ConnectController`) from
// `atlas_config::servers::list()`, sorted last-connected desc.
export struct SavedServerRow {
    /// Stable server id (matches `atlas_config::servers::SavedServer::id`).
    id: string,
    /// User-facing label ("prod", "home NAS", …), or `user@host` fallback.
    label: string,
    /// Display-ready subtitle — full URI (e.g. `sftp://landon@host:22/var`).
    address: string,
    /// Backend glyph used as the row's left icon (📁 🔐 ☁️ 🌐 📡).
    glyph: string,
    /// Preformatted relative-time string ("just now", "3 days ago", "never").
    last-connected-relative: string,
    /// True while this row is showing the inline "Delete?" confirm chip.
    delete-pending: bool,
}

export component ConnectServerModal inherits Rectangle {
    // ── Externally-controlled state ────────────────────────────────────────

    in property <bool> visible-modal: false;
    in-out property <int> backend-index: 0;
    in-out property <int> auth-index: 0;

    in-out property <string> host: "";
    in-out property <string> path: "";
    in-out property <string> username: "";
    in-out property <string> password: "";
    in-out property <string> ssh-key-path: "";
    in-out property <string> iam-access-key: "";
    in-out property <string> iam-secret-key: "";
    in-out property <string> iam-session-token: "";
    in-out property <string> s3-endpoint: "";
    in-out property <string> label-text: "";

    in property <bool> save-to-keychain: true;
    in property <bool> connecting: false;
    in property <string> status-text: "";
    in property <bool> status-is-error: false;

    // ── TOFU host-key prompt (Phase 2.6) ─────────────────────────────────
    //
    // The banner is inline above the host/path row so it can't be
    // dismissed just by scrolling. Rust sets `host-key-prompt-visible = true`
    // after the SFTP handshake yields an unknown or mismatched key; three
    // callbacks come back the other way. Non-empty
    // `host-key-mismatch-known-fingerprint` picks the red "key changed"
    // variant; empty picks the accent "first-time" variant.
    in property <bool> host-key-prompt-visible: false;
    in property <string> host-key-host: "";
    in property <string> host-key-fingerprint: "";
    in property <string> host-key-mismatch-known-fingerprint: "";

    // ── Saved-servers viewer ──────────────────────────────────────────────
    // The list is fully controlled by Rust: the `saved-servers` array is
    // rebuilt on modal open, on successful connect (to bump the recency
    // sort), and after a delete confirms. Rows fire either
    // `saved-server-selected` (populate the fields) or the pair
    // `saved-server-delete-requested` / `saved-server-delete-confirmed`
    // depending on which button the user hits.
    in property <[SavedServerRow]> saved-servers: [];

    // Reflects "any TextInput in this modal has focus". Bubbles up to the
    // window's FocusScope so Cmd+A / Cmd+C / Cmd+V land in the input, not
    // the pane's keymap dispatcher. Matches the address-bar mechanism from
    // 269ab5a.
    out property <bool> input-focused: host-focus || path-focus
        || username-focus || password-focus
        || ssh-key-focus || iam-access-focus
        || iam-secret-focus || iam-session-focus
        || s3-endpoint-focus || label-focus;

    // ── Callbacks fired at the Rust bridge ─────────────────────────────────

    callback backend-changed(int);
    callback auth-changed(int);
    callback host-changed(string);
    callback path-changed(string);
    callback username-changed(string);
    callback password-changed(string);
    callback ssh-key-path-changed(string);
    callback iam-access-key-changed(string);
    callback iam-secret-key-changed(string);
    callback iam-session-token-changed(string);
    callback s3-endpoint-changed(string);
    callback label-changed(string);
    callback toggle-save-to-keychain();
    callback browse-ssh-key();
    callback cancel();
    callback connect();
    callback save-and-connect();

    // ── Saved-servers callbacks ───────────────────────────────────────────
    /// A row was single-clicked. Rust populates the connection form.
    callback saved-server-selected(string /* id */);
    /// The row's Delete button was clicked once. Rust flips
    /// `delete-pending` on that row so the confirm chip renders.
    callback saved-server-delete-requested(string /* id */);
    /// The inline "Confirm delete?" chip was clicked. Rust removes the
    /// entry from servers.toml + purges the keychain secret.
    callback saved-server-delete-confirmed(string /* id */);
    /// The delete-pending state was aborted (Cancel clicked or another
    /// row selected). Rust clears `delete-pending` on all rows.
    callback saved-server-delete-cancelled();

    // ── TOFU host-key callbacks ─────────────────────────────────────────
    callback host-key-trust-once();
    callback host-key-trust-always();
    callback host-key-cancel();

    // ── Derived visibility flags ───────────────────────────────────────────
    // Backend indices: 0=SFTP, 1=FTP, 2=WebDAV, 3=S3.
    // Auth indices:    0=Password, 1=SSH Key, 2=IAM, 3=Anonymous.

    property <bool> is-sftp: backend-index == 0;
    property <bool> is-ftp: backend-index == 1;
    property <bool> is-webdav: backend-index == 2;
    property <bool> is-s3: backend-index == 3;

    property <bool> auth-password: auth-index == 0;
    property <bool> auth-ssh-key: auth-index == 1;
    property <bool> auth-iam: auth-index == 2;
    property <bool> auth-anon: auth-index == 3;

    property <bool> show-username: !auth-anon && !auth-iam;
    property <bool> show-password: auth-password;
    property <bool> show-ssh-key: auth-ssh-key;
    property <bool> show-iam: auth-iam;
    property <bool> show-s3-endpoint: is-s3;

    // Hint appended to the placeholder to show the merged `host:port`
    // syntax. Empty for S3 which uses a bucket name + endpoint URL.
    property <string> host-placeholder: is-s3
        ? "my-bucket"
        : "host.example.com or host.example.com:2222";

    // ── Per-input focus mirrors (used by `input-focused` above) ───────────

    property <bool> host-focus: false;
    property <bool> path-focus: false;
    property <bool> username-focus: false;
    property <bool> password-focus: false;
    property <bool> ssh-key-focus: false;
    property <bool> iam-access-focus: false;
    property <bool> iam-secret-focus: false;
    property <bool> iam-session-focus: false;
    property <bool> s3-endpoint-focus: false;
    property <bool> label-focus: false;

    if visible-modal: Rectangle {
        width: 100%;
        height: 100%;
        background: #00000066;

        // Backdrop click dismisses; matches bulk-rename.
        TouchArea {
            width: 100%;
            height: 100%;
            clicked => { root.cancel(); }
        }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: min(620px, parent.width - Theme.space-6 * 2);
            height: min(820px, parent.height - Theme.space-6 * 2);
            background: Theme.panel-bg-elevated;
            border-width: 1px;
            border-color: Theme.border;
            border-radius: Theme.radius-lg;

            // Swallow clicks on the panel body so they never propagate to the
            // scrim's dismiss handler.
            TouchArea {
                width: 100%;
                height: 100%;
            }

            VerticalLayout {
                padding: Theme.space-4;
                spacing: Theme.space-3;

                // ── Title ────────────────────────────────────────────────────
                Text {
                    text: "Connect to Server";
                    color: Theme.fg;
                    font-size: 17px;
                    font-weight: 600;
                    horizontal-alignment: left;
                }

                Rectangle { height: 1px; background: Theme.border; }

                // ── Backend picker (segmented control) ───────────────────────
                VerticalLayout {
                    spacing: Theme.space-1;

                    Text {
                        text: "BACKEND";
                        color: Theme.fg-muted;
                        font-size: 10px;
                        font-weight: 600;
                        
                    }

                    HorizontalLayout {
                        spacing: Theme.space-1;

                        for label[i] in ["SFTP", "FTP", "WebDAV", "S3"]: Rectangle {
                            horizontal-stretch: 1;
                            height: 30px;
                            border-radius: Theme.radius-sm;
                            border-width: 1px;
                            border-color: backend-index == i ? Theme.accent : Theme.border;
                            background: backend-index == i ? Theme.accent : Theme.panel-bg;

                            TouchArea {
                                width: 100%; height: 100%;
                                clicked => { root.backend-changed(i); }
                            }

                            Text {
                                text: label;
                                color: backend-index == i ? Theme.accent-fg : Theme.fg;
                                font-size: 12px;
                                font-weight: backend-index == i ? 600 : 400;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // ── TOFU host-key banner (Phase 2.6) ────────────────────────
                //
                // Two variants share one Rectangle to keep layout simple:
                //   * `host-key-mismatch-known-fingerprint == ""`  → first-time
                //     host: subtle accent-soft banner with three buttons.
                //   * `host-key-mismatch-known-fingerprint != ""`  → key changed:
                //     red-tinted banner with an extra "known" fingerprint line
                //     and an emphatic scary-warning header.
                //
                // Fingerprints render in the monospace theme font so the
                // 43-char SHA-256 body stays aligned when the user compares
                // two of them. The banner sits above the host row so a
                // scroll can't hide it.
                if root.host-key-prompt-visible: Rectangle {
                    property <bool> is-mismatch: root.host-key-mismatch-known-fingerprint != "";
                    border-width: 1px;
                    border-color: is-mismatch ? Theme.error : Theme.accent;
                    border-radius: Theme.radius-sm;
                    background: is-mismatch ? #ff6b6b1f : Theme.accent-soft;

                    VerticalLayout {
                        padding: Theme.space-3;
                        spacing: Theme.space-2;

                        Text {
                            text: is-mismatch
                                ? "⚠ SERVER KEY CHANGED"
                                : "The authenticity of this host can't be established.";
                            color: is-mismatch ? Theme.error : Theme.fg;
                            font-size: 12px;
                            font-weight: 700;
                            wrap: word-wrap;
                        }

                        Text {
                            text: is-mismatch
                                ? "Someone may be intercepting your connection, or this server's key legitimately rotated. Verify the new fingerprint before continuing."
                                : "Verify the fingerprint below matches what the server operator published, then trust it.";
                            color: Theme.fg-muted;
                            font-size: 11px;
                            wrap: word-wrap;
                        }

                        // Compact key/value grid — subject, offered fp, and
                        // (for mismatch) the previously-known fp.
                        VerticalLayout {
                            spacing: Theme.space-1;

                            HorizontalLayout {
                                spacing: Theme.space-2;
                                Text {
                                    text: "host";
                                    color: Theme.fg-faint;
                                    font-size: 10px;
                                    font-weight: 600;
                                    width: 60px;
                                }
                                Text {
                                    text: root.host-key-host;
                                    color: Theme.fg;
                                    font-family: Theme.monospace;
                                    font-size: 12px;
                                    horizontal-stretch: 1;
                                    wrap: word-wrap;
                                }
                            }

                            HorizontalLayout {
                                spacing: Theme.space-2;
                                Text {
                                    text: is-mismatch ? "offered" : "fingerprint";
                                    color: Theme.fg-faint;
                                    font-size: 10px;
                                    font-weight: 600;
                                    width: 60px;
                                }
                                Text {
                                    text: root.host-key-fingerprint;
                                    color: is-mismatch ? Theme.error : Theme.fg;
                                    font-family: Theme.monospace;
                                    font-size: 12px;
                                    horizontal-stretch: 1;
                                    wrap: word-wrap;
                                }
                            }

                            if is-mismatch: HorizontalLayout {
                                spacing: Theme.space-2;
                                Text {
                                    text: "known";
                                    color: Theme.fg-faint;
                                    font-size: 10px;
                                    font-weight: 600;
                                    width: 60px;
                                }
                                Text {
                                    text: root.host-key-mismatch-known-fingerprint;
                                    color: Theme.fg;
                                    font-family: Theme.monospace;
                                    font-size: 12px;
                                    horizontal-stretch: 1;
                                    wrap: word-wrap;
                                }
                            }
                        }

                        // Buttons row. Cancel is visually emphasised via the
                        // accent-outlined variant so it reads as the default
                        // action. The FocusScope grabs focus when the banner
                        // appears so the user can press Enter or Escape without
                        // touching the mouse.
                        host-key-focus := FocusScope {
                            width: 100%;
                            height: 30px;
                            key-pressed(event) => {
                                if event.text == Key.Escape {
                                    root.host-key-cancel();
                                    return accept;
                                }
                                if event.text == Key.Return {
                                    // Enter defaults to Cancel — the safest
                                    // choice per SSH's own prompt convention.
                                    root.host-key-cancel();
                                    return accept;
                                }
                                reject;
                            }
                            init => { self.focus(); }

                            HorizontalLayout {
                                spacing: Theme.space-2;

                                Rectangle {
                                    horizontal-stretch: 1;
                                    height: 30px;
                                    background: Theme.panel-bg;
                                    border-width: 1px;
                                    border-color: Theme.border;
                                    border-radius: Theme.radius-sm;
                                    TouchArea {
                                        width: 100%; height: 100%;
                                        clicked => { root.host-key-trust-once(); }
                                    }
                                    Text {
                                        text: "Trust once";
                                        color: Theme.fg;
                                        font-size: 12px;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                Rectangle {
                                    horizontal-stretch: 1;
                                    height: 30px;
                                    background: is-mismatch ? Theme.error : Theme.accent;
                                    border-width: 1px;
                                    border-color: is-mismatch ? Theme.error : Theme.accent;
                                    border-radius: Theme.radius-sm;
                                    TouchArea {
                                        width: 100%; height: 100%;
                                        clicked => { root.host-key-trust-always(); }
                                    }
                                    Text {
                                        text: is-mismatch ? "Replace and continue" : "Trust always";
                                        color: Theme.accent-fg;
                                        font-size: 12px;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }

                                Rectangle {
                                    horizontal-stretch: 1;
                                    height: 30px;
                                    background: Theme.panel-bg;
                                    border-width: 1px;
                                    border-color: Theme.accent;
                                    border-radius: Theme.radius-sm;
                                    TouchArea {
                                        width: 100%; height: 100%;
                                        clicked => { root.host-key-cancel(); }
                                    }
                                    Text {
                                        text: "Cancel";
                                        color: Theme.accent;
                                        font-size: 12px;
                                        font-weight: 600;
                                        horizontal-alignment: center;
                                        vertical-alignment: center;
                                    }
                                }
                            }
                        }
                    }
                }

                // ── Host / Path row ──────────────────────────────────────────
                HorizontalLayout {
                    spacing: Theme.space-2;

                    // Host — accepts either `host.example.com` or
                    // `host.example.com:2222`. The Rust controller
                    // splits any `:PORT` suffix off into the internal
                    // `port` state field on edit (see `set_host`).
                    VerticalLayout {
                        horizontal-stretch: 3;
                        spacing: Theme.space-1;

                        Text {
                            text: is-s3 ? "BUCKET" : "HOST";
                            color: Theme.fg-muted;
                            font-size: 10px;
                            font-weight: 600;
                            
                        }

                        Rectangle {
                            height: 30px;
                            border-width: 1px;
                            border-color: host-input.has-focus ? Theme.accent : Theme.border;
                            border-radius: Theme.radius-sm;
                            background: Theme.panel-bg;

                            // Whole cell (padding + placeholder area) delegates
                            // clicks to the TextInput. Sits below the
                            // HorizontalLayout so glyph-hits still land on the
                            // input directly (TextInput is topmost).
                            TouchArea {
                                width: 100%;
                                height: 100%;
                                clicked => { host-input.focus(); }
                            }

                            HorizontalLayout {
                                padding-left: Theme.space-3;
                                padding-right: Theme.space-3;
                                alignment: center;

                                host-input := TextInput {
                                    init => { self.focus(); }
                                    text <=> root.host;
                                    color: Theme.fg;
                                    font-size: Theme.font-size;
                                    vertical-alignment: center;
                                    single-line: true;
                                    horizontal-stretch: 1;
                                    edited => { root.host-changed(self.text); }
                                    changed has-focus => { host-focus = self.has-focus; }
                                    accepted => {
                                        if !root.connecting { root.connect(); }
                                    }
                                    key-pressed(event) => {
                                        if event.text == Key.Escape {
                                            root.cancel();
                                            return accept;
                                        }
                                        reject;
                                    }
                                }

                                if root.host == "": Text {
                                    text: host-placeholder;
                                    color: Theme.fg-faint;
                                    font-size: Theme.font-size;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                            }
                        }
                    }


                }

                // ── Path (own row so it can be wide) ─────────────────────────
                VerticalLayout {
                    spacing: Theme.space-1;

                    Text {
                        text: is-s3 ? "PREFIX" : "PATH";
                        color: Theme.fg-muted;
                        font-size: 10px;
                        font-weight: 600;
                        
                    }

                    Rectangle {
                        height: 30px;
                        border-width: 1px;
                        border-color: path-input.has-focus ? Theme.accent : Theme.border;
                        border-radius: Theme.radius-sm;
                        background: Theme.panel-bg;

                        TouchArea {
                            width: 100%;
                            height: 100%;
                            clicked => { path-input.focus(); }
                        }

                        HorizontalLayout {
                            padding-left: Theme.space-3;
                            padding-right: Theme.space-3;
                            alignment: center;

                            path-input := TextInput {
                                text <=> root.path;
                                color: Theme.fg;
                                font-size: Theme.font-size;
                                vertical-alignment: center;
                                single-line: true;
                                horizontal-stretch: 1;
                                edited => { root.path-changed(self.text); }
                                changed has-focus => { path-focus = self.has-focus; }
                                key-pressed(event) => {
                                    if event.text == Key.Escape {
                                        root.cancel();
                                        return accept;
                                    }
                                    reject;
                                }
                            }

                            if root.path == "": Text {
                                text: is-s3 ? "prefix/optional" : "/";
                                color: Theme.fg-faint;
                                font-size: Theme.font-size;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                        }
                    }
                }

                // ── S3 endpoint (non-standard S3 buckets — minio, LocalStack) ─
                if show-s3-endpoint: VerticalLayout {
                    spacing: Theme.space-1;

                    Text {
                        text: "ENDPOINT URL (leave blank for AWS)";
                        color: Theme.fg-muted;
                        font-size: 10px;
                        font-weight: 600;
                        
                    }

                    Rectangle {
                        height: 30px;
                        border-width: 1px;
                        border-color: s3ep-input.has-focus ? Theme.accent : Theme.border;
                        border-radius: Theme.radius-sm;
                        background: Theme.panel-bg;

                        TouchArea {
                            width: 100%;
                            height: 100%;
                            clicked => { s3ep-input.focus(); }
                        }

                        HorizontalLayout {
                            padding-left: Theme.space-3;
                            padding-right: Theme.space-3;
                            alignment: center;

                            s3ep-input := TextInput {
                                text <=> root.s3-endpoint;
                                color: Theme.fg;
                                font-size: Theme.font-size;
                                vertical-alignment: center;
                                single-line: true;
                                horizontal-stretch: 1;
                                edited => { root.s3-endpoint-changed(self.text); }
                                changed has-focus => { s3-endpoint-focus = self.has-focus; }
                                key-pressed(event) => {
                                    if event.text == Key.Escape {
                                        root.cancel();
                                        return accept;
                                    }
                                    reject;
                                }
                            }

                            if root.s3-endpoint == "": Text {
                                text: "http://localhost:9000";
                                color: Theme.fg-faint;
                                font-size: Theme.font-size;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                        }
                    }
                }

                // ── Auth method picker (filtered per backend) ────────────────
                VerticalLayout {
                    spacing: Theme.space-1;

                    Text {
                        text: "AUTHENTICATION";
                        color: Theme.fg-muted;
                        font-size: 10px;
                        font-weight: 600;
                        
                    }

                    HorizontalLayout {
                        spacing: Theme.space-1;

                        // Password chip — SFTP / FTP / WebDAV
                        if is-sftp || is-ftp || is-webdav: Rectangle {
                            horizontal-stretch: 1;
                            height: 28px;
                            border-radius: Theme.radius-sm;
                            border-width: 1px;
                            border-color: auth-index == 0 ? Theme.accent : Theme.border;
                            background: auth-index == 0 ? Theme.accent : Theme.panel-bg;

                            TouchArea {
                                width: 100%; height: 100%;
                                clicked => { root.auth-changed(0); }
                            }

                            Text {
                                text: "Password";
                                color: auth-index == 0 ? Theme.accent-fg : Theme.fg;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        // SSH Key chip — SFTP only
                        if is-sftp: Rectangle {
                            horizontal-stretch: 1;
                            height: 28px;
                            border-radius: Theme.radius-sm;
                            border-width: 1px;
                            border-color: auth-index == 1 ? Theme.accent : Theme.border;
                            background: auth-index == 1 ? Theme.accent : Theme.panel-bg;

                            TouchArea {
                                width: 100%; height: 100%;
                                clicked => { root.auth-changed(1); }
                            }

                            Text {
                                text: "SSH Key";
                                color: auth-index == 1 ? Theme.accent-fg : Theme.fg;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        // IAM chip — S3 only
                        if is-s3: Rectangle {
                            horizontal-stretch: 1;
                            height: 28px;
                            border-radius: Theme.radius-sm;
                            border-width: 1px;
                            border-color: auth-index == 2 ? Theme.accent : Theme.border;
                            background: auth-index == 2 ? Theme.accent : Theme.panel-bg;

                            TouchArea {
                                width: 100%; height: 100%;
                                clicked => { root.auth-changed(2); }
                            }

                            Text {
                                text: "IAM";
                                color: auth-index == 2 ? Theme.accent-fg : Theme.fg;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }

                        // Anonymous chip — every backend
                        Rectangle {
                            horizontal-stretch: 1;
                            height: 28px;
                            border-radius: Theme.radius-sm;
                            border-width: 1px;
                            border-color: auth-index == 3 ? Theme.accent : Theme.border;
                            background: auth-index == 3 ? Theme.accent : Theme.panel-bg;

                            TouchArea {
                                width: 100%; height: 100%;
                                clicked => { root.auth-changed(3); }
                            }

                            Text {
                                text: "Anonymous";
                                color: auth-index == 3 ? Theme.accent-fg : Theme.fg;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // ── Username (hidden for anon and IAM) ───────────────────────
                if show-username: VerticalLayout {
                    spacing: Theme.space-1;

                    Text {
                        text: "USERNAME";
                        color: Theme.fg-muted;
                        font-size: 10px;
                        font-weight: 600;
                        
                    }

                    Rectangle {
                        height: 30px;
                        border-width: 1px;
                        border-color: user-input.has-focus ? Theme.accent : Theme.border;
                        border-radius: Theme.radius-sm;
                        background: Theme.panel-bg;

                        TouchArea {
                            width: 100%;
                            height: 100%;
                            clicked => { user-input.focus(); }
                        }

                        HorizontalLayout {
                            padding-left: Theme.space-3;
                            padding-right: Theme.space-3;
                            alignment: center;

                            user-input := TextInput {
                                text <=> root.username;
                                color: Theme.fg;
                                font-size: Theme.font-size;
                                vertical-alignment: center;
                                single-line: true;
                                horizontal-stretch: 1;
                                edited => { root.username-changed(self.text); }
                                changed has-focus => { username-focus = self.has-focus; }
                                key-pressed(event) => {
                                    if event.text == Key.Escape {
                                        root.cancel();
                                        return accept;
                                    }
                                    reject;
                                }
                            }
                        }
                    }
                }

                // ── Password (Password auth only) ────────────────────────────
                if show-password: VerticalLayout {
                    spacing: Theme.space-1;

                    Text {
                        text: "PASSWORD";
                        color: Theme.fg-muted;
                        font-size: 10px;
                        font-weight: 600;
                        
                    }

                    Rectangle {
                        height: 30px;
                        border-width: 1px;
                        border-color: pw-input.has-focus ? Theme.accent : Theme.border;
                        border-radius: Theme.radius-sm;
                        background: Theme.panel-bg;

                        TouchArea {
                            width: 100%;
                            height: 100%;
                            clicked => { pw-input.focus(); }
                        }

                        HorizontalLayout {
                            padding-left: Theme.space-3;
                            padding-right: Theme.space-3;
                            alignment: center;

                            pw-input := TextInput {
                                text <=> root.password;
                                color: Theme.fg;
                                font-size: Theme.font-size;
                                vertical-alignment: center;
                                single-line: true;
                                horizontal-stretch: 1;
                                input-type: InputType.password;
                                edited => { root.password-changed(self.text); }
                                changed has-focus => { password-focus = self.has-focus; }
                                accepted => {
                                    if !root.connecting {
                                        if root.save-to-keychain {
                                            root.save-and-connect();
                                        } else {
                                            root.connect();
                                        }
                                    }
                                }
                                key-pressed(event) => {
                                    if event.text == Key.Escape {
                                        root.cancel();
                                        return accept;
                                    }
                                    reject;
                                }
                            }
                        }
                    }
                }

                // ── SSH key path + Browse (SSH Key auth only) ────────────────
                if show-ssh-key: VerticalLayout {
                    spacing: Theme.space-1;

                    Text {
                        text: "SSH PRIVATE KEY PATH";
                        color: Theme.fg-muted;
                        font-size: 10px;
                        font-weight: 600;
                        
                    }

                    HorizontalLayout {
                        spacing: Theme.space-2;

                        Rectangle {
                            horizontal-stretch: 1;
                            height: 30px;
                            border-width: 1px;
                            border-color: ssh-input.has-focus ? Theme.accent : Theme.border;
                            border-radius: Theme.radius-sm;
                            background: Theme.panel-bg;

                            TouchArea {
                                width: 100%;
                                height: 100%;
                                clicked => { ssh-input.focus(); }
                            }

                            HorizontalLayout {
                                padding-left: Theme.space-3;
                                padding-right: Theme.space-3;
                                alignment: center;

                                ssh-input := TextInput {
                                    text <=> root.ssh-key-path;
                                    color: Theme.fg;
                                    font-size: Theme.font-size;
                                    vertical-alignment: center;
                                    single-line: true;
                                    horizontal-stretch: 1;
                                    edited => { root.ssh-key-path-changed(self.text); }
                                    changed has-focus => { ssh-key-focus = self.has-focus; }
                                    key-pressed(event) => {
                                        if event.text == Key.Escape {
                                            root.cancel();
                                            return accept;
                                        }
                                        reject;
                                    }
                                }

                                if root.ssh-key-path == "": Text {
                                    text: "~/.ssh/id_ed25519";
                                    color: Theme.fg-faint;
                                    font-size: Theme.font-size;
                                    vertical-alignment: center;
                                    horizontal-stretch: 1;
                                }
                            }
                        }

                        Rectangle {
                            width: 78px;
                            height: 30px;
                            border-width: 1px;
                            border-color: Theme.border;
                            border-radius: Theme.radius-sm;
                            background: Theme.panel-bg;

                            TouchArea {
                                width: 100%; height: 100%;
                                clicked => { root.browse-ssh-key(); }
                            }

                            Text {
                                text: "Browse…";
                                color: Theme.fg;
                                font-size: 12px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                            }
                        }
                    }
                }

                // ── IAM credentials (S3 IAM auth only) ───────────────────────
                if show-iam: VerticalLayout {
                    spacing: Theme.space-2;

                    VerticalLayout {
                        spacing: Theme.space-1;
                        Text {
                            text: "ACCESS KEY ID";
                            color: Theme.fg-muted;
                            font-size: 10px;
                            font-weight: 600;
                            
                        }
                        Rectangle {
                            height: 30px;
                            border-width: 1px;
                            border-color: iam-key.has-focus ? Theme.accent : Theme.border;
                            border-radius: Theme.radius-sm;
                            background: Theme.panel-bg;

                            TouchArea {
                                width: 100%;
                                height: 100%;
                                clicked => { iam-key.focus(); }
                            }

                            HorizontalLayout {
                                padding-left: Theme.space-3;
                                padding-right: Theme.space-3;
                                alignment: center;

                                iam-key := TextInput {
                                    text <=> root.iam-access-key;
                                    color: Theme.fg;
                                    font-size: Theme.font-size;
                                    vertical-alignment: center;
                                    single-line: true;
                                    horizontal-stretch: 1;
                                    edited => { root.iam-access-key-changed(self.text); }
                                    changed has-focus => { iam-access-focus = self.has-focus; }
                                }
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: Theme.space-1;
                        Text {
                            text: "SECRET KEY";
                            color: Theme.fg-muted;
                            font-size: 10px;
                            font-weight: 600;
                            
                        }
                        Rectangle {
                            height: 30px;
                            border-width: 1px;
                            border-color: iam-sec.has-focus ? Theme.accent : Theme.border;
                            border-radius: Theme.radius-sm;
                            background: Theme.panel-bg;

                            TouchArea {
                                width: 100%;
                                height: 100%;
                                clicked => { iam-sec.focus(); }
                            }

                            HorizontalLayout {
                                padding-left: Theme.space-3;
                                padding-right: Theme.space-3;
                                alignment: center;

                                iam-sec := TextInput {
                                    text <=> root.iam-secret-key;
                                    color: Theme.fg;
                                    font-size: Theme.font-size;
                                    vertical-alignment: center;
                                    single-line: true;
                                    horizontal-stretch: 1;
                                    input-type: InputType.password;
                                    edited => { root.iam-secret-key-changed(self.text); }
                                    changed has-focus => { iam-secret-focus = self.has-focus; }
                                }
                            }
                        }
                    }

                    VerticalLayout {
                        spacing: Theme.space-1;
                        Text {
                            text: "SESSION TOKEN (OPTIONAL)";
                            color: Theme.fg-muted;
                            font-size: 10px;
                            font-weight: 600;
                            
                        }
                        Rectangle {
                            height: 30px;
                            border-width: 1px;
                            border-color: iam-tok.has-focus ? Theme.accent : Theme.border;
                            border-radius: Theme.radius-sm;
                            background: Theme.panel-bg;

                            TouchArea {
                                width: 100%;
                                height: 100%;
                                clicked => { iam-tok.focus(); }
                            }

                            HorizontalLayout {
                                padding-left: Theme.space-3;
                                padding-right: Theme.space-3;
                                alignment: center;

                                iam-tok := TextInput {
                                    text <=> root.iam-session-token;
                                    color: Theme.fg;
                                    font-size: Theme.font-size;
                                    vertical-alignment: center;
                                    single-line: true;
                                    horizontal-stretch: 1;
                                    edited => { root.iam-session-token-changed(self.text); }
                                    changed has-focus => { iam-session-focus = self.has-focus; }
                                }
                            }
                        }
                    }
                }

                // ── Save-to-keychain checkbox + Label ────────────────────────
                HorizontalLayout {
                    spacing: Theme.space-3;
                    alignment: stretch;

                    // Custom checkbox chip (defaults ON per phase-2 design).
                    Rectangle {
                        width: 20px;
                        height: 20px;
                        y: (parent.height - self.height) / 2;
                        border-width: 1px;
                        border-color: Theme.border-strong;
                        border-radius: Theme.radius-xs;
                        background: root.save-to-keychain ? Theme.accent : Theme.panel-bg;

                        TouchArea {
                            width: 100%; height: 100%;
                            clicked => { root.toggle-save-to-keychain(); }
                        }

                        if root.save-to-keychain: Text {
                            text: "✓";
                            color: Theme.accent-fg;
                            font-size: 13px;
                            font-weight: 700;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Text {
                        y: (parent.height - self.height) / 2;
                        text: "Save to keychain";
                        color: Theme.fg;
                        font-size: 12px;
                        vertical-alignment: center;
                    }

                    Rectangle {
                        horizontal-stretch: 1;
                        height: 30px;
                        border-width: 1px;
                        border-color: label-input.has-focus ? Theme.accent : Theme.border;
                        border-radius: Theme.radius-sm;
                        background: Theme.panel-bg;

                        TouchArea {
                            width: 100%;
                            height: 100%;
                            clicked => { label-input.focus(); }
                        }

                        HorizontalLayout {
                            padding-left: Theme.space-3;
                            padding-right: Theme.space-3;
                            alignment: center;

                            label-input := TextInput {
                                text <=> root.label-text;
                                color: Theme.fg;
                                font-size: Theme.font-size;
                                vertical-alignment: center;
                                single-line: true;
                                horizontal-stretch: 1;
                                edited => { root.label-changed(self.text); }
                                changed has-focus => { label-focus = self.has-focus; }
                                key-pressed(event) => {
                                    if event.text == Key.Escape {
                                        root.cancel();
                                        return accept;
                                    }
                                    reject;
                                }
                            }

                            if root.label-text == "": Text {
                                text: "Label (e.g. prod, home NAS)";
                                color: Theme.fg-faint;
                                font-size: Theme.font-size;
                                vertical-alignment: center;
                                horizontal-stretch: 1;
                            }
                        }
                    }
                }

                // ── Status area (multi-line error / info) ────────────────────
                if root.status-text != "": Rectangle {
                    height: 32px;
                    background: root.status-is-error
                        ? Theme.error.with-alpha(0.12)
                        : Theme.accent-soft;
                    border-radius: Theme.radius-sm;

                    HorizontalLayout {
                        padding-left: Theme.space-3;
                        padding-right: Theme.space-3;
                        alignment: center;

                        Text {
                            text: root.status-text;
                            color: root.status-is-error ? Theme.error : Theme.fg;
                            font-size: 12px;
                            wrap: word-wrap;
                            vertical-alignment: center;
                            horizontal-alignment: left;
                            horizontal-stretch: 1;
                        }
                    }
                }

                // ── Saved servers list ───────────────────────────────────────
                //
                // Displayed under the connection form. Each row shows the
                // backend glyph, the label + full URI, a relative-time
                // hint, and Edit / Delete affordances. Clicking anywhere
                // outside those controls populates the form. Delete uses a
                // two-step confirm — the first click flips `delete-pending`
                // on that row (chip morphs into "Delete?" / "Cancel"), a
                // subsequent click on "Delete?" removes the entry and its
                // keychain secret. Capped at ~6 visible rows via
                // `saved-servers-viewport`.
                Rectangle { height: 1px; background: Theme.border; }

                VerticalLayout {
                    spacing: Theme.space-1;

                    HorizontalLayout {
                        spacing: Theme.space-2;
                        alignment: space-between;

                        Text {
                            text: "SAVED SERVERS";
                            color: Theme.fg-muted;
                            font-size: 10px;
                            font-weight: 600;
                            vertical-alignment: center;
                        }

                        Text {
                            text: root.saved-servers.length > 0
                                ? root.saved-servers.length + " total"
                                : "";
                            color: Theme.fg-faint;
                            font-size: 10px;
                            vertical-alignment: center;
                        }
                    }

                    if root.saved-servers.length == 0 : Rectangle {
                        height: 48px;
                        background: Theme.panel-bg;
                        border-width: 1px;
                        border-color: Theme.border;
                        border-radius: Theme.radius-sm;

                        Text {
                            text: "No saved servers yet. Fill in a connection above and click Save + Connect.";
                            color: Theme.fg-faint;
                            font-size: 12px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            wrap: word-wrap;
                            width: parent.width - Theme.space-4 * 2;
                            x: Theme.space-4;
                        }
                    }

                    // Cap the viewport at ~6 rows (row-h 44px × 6 + spacing).
                    if root.saved-servers.length > 0 : saved-servers-viewport := Rectangle {
                        height: min(6 * 44px + Theme.space-1 * 5, root.saved-servers.length * 44px + max(root.saved-servers.length - 1, 0) * Theme.space-1);
                        border-width: 1px;
                        border-color: Theme.border;
                        border-radius: Theme.radius-sm;
                        background: Theme.panel-bg;
                        clip: true;

                        saved-list := ScrollView {
                            x: 0px; y: 0px;
                            width: parent.width;
                            height: parent.height;
                            viewport-width: parent.width;

                            VerticalLayout {
                                width: parent.width;
                                spacing: Theme.space-1;
                                padding: Theme.space-1;

                                for entry[i] in root.saved-servers : Rectangle {
                                    height: 40px;
                                    background: row-ta.has-hover ? Theme.hover-bg : transparent;
                                    border-radius: Theme.radius-xs;
                                    border-width: entry.delete-pending ? 1px : 0px;
                                    border-color: Theme.error;

                                    row-ta := TouchArea {
                                        width: 100%; height: 100%;
                                        clicked => {
                                            root.saved-server-selected(entry.id);
                                        }
                                    }

                                    HorizontalLayout {
                                        padding-left: Theme.space-2;
                                        padding-right: Theme.space-2;
                                        spacing: Theme.space-3;
                                        alignment: center;

                                        // Backend glyph
                                        Text {
                                            text: entry.glyph;
                                            font-size: 18px;
                                            vertical-alignment: center;
                                            width: 22px;
                                            horizontal-alignment: center;
                                        }

                                        // Label + address
                                        VerticalLayout {
                                            horizontal-stretch: 1;
                                            spacing: 0px;
                                            alignment: center;

                                            Text {
                                                text: entry.label;
                                                color: Theme.fg;
                                                font-size: 12px;
                                                font-weight: 500;
                                                overflow: elide;
                                            }
                                            Text {
                                                text: entry.address;
                                                color: Theme.fg-muted;
                                                font-size: 10px;
                                                overflow: elide;
                                            }
                                        }

                                        // Last-connected relative
                                        Text {
                                            text: entry.last-connected-relative;
                                            color: Theme.fg-faint;
                                            font-size: 10px;
                                            vertical-alignment: center;
                                            width: 76px;
                                            horizontal-alignment: right;
                                        }

                                        // Delete button (morphs into "Delete?" chip once armed)
                                        Rectangle {
                                            width: entry.delete-pending ? 96px : 64px;
                                            height: 26px;
                                            border-radius: Theme.radius-xs;
                                            border-width: 1px;
                                            border-color: entry.delete-pending
                                                ? Theme.error
                                                : Theme.border;
                                            background: entry.delete-pending
                                                ? Theme.error.with-alpha(0.12)
                                                : Theme.panel-bg;

                                            delete-ta := TouchArea {
                                                width: 100%; height: 100%;
                                                clicked => {
                                                    if entry.delete-pending {
                                                        root.saved-server-delete-confirmed(entry.id);
                                                    } else {
                                                        root.saved-server-delete-requested(entry.id);
                                                    }
                                                }
                                            }

                                            Text {
                                                text: entry.delete-pending ? "Confirm?" : "Delete";
                                                color: entry.delete-pending ? Theme.error : Theme.fg-muted;
                                                font-size: 11px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }

                                        // Cancel-delete (only when armed)
                                        if entry.delete-pending : Rectangle {
                                            width: 64px;
                                            height: 26px;
                                            border-radius: Theme.radius-xs;
                                            border-width: 1px;
                                            border-color: Theme.border;
                                            background: Theme.panel-bg;

                                            cancel-ta := TouchArea {
                                                width: 100%; height: 100%;
                                                clicked => { root.saved-server-delete-cancelled(); }
                                            }

                                            Text {
                                                text: "Cancel";
                                                color: Theme.fg-muted;
                                                font-size: 11px;
                                                horizontal-alignment: center;
                                                vertical-alignment: center;
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }

                // Vertical spring so buttons hug the bottom on tall modals.
                Rectangle {
                    vertical-stretch: 1;
                    background: transparent;
                }

                Rectangle { height: 1px; background: Theme.border; }

                // ── Buttons ──────────────────────────────────────────────────
                HorizontalLayout {
                    spacing: Theme.space-2;
                    alignment: end;

                    Rectangle {
                        width: 78px;
                        height: 30px;
                        border-radius: Theme.radius-sm;
                        border-width: 1px;
                        border-color: Theme.border;
                        background: Theme.panel-bg;
                        opacity: root.connecting ? 0.5 : 1.0;

                        TouchArea {
                            width: 100%; height: 100%;
                            clicked => { root.cancel(); }
                        }

                        Text {
                            text: "Cancel";
                            color: Theme.fg;
                            font-size: 13px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        width: 108px;
                        height: 30px;
                        border-radius: Theme.radius-sm;
                        border-width: 1px;
                        border-color: Theme.border-strong;
                        background: Theme.panel-bg;
                        opacity: root.connecting ? 0.5 : 1.0;

                        TouchArea {
                            width: 100%; height: 100%;
                            clicked => {
                                if !root.connecting { root.connect(); }
                            }
                        }

                        Text {
                            text: root.connecting ? "Connecting…" : "Connect";
                            color: Theme.fg;
                            font-size: 13px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }

                    Rectangle {
                        width: 152px;
                        height: 30px;
                        border-radius: Theme.radius-sm;
                        background: Theme.accent;
                        opacity: root.connecting ? 0.5 : 1.0;

                        TouchArea {
                            width: 100%; height: 100%;
                            clicked => {
                                if !root.connecting { root.save-and-connect(); }
                            }
                        }

                        Text {
                            text: "Save + Connect";
                            color: Theme.accent-fg;
                            font-size: 13px;
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
