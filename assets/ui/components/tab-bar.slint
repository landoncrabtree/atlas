import { Theme } from "../theme.slint";

export struct TabEntry {
    title: string,
    dirty: bool,
}

export component TabBar {
    in property <[TabEntry]> tabs: [];
    in property <int> active-index: 0;

    callback select(int);
    callback close(int);
    callback new-tab();

    height: Theme.tab-h;

    // Fixed tab width — overflow clips rather than pushing the window
    // wider. A future v0.2 will replace this with a proper horizontal
    // scroller + tab dropdown when overflow.
    property <length> tab-w: 140px;

    Rectangle {
        background: Theme.panel-bg;
        clip: true;

        // Bottom border
        Rectangle {
            y: parent.height - 1px;
            height: 1px;
            background: Theme.border;
        }

        HorizontalLayout {
            alignment: start;
            spacing: Theme.space-1;
            padding-left: Theme.space-2;
            padding-right: Theme.space-2;

            for tab[i] in tabs: tab-outer := Rectangle {
                width: root.tab-w;
                height: Theme.tab-h;
                background: transparent;

                tab-ta := TouchArea {
                    x: 0px; y: 0px;
                    width: parent.width;
                    height: parent.height;
                    clicked => { root.select(i); }
                }

                // Pill background
                pill := Rectangle {
                    x: 0px;
                    y: (Theme.tab-h - 26px) / 2;
                    width: parent.width;
                    height: 26px;
                    border-radius: Theme.radius-sm;
                    background: i == active-index
                        ? Theme.panel-bg-elevated
                        : (tab-ta.has-hover ? Theme.hover-bg : transparent);
                    animate background { duration: 120ms; easing: ease-out; }
                }

                // Active bottom accent rail
                if i == active-index : Rectangle {
                    x: Theme.space-2;
                    y: Theme.tab-h - 2px;
                    width: parent.width - Theme.space-2 * 2;
                    height: 2px;
                    border-radius: 1px;
                    background: Theme.accent;
                }

                HorizontalLayout {
                    x: 0px; y: 0px;
                    width: parent.width;
                    height: Theme.tab-h;
                    alignment: center;
                    spacing: Theme.space-1;
                    padding-left: Theme.space-3;
                    padding-right: Theme.space-1;

                    Text {
                        text: (tab.dirty ? "● " : "") + tab.title;
                        color: i == active-index ? Theme.fg : Theme.fg-muted;
                        font-size: 12px;
                        vertical-alignment: center;
                        overflow: elide;
                        horizontal-stretch: 1;
                        animate color { duration: 120ms; easing: ease-out; }
                    }

                    // Close button — visible only on hover (progressive disclosure)
                    close-ta := TouchArea {
                        width: 18px;
                        height: 18px;
                        visible: tab-ta.has-hover || i == active-index;
                        clicked => { root.close(i); }

                        Rectangle {
                            width: parent.width;
                            height: parent.height;
                            border-radius: parent.width / 2;
                            background: close-ta.has-hover ? Theme.border-strong : transparent;
                            animate background { duration: 100ms; easing: ease-out; }

                            Text {
                                text: "✕";
                                color: close-ta.has-hover ? Theme.fg : Theme.fg-muted;
                                font-size: 10px;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                }
            }

            // New-tab + button
            new-ta := TouchArea {
                width: 28px;
                height: Theme.tab-h;
                clicked => { root.new-tab(); }

                Text {
                    text: "+";
                    color: new-ta.has-hover ? Theme.fg-muted : Theme.fg-faint;
                    font-size: 16px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    width: parent.width;
                    height: parent.height;
                    animate color { duration: 120ms; easing: ease-out; }
                }
            }
        }
    }
}
