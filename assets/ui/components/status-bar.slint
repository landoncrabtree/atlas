import { Theme } from "../theme.slint";

export component StatusBar {
    in property <int> total-entries: 0;
    in property <int> folder-count: 0;
    in property <int> file-count: 0;
    in property <string> total-size-text: "";
    in property <int> selected-entries: 0;
    in property <string> selected-size-text: "";
    in property <string> view-mode: "Details";
    in property <string> sort-by: "Name";
    in property <string> indexer-status: "Stopped";

    height: Theme.statusbar-h;

    pure function primary-text() -> string {
        selected-entries > 0
            ? selected-entries + " selected · " + selected-size-text
            : folder-count + " folders, " + file-count + " files · " + total-size-text
    }

    Rectangle {
        background: Theme.panel-bg;

        // Top border only
        Rectangle {
            x: 0px; y: 0px;
            height: 1px;
            width: parent.width;
            background: Theme.border;
        }

        HorizontalLayout {
            padding-left: Theme.space-4;
            padding-right: Theme.space-4;
            spacing: Theme.space-4;

            Text {
                text: primary-text();
                color: Theme.fg-muted;
                font-size: 11px;
                vertical-alignment: center;
            }

            Rectangle { horizontal-stretch: 1; }

            Text {
                text: view-mode;
                color: Theme.fg-muted;
                font-size: 11px;
                vertical-alignment: center;
            }

            Text {
                text: sort-by;
                color: Theme.fg-muted;
                font-size: 11px;
                vertical-alignment: center;
            }

            Text {
                text: indexer-status;
                color: indexer-status == "Error"
                    ? Theme.error
                    : indexer-status == "Stopped"
                        ? Theme.fg-faint
                        : Theme.success;
                font-size: 11px;
                vertical-alignment: center;
            }
        }
    }
}
