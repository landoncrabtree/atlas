import { Theme } from "../theme.slint";

export component StatusBar {
    in property <int> total-entries: 0;
    in property <int> selected-entries: 0;
    in property <string> view-mode: "Details";
    in property <string> sort-by: "Name";
    in property <string> indexer-status: "Stopped";

    height: Theme.statusbar-h;

    Rectangle {
        background: Theme.panel-bg;

        // Top border only
        Rectangle {
            x: 0px; y: 0px;
            height: 1px;
            width: parent.width;
            background: Theme.border;
        }

        HorizontalLayout {
            padding-left: Theme.space-4;
            padding-right: Theme.space-4;
            spacing: Theme.space-4;

            Text {
                text: selected-entries > 0
                    ? selected-entries + " of " + total-entries + " selected"
                    : total-entries + " items";
                color: Theme.fg-muted;
                font-size: 11px;
                vertical-alignment: center;
            }

            Rectangle { horizontal-stretch: 1; }

            Text {
                text: view-mode;
                color: Theme.fg-muted;
                font-size: 11px;
                vertical-alignment: center;
            }

            Text {
                text: sort-by;
                color: Theme.fg-muted;
                font-size: 11px;
                vertical-alignment: center;
            }

            Text {
                text: indexer-status;
                color: indexer-status == "Error"
                    ? Theme.error
                    : indexer-status == "Stopped"
                        ? Theme.fg-faint
                        : Theme.success;
                font-size: 11px;
                vertical-alignment: center;
            }
        }
    }
}
