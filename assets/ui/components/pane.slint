import { Theme } from "../theme.slint";
import { AddressBar } from "address-bar.slint";
import { Breadcrumbs } from "breadcrumbs.slint";
import { TabBar, TabEntry } from "tab-bar.slint";
import { EmptyView } from "../views/empty-view.slint";
import { DetailsView } from "../views/details/details-view.slint";
import { GridView } from "../views/grid/grid-view.slint";
import { GalleryView } from "../views/gallery/gallery-view.slint";
import { MillerView } from "../views/miller/miller-view.slint";
import { MillerColData } from "../views/miller/miller-state.slint";
import { EntryRowItem, ColumnSpec } from "../views/details/column.slint";
import { MetadataFields } from "../views/gallery/gallery-metadata.slint";

// Bottom-of-pane status bar. Shows folder/file counts, cumulative size,
// and free-space for the pane's volume. Styled to match the deprecated
// window-level StatusBar (`Theme.panel-bg`, muted caption, 24px tall).
// Reserves height even when every string is empty so the pane layout
// doesn't jump when a new pane first opens.
//
// Layout: counts on the LEFT, flex spacer, "N free of M" on the RIGHT
// hugging `padding-right`. For remote panes the connection-status
// chip sits between the primary text and the spacer. Future plugin
// chips (git branch, k8s context, devcontainer badge, …) will slot in
// between the spacer and the free-space text once the plugin runtime
// lands (v0.4+); until then no placeholder element is instantiated so
// the free-space chunk truly reaches the pane's right edge.
component PaneStatusBar {
    in property <int> folder-count: 0;
    in property <int> file-count: 0;
    in property <string> total-size-text: "";
    in property <string> free-space-text: "";
    /// Connection status for remote panes. One of `"local"`, `"ok"`,
    /// `"reconnecting"`, `"failed"`. Empty string == same as `"local"`
    /// (no chip rendered).
    in property <string> connection-status: "local";
    /// Optional tooltip text — surfaced to the user on hover; also
    /// used for the `accessible-label` so a screen reader gets the
    /// full context.
    in property <string> connection-tooltip: "";
    /// Ephemeral warning banner. Rendered as an amber chip in the
    /// status bar when non-empty. Auto-cleared by Rust after a short
    /// dismissal window (see `AppShell::push_pane_warning`).
    in property <string> warning-text: "";

    height: Theme.statusbar-h;

    pure function primary-text() -> string {
        folder-count + " folders, " + file-count + " files"
            + (total-size-text != "" ? " · " + total-size-text : "")
    }

    pure function chip-color() -> color {
        connection-status == "ok"           ? #22c55e :
        connection-status == "reconnecting" ? #eab308 :
        connection-status == "failed"       ? Theme.error :
        transparent
    }

    pure function chip-label() -> string {
        connection-status == "ok"           ? "connected" :
        connection-status == "reconnecting" ? "reconnecting…" :
        connection-status == "failed"       ? "disconnected" :
        ""
    }

    Rectangle {
        background: Theme.panel-bg;

        // Top border only — mirrors the global StatusBar look.
        Rectangle {
            x: 0px; y: 0px;
            height: 1px;
            width: parent.width;
            background: Theme.border;
        }

        HorizontalLayout {
            padding-left: Theme.space-4;
            padding-right: Theme.space-4;
            spacing: Theme.space-4;

            Text {
                text: primary-text();
                color: Theme.fg-muted;
                font-size: 11px;
                vertical-alignment: center;
            }

            // Remote connection chip. Rendered only for non-local
            // panes; a green/yellow/red dot next to a caption. The
            // `accessible-label` folds the tooltip text so a screen
            // reader can announce the retry / failure detail even
            // though there's no hover tooltip in Slint 1.17.
            if connection-status != "local" && connection-status != "" : HorizontalLayout {
                spacing: Theme.space-2;
                Rectangle {
                    width: 8px; height: 8px;
                    y: (parent.height - self.height) / 2;
                    background: chip-color();
                    border-radius: 4px;
                    accessible-role: text;
                    accessible-label: connection-tooltip;
                }
                Text {
                    text: chip-label();
                    color: chip-color();
                    font-size: 11px;
                    vertical-alignment: center;
                    accessible-role: text;
                    accessible-label: connection-tooltip;
                }
            }

            // Ephemeral warning chip (e.g. "file too large to
            // preview"). Same footprint as the connection chip; auto-
            // cleared by Rust after a short window.
            if warning-text != "" : Text {
                text: "⚠ " + warning-text;
                color: #eab308;
                font-size: 11px;
                vertical-alignment: center;
                accessible-role: text;
                accessible-label: warning-text;
            }

            Rectangle { horizontal-stretch: 1; }

            if free-space-text != "" : Text {
                text: free-space-text;
                color: Theme.fg-faint;
                font-size: 11px;
                vertical-alignment: center;
            }
        }
    }
}

// A single pane: address bar + breadcrumbs + tab bar + content view.
//
// `pane-id` is the stable semantic identifier (matches the Rust `PaneId`);
// the parent passes it through so callbacks can carry it up to `AtlasWindow`
// without the pane needing to know its own array position.
export component Pane {
    /// Stable pane identifier forwarded to every callback (Phase 4).
    in property <int> pane-id: -1;
    in property <bool> focused: false;
    in property <string> path: "";
    /// Optional backend glyph (`🔐` / `📡` / `🌐` / `☁️`). Empty string
    /// means local pane; the address bar and breadcrumb chip skip the
    /// glyph in that case. Populated from `PaneSlintData.backend-glyph`.
    in property <string> backend-glyph: "";
    /// When true, the breadcrumb strip below the address bar is rendered. When
    /// false, it is hidden entirely (wired from `ui.show_breadcrumbs`).
    in property <bool> show-breadcrumbs: true;
    /// When true, the per-pane status bar is rendered at the bottom of the
    /// pane frame (wired from `ui.show_status_bar`). Layout height is
    /// reclaimed when hidden.
    in property <bool> show-status-bar: true;
    /// When true, a 2-px accent inset border is rendered to indicate this pane
    /// is a valid drop destination for the current drag operation.
    in property <bool> drag-target: false;
    in property <[string]> path-segments: [];
    in property <string> view-mode: "Details";
    in property <[TabEntry]> tabs: [];
    in property <int> active-tab: 0;

    in property <[EntryRowItem]> details-rows: [];
    in property <[ColumnSpec]> details-columns: [];
    in property <[bool]> details-selected-mask: [];
    in property <int> details-selected-anchor: -1;
    in property <int> details-focused-index: -1;

    in property <[image]> grid-thumbnails: [];
    in property <[bool]> grid-has-thumbs: [];
    in property <[bool]> grid-selected-mask: [];
    in property <int> grid-focused-index: -1;

    in property <[image]> gallery-strip-thumbnails: [];
    in property <image> gallery-preview-image;
    in property <bool> gallery-preview-loading: false;
    in property <string> gallery-preview-fallback-glyph: "";
    in property <int> gallery-focused-index: -1;
    in property <MetadataFields> gallery-metadata: {
        name: "",
        path: "",
        size-text: "",
        modified-text: "",
        kind: "",
        dimensions: "",
    };

    in property <[MillerColData]> miller-columns: [];
    in property <int> miller-focused-col: 0;

    // ── Per-pane status bar data ─────────────────────────────────────────
    /// Number of directories in the pane's current listing.
    in property <int> status-folder-count: 0;
    /// Number of non-directory entries in the pane's current listing.
    in property <int> status-file-count: 0;
    /// Cumulative bytes of the visible files, pre-formatted by Rust
    /// (e.g. `"1.7 MiB"`). Empty until the first fs event fires.
    in property <string> status-total-size-text: "";
    /// Free/total space on the pane's volume, pre-formatted by Rust
    /// (e.g. `"590 GB free of 926 GB"`). Empty when unavailable.
    in property <string> status-free-space-text: "";
    /// Connection status for a remote pane. Local panes use `"local"`;
    /// remote panes flip between `"ok"` / `"reconnecting"` / `"failed"`
    /// as the pool + retry layer emits events.
    in property <string> connection-status: "local";
    /// Human-readable tooltip / accessibility label for the chip
    /// (e.g. `"sftp://user@host — retry 2/3, waiting 400ms"`).
    in property <string> connection-tooltip: "";
    /// Ephemeral warning banner shown in the status bar (currently
    /// used for "file too large to preview" toasts). Empty string
    /// hides the chip. Auto-cleared by Rust after a short window.
    in property <string> status-warning-text: "";

    // ── Inline rename cell state (F2 / ctx-Rename) ───────────────────────
    //
    // Owned by `AtlasWindow`; the shell publishes state only for the
    // pane whose id matches `rename-active-pane-id`. For every other
    // pane these fields stay at their defaults and the views render
    // normal filename Text labels.
    /// Entry index in the pane's current listing that hosts the
    /// active `InlineRenameCell`, or -1 when no rename is active in
    /// this pane.
    in property <int> rename-active-index: -1;
    /// Miller-only: which column hosts the rename. -1 for other views.
    in property <int> rename-active-col: -1;
    in property <string> rename-buffer: "";
    in property <int> rename-selection-start: 0;
    in property <int> rename-selection-end: 0;
    in property <int> rename-selection-tick: 0;
    /// Set to true while the cell's TextInput owns focus. Bubbles up
    /// to the root `keymap-bypass-active` disjunction so Cmd+A / Cmd+C
    /// / Cmd+V route to the TextInput while a rename is in flight.
    out property <bool> rename-input-focused: false;
    callback rename-submit();
    callback rename-cancel();
    callback rename-blur-commit();
    callback rename-edited(string);

    callback address-submitted(string);
    callback address-cancelled();
    callback breadcrumb-clicked(int);
    callback tab-selected(int);
    callback tab-closed(int);
    callback new-tab();
    callback pane-clicked();
    /// Emitted from any view when a drag threshold is exceeded.
    /// `entry-index` is the index of the dragged entry in the pane's current
    /// listing.
    callback drag-start(int /*entry-index*/);

    callback details-row-clicked(int, bool, bool);
    callback details-row-double-clicked(int);
    callback details-row-context-menu(int, length, length);
    callback details-header-clicked(int);
    callback details-header-resize(int, float);

    callback grid-entry-clicked(int, bool, bool);
    callback grid-entry-double-clicked(int);
    callback grid-entry-context-menu(int, length, length);
    callback grid-thumbnail-visible(int);
    callback grid-columns-changed(int);

    callback gallery-entry-clicked(int);
    callback gallery-strip-visible(int);
    callback gallery-preview-visible(int);
    callback gallery-prev-image();
    callback gallery-next-image();
    /// Right-click on a gallery strip cell.  Arguments: entry-index,
    /// window-absolute-x, window-absolute-y.  Bubbled up so the shared
    /// capability-aware context menu can act on the target entry.
    callback gallery-entry-context-menu(int, length, length);

    /// Border thickness for the focused-pane ring. `0px` disables it.
    in property <length> focused-border-px: 2px;

    callback miller-row-clicked(int, int);
    callback miller-row-double-clicked(int, int);
    /// Right-click on a miller row.  Arguments: column-index, row-index,
    /// window-absolute-x, window-absolute-y.  Routes through the same
    /// context-menu callback Details / Grid use.
    callback miller-row-context-menu(int, int, length, length);

    /// True while the pane's address bar TextInput owns keyboard focus.
    /// The root FocusScope watches this via a `changed` handler on each
    /// pane iteration and folds it into `keymap-bypass-active` so
    /// Cmd+A / Cmd+C / Cmd+V route to the TextInput's native edit
    /// shortcuts instead of firing pane::SelectAll / fs::Copy / fs::Paste.
    /// Mirrors the modal-focus fix from `a3830bc`, extended to per-pane
    /// text inputs.
    out property <bool> text-input-focused: address-bar.input-focused;

    Rectangle {
        background: Theme.bg;

        // Full-pane click capture (fires on empty background clicks so the
        // pane can request focus). Placed BEHIND the layout so children with
        // their own TouchAreas still receive events.
        TouchArea {
            width: 100%;
            height: 100%;
            clicked => { root.pane-clicked(); }
        }

        VerticalLayout {
                spacing: 0px;

                Rectangle {
                    height: 38px;
                    background: Theme.panel-bg;

                    HorizontalLayout {
                        padding: Theme.space-2;

                        address-bar := AddressBar {
                            path: root.path;
                            backend-glyph: root.backend-glyph;
                            submitted(p) => { root.address-submitted(p); }
                            cancelled => { root.address-cancelled(); }
                        }
                    }
                }

                if root.show-breadcrumbs : Breadcrumbs {
                    segments: root.path-segments;
                    remote-root: root.backend-glyph != "";
                    clicked(i) => { root.breadcrumb-clicked(i); }
                }

                TabBar {
                    tabs: root.tabs;
                    active-index: root.active-tab;
                    // Only show the tab bar when there are 2+ tabs — with
                    // exactly one tab the tab title (folder name) duplicates
                    // the trailing breadcrumb segment.
                    visible: root.tabs.length > 1;
                    height: root.tabs.length > 1 ? 32px : 0px;
                    select(i) => { root.tab-selected(i); }
                    close(i) => { root.tab-closed(i); }
                    new-tab => { root.new-tab(); }
                }

                if root.view-mode == "Details" : DetailsView {
                    vertical-stretch: 1;
                    rows: root.details-rows;
                    columns: root.details-columns;
                    selected-mask: root.details-selected-mask;
                    selected-anchor: root.details-selected-anchor;
                    focused-index: root.details-focused-index;
                    rename-active-index: root.rename-active-index;
                    rename-buffer: root.rename-buffer;
                    rename-selection-start: root.rename-selection-start;
                    rename-selection-end: root.rename-selection-end;
                    rename-selection-tick: root.rename-selection-tick;

                    row-clicked(i, ctrl, shift) => { root.details-row-clicked(i, ctrl, shift); }
                    row-double-clicked(i) => { root.details-row-double-clicked(i); }
                    row-context-menu(i, x, y) => { root.details-row-context-menu(i, x, y); }
                    header-clicked(i) => { root.details-header-clicked(i); }
                    header-resize(i, w) => { root.details-header-resize(i, w); }
                    drag-start(i) => { root.drag-start(i); }
                    rename-submit => { root.rename-submit(); }
                    rename-cancel => { root.rename-cancel(); }
                    rename-blur-commit => { root.rename-blur-commit(); }
                    rename-edited(t) => { root.rename-edited(t); }
                    changed rename-input-focused => {
                        root.rename-input-focused = self.rename-input-focused;
                    }
                }

                if root.view-mode == "Grid" : GridView {
                    vertical-stretch: 1;
                    entries: root.details-rows;
                    thumbnails: root.grid-thumbnails;
                    has-thumbs: root.grid-has-thumbs;
                    selected-mask: root.grid-selected-mask;
                    focused-index: root.grid-focused-index;
                    rename-active-index: root.rename-active-index;
                    rename-buffer: root.rename-buffer;
                    rename-selection-start: root.rename-selection-start;
                    rename-selection-end: root.rename-selection-end;
                    rename-selection-tick: root.rename-selection-tick;

                    entry-clicked(i, ctrl, shift) => { root.grid-entry-clicked(i, ctrl, shift); }
                    entry-double-clicked(i) => { root.grid-entry-double-clicked(i); }
                    entry-context-menu(i, x, y) => { root.grid-entry-context-menu(i, x, y); }
                    thumbnail-visible(i) => { root.grid-thumbnail-visible(i); }
                    columns-changed(c) => { root.grid-columns-changed(c); }
                    drag-start(i) => { root.drag-start(i); }
                    rename-submit => { root.rename-submit(); }
                    rename-cancel => { root.rename-cancel(); }
                    rename-blur-commit => { root.rename-blur-commit(); }
                    rename-edited(t) => { root.rename-edited(t); }
                    changed rename-input-focused => {
                        root.rename-input-focused = self.rename-input-focused;
                    }
                }

                if root.view-mode == "Gallery" : GalleryView {
                    vertical-stretch: 1;
                    entries: root.details-rows;
                    strip-thumbnails: root.gallery-strip-thumbnails;
                    preview-image: root.gallery-preview-image;
                    preview-loading: root.gallery-preview-loading;
                    preview-fallback-glyph: root.gallery-preview-fallback-glyph;
                    focused-index: root.gallery-focused-index;
                    metadata: root.gallery-metadata;
                    rename-active-index: root.rename-active-index;
                    rename-buffer: root.rename-buffer;
                    rename-selection-start: root.rename-selection-start;
                    rename-selection-end: root.rename-selection-end;
                    rename-selection-tick: root.rename-selection-tick;

                    entry-clicked(i) => { root.gallery-entry-clicked(i); }
                    entry-context-menu(i, x, y) => { root.gallery-entry-context-menu(i, x, y); }
                    strip-visible(i) => { root.gallery-strip-visible(i); }
                    preview-visible(i) => { root.gallery-preview-visible(i); }
                    prev-image => { root.gallery-prev-image(); }
                    next-image => { root.gallery-next-image(); }
                    drag-start(i) => { root.drag-start(i); }
                    rename-submit => { root.rename-submit(); }
                    rename-cancel => { root.rename-cancel(); }
                    rename-blur-commit => { root.rename-blur-commit(); }
                    rename-edited(t) => { root.rename-edited(t); }
                    changed rename-input-focused => {
                        root.rename-input-focused = self.rename-input-focused;
                    }
                }

                if root.view-mode == "Miller" : MillerView {
                    vertical-stretch: 1;
                    columns: root.miller-columns;
                    focused-col: root.miller-focused-col;
                    rename-active-col: root.rename-active-col;
                    rename-active-index: root.rename-active-index;
                    rename-buffer: root.rename-buffer;
                    rename-selection-start: root.rename-selection-start;
                    rename-selection-end: root.rename-selection-end;
                    rename-selection-tick: root.rename-selection-tick;

                    row-clicked(col, row) => { root.miller-row-clicked(col, row); }
                    row-double-clicked(col, row) => { root.miller-row-double-clicked(col, row); }
                    row-context-menu(col, row, x, y) => { root.miller-row-context-menu(col, row, x, y); }
                    drag-start(col, row) => { root.drag-start(row); }
                    rename-submit => { root.rename-submit(); }
                    rename-cancel => { root.rename-cancel(); }
                    rename-blur-commit => { root.rename-blur-commit(); }
                    rename-edited(t) => { root.rename-edited(t); }
                    changed rename-input-focused => {
                        root.rename-input-focused = self.rename-input-focused;
                    }
                }

                if root.view-mode != "Details" && root.view-mode != "Grid" && root.view-mode != "Gallery" && root.view-mode != "Miller" : EmptyView {
                    view-mode: root.view-mode;
                    vertical-stretch: 1;
                }

                // Per-pane status bar — pinned to the bottom of the pane
                // frame (inside the border), gated on `ui.show_status_bar`.
                if root.show-status-bar : PaneStatusBar {
                    folder-count: root.status-folder-count;
                    file-count: root.status-file-count;
                    total-size-text: root.status-total-size-text;
                    free-space-text: root.status-free-space-text;
                    connection-status: root.connection-status;
                    connection-tooltip: root.connection-tooltip;
                    warning-text: root.status-warning-text;
                }
        }

        // Focused / drag-target ring, painted ON TOP of the pane content so
        // it is always visible (the pane's Rectangle border would otherwise
        // be occluded by 100%-sized children). Non-interactive.
        Rectangle {
            x: 0px; y: 0px;
            width: parent.width;
            height: parent.height;
            background: transparent;
            border-width: drag-target ? focused-border-px + 1px : (focused ? focused-border-px : 0px);
            border-color: focused
                ? Theme.accent
                : Theme.accent.with-alpha(drag-target ? 0.6 : 0.3);
            border-radius: 0px;
        }
    }
}
