import { Theme } from "../theme.slint";
import { AddressBar } from "address-bar.slint";
import { Breadcrumbs } from "breadcrumbs.slint";
import { TabBar, TabEntry } from "tab-bar.slint";
import { EmptyView } from "../views/empty-view.slint";
import { DetailsView } from "../views/details/details-view.slint";
import { GridView } from "../views/grid/grid-view.slint";
import { GalleryView } from "../views/gallery/gallery-view.slint";
import { MillerView } from "../views/miller/miller-view.slint";
import { MillerColData } from "../views/miller/miller-state.slint";
import { EntryRowItem, ColumnSpec } from "../views/details/column.slint";
import { TreeView, TreeNode } from "../views/tree/tree-view.slint";
import { MetadataFields } from "../views/gallery/gallery-metadata.slint";

// A single pane: address bar + breadcrumbs + tab bar + content view.
//
// When view-mode is "Details" the DetailsView is shown; all other modes
// fall back to EmptyView so that future agents can slot in Grid/Gallery/
// Miller/Tree without touching this file.
export component Pane {
    in property <bool> focused: false;
    in property <string> path: "";
    in property <[string]> path-segments: [];
    in property <string> view-mode: "Details";
    in property <[TabEntry]> tabs: [];
    in property <int> active-tab: 0;

    in property <[EntryRowItem]> details-rows: [];
    in property <[ColumnSpec]> details-columns: [];
    in property <[bool]> details-selected-mask: [];
    in property <int> details-selected-anchor: -1;
    in property <int> details-focused-index: -1;

    // Grid view properties
    in property <[image]> grid-thumbnails: [];
    in property <[bool]> grid-has-thumbs: [];
    in property <[bool]> grid-selected-mask: [];
    in property <int> grid-focused-index: -1;

    // Gallery view properties
    in property <[image]> gallery-strip-thumbnails: [];
    in property <image> gallery-preview-image;
    in property <bool> gallery-preview-loading: false;
    in property <string> gallery-preview-fallback-glyph: "";
    in property <int> gallery-focused-index: -1;
    in property <MetadataFields> gallery-metadata: {
        name: "",
        path: "",
        size-text: "",
        modified-text: "",
        kind: "",
        dimensions: "",
    };

    // Tree view properties
    in property <[TreeNode]> tree-nodes: [];
    in property <int> tree-focused-index: -1;
    in property <int> tree-selected-index: -1;

    // Miller columns view properties
    in property <[MillerColData]> miller-columns: [];
    in property <int> miller-focused-col: 0;

    callback address-submitted(string);
    callback address-cancelled();
    callback breadcrumb-clicked(int);
    callback tab-selected(int);
    callback tab-closed(int);
    callback new-tab();
    callback pane-clicked();

    callback details-row-clicked(int, bool, bool);
    callback details-row-double-clicked(int);
    callback details-row-context-menu(int, length, length);
    callback details-header-clicked(int);
    callback details-header-resize(int, float);

    // Grid view callbacks
    callback grid-entry-clicked(int, bool, bool);
    callback grid-entry-double-clicked(int);
    callback grid-entry-context-menu(int, length, length);
    callback grid-thumbnail-visible(int);
    callback grid-columns-changed(int);

    callback gallery-entry-clicked(int);
    callback gallery-strip-visible(int);
    callback gallery-preview-visible(int);
    callback gallery-prev-image();
    callback gallery-next-image();

    // Tree view callbacks
    callback tree-row-clicked(int, bool, bool);
    callback tree-row-double-clicked(int);
    callback tree-chevron-clicked(int);
    callback miller-row-clicked(int, int);
    callback miller-row-double-clicked(int, int);

    TouchArea {
        clicked => { root.pane-clicked(); }

        Rectangle {
            background: Theme.bg;
            border-width: focused ? 1px : 0px;
            border-color: Theme.accent;

            VerticalLayout {
                spacing: 0px;

                Rectangle {
                    height: 38px;
                    background: Theme.panel-bg;
                    border-width: 1px;
                    border-color: Theme.border;

                    HorizontalLayout {
                        padding: Theme.spacing-sm;

                        AddressBar {
                            path: root.path;
                            submitted(p) => { root.address-submitted(p); }
                            cancelled => { root.address-cancelled(); }
                        }
                    }
                }

                Breadcrumbs {
                    segments: root.path-segments;
                    clicked(i) => { root.breadcrumb-clicked(i); }
                }

                TabBar {
                    tabs: root.tabs;
                    active-index: root.active-tab;
                    select(i) => { root.tab-selected(i); }
                    close(i) => { root.tab-closed(i); }
                    new-tab => { root.new-tab(); }
                }

                if root.view-mode == "Details" : DetailsView {
                    vertical-stretch: 1;
                    rows: root.details-rows;
                    columns: root.details-columns;
                    selected-mask: root.details-selected-mask;
                    selected-anchor: root.details-selected-anchor;
                    focused-index: root.details-focused-index;

                    row-clicked(i, ctrl, shift) => { root.details-row-clicked(i, ctrl, shift); }
                    row-double-clicked(i) => { root.details-row-double-clicked(i); }
                    row-context-menu(i, x, y) => { root.details-row-context-menu(i, x, y); }
                    header-clicked(i) => { root.details-header-clicked(i); }
                    header-resize(i, w) => { root.details-header-resize(i, w); }
                }

                if root.view-mode == "Grid" : GridView {
                    vertical-stretch: 1;
                    entries: root.details-rows;
                    thumbnails: root.grid-thumbnails;
                    has-thumbs: root.grid-has-thumbs;
                    selected-mask: root.grid-selected-mask;
                    focused-index: root.grid-focused-index;

                    entry-clicked(i, ctrl, shift) => { root.grid-entry-clicked(i, ctrl, shift); }
                    entry-double-clicked(i) => { root.grid-entry-double-clicked(i); }
                    entry-context-menu(i, x, y) => { root.grid-entry-context-menu(i, x, y); }
                    thumbnail-visible(i) => { root.grid-thumbnail-visible(i); }
                    columns-changed(c) => { root.grid-columns-changed(c); }
                }

                if root.view-mode == "Gallery" : GalleryView {
                    vertical-stretch: 1;
                    entries: root.details-rows;
                    strip-thumbnails: root.gallery-strip-thumbnails;
                    preview-image: root.gallery-preview-image;
                    preview-loading: root.gallery-preview-loading;
                    preview-fallback-glyph: root.gallery-preview-fallback-glyph;
                    focused-index: root.gallery-focused-index;
                    metadata: root.gallery-metadata;

                    entry-clicked(i) => { root.gallery-entry-clicked(i); }
                    strip-visible(i) => { root.gallery-strip-visible(i); }
                    preview-visible(i) => { root.gallery-preview-visible(i); }
                    prev-image => { root.gallery-prev-image(); }
                    next-image => { root.gallery-next-image(); }
                }

                if root.view-mode == "Miller" : MillerView {
                    vertical-stretch: 1;
                    columns: root.miller-columns;
                    focused-col: root.miller-focused-col;
                    row-clicked(col, row) => { root.miller-row-clicked(col, row); }
                    row-double-clicked(col, row) => { root.miller-row-double-clicked(col, row); }
                }

                if root.view-mode == "Tree" : TreeView {
                    vertical-stretch: 1;
                    nodes: root.tree-nodes;
                    focused-index: root.tree-focused-index;
                    selected-index: root.tree-selected-index;

                    row-clicked(i, ctrl, shift) => { root.tree-row-clicked(i, ctrl, shift); }
                    row-double-clicked(i) => { root.tree-row-double-clicked(i); }
                    chevron-clicked(i) => { root.tree-chevron-clicked(i); }
                }

                if root.view-mode != "Details" && root.view-mode != "Grid" && root.view-mode != "Gallery" && root.view-mode != "Miller" && root.view-mode != "Tree" : EmptyView {
                    view-mode: root.view-mode;
                    vertical-stretch: 1;
                }
            }
        }
    }
}
