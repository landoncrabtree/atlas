import { Theme } from "../theme.slint";

export struct PaletteEntry {
    title: string,
    subtitle: string,
    action-id: string,
}

export component CommandPalette {
    in-out property <string> query: "";
    in property <[PaletteEntry]> results: [];
    in property <int> selected-index: 0;

    callback query-changed(string);
    callback confirm(string);
    callback dismiss();
    callback select-delta(int);

    if self.visible : Rectangle {
        width: 100%;
        height: 100%;
        background: #00000066;

        TouchArea {
            width: 100%;
            height: 100%;
            clicked => { root.dismiss(); }
        }

        Rectangle {
            x: (parent.width - self.width) / 2;
            y: parent.height * 0.20;
            width: min(560px, parent.width - 48px);
            height: min(440px, parent.height - 80px);
            background: Theme.panel-bg-elevated;
            border-radius: Theme.radius-lg;

            TouchArea { width: 100%; height: 100%; }

            VerticalLayout {
                spacing: 0px;

                // Prompt input row
                Rectangle {
                    height: 44px;
                    background: transparent;

                    HorizontalLayout {
                        padding-left: Theme.space-4;
                        padding-right: Theme.space-4;

                        TextInput {
                            init => { self.focus(); }
                            text <=> root.query;
                            color: Theme.fg;
                            font-size: 15px;
                            font-weight: 600;
                            vertical-alignment: center;
                            single-line: true;
                            horizontal-stretch: 1;
                            edited => { root.query-changed(self.text); }
                            accepted => {
                                if results.length > 0 {
                                    root.confirm(results[selected-index].action-id);
                                }
                            }
                            key-pressed(event) => {
                                if event.text == Key.Escape {
                                    root.dismiss();
                                    return accept;
                                }
                                if event.text == Key.DownArrow {
                                    root.select-delta(1);
                                    return accept;
                                }
                                if event.text == Key.UpArrow {
                                    root.select-delta(-1);
                                    return accept;
                                }
                                reject;
                            }
                        }
                    }
                }

                // Divider
                Rectangle { height: 1px; background: Theme.border; }

                // Results list
                Rectangle {
                    vertical-stretch: 1;
                    clip: true;

                    for entry[i] in results : Rectangle {
                        y: i * 40px;
                        height: 40px;
                        width: parent.width;
                        background: i == selected-index ? Theme.accent-soft : transparent;
                        animate background { duration: Theme.motion-fast; easing: linear; }

                        // Selected accent left rail
                        if i == selected-index : Rectangle {
                            x: 0px; y: 0px;
                            width: 2px;
                            height: 40px;
                            background: Theme.accent;
                        }

                        TouchArea {
                            width: 100%;
                            height: 100%;
                            clicked => { root.confirm(entry.action-id); }
                        }

                        VerticalLayout {
                            x: Theme.space-4;
                            y: 0px;
                            width: parent.width - Theme.space-4 * 2;
                            height: parent.height;
                            alignment: center;
                            spacing: 2px;

                            Text {
                                text: entry.title;
                                color: Theme.fg;
                                font-size: 13px;
                            }

                            if entry.subtitle != "" : Text {
                                text: entry.subtitle;
                                color: Theme.fg-muted;
                                font-size: 11px;
                            }
                        }
                    }

                    if results.length == 0 : Text {
                        text: query == "" ? "Type to search…" : "No results";
                        color: Theme.fg-faint;
                        font-size: 13px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: 60px;
                    }
                }
            }
        }
    }
}
