import { Theme } from "../theme.slint";
import {
    AtlasModal, AtlasSecondaryButton,
} from "atlas-controls.slint";

// Finder-parity conflict prompt shown when Copy/Move hits a colliding
// destination under `ConflictPolicy::Prompt`.
//
// Layout modeled on macOS Sequoia Finder's replace-item sheet
// (~460×180 px): document icon on the left with a warning-triangle
// badge; single-paragraph body on the right; a right-aligned row of
// three neutral buttons at the bottom. The "Apply to all" checkbox
// sits on the same button row at the left, visually recessive.
//
// Design refs (design.instructions.md):
// - "Restrained accent" — accent is reserved for a single truly-primary
//   action. Confirmation modals like this one keep every button
//   neutral, matching Apple's confirm sheets. See §Confirmation
//   modals.
// - "Modal depth" — reuses `AtlasModal` (`modal-radius` = `radius-xl`,
//   modal-scrim, soft drop-shadow). No nested boxes.
// - "Sentence-case labels" — single sentence body, no forced break
//   between statement and question.
//
// Chord routing (ui-composition.instructions.md §5):
// - The modal owns no TextInput, so it doesn't need the
//   `input-focused` bubble. Escape and Enter are handled by the root
//   FocusScope: Escape maps to Stop; Enter activates Stop as the safe
//   default focus target.
export component AtlasConflictModal inherits Rectangle {
    // ── inputs ────────────────────────────────────────────────────────────
    in property <bool> visible-modal: false;
    /// File name in question (`README.md`).
    in property <string> item-name: "";
    /// Full source path/URI. Currently unused by the compact layout but
    /// preserved on the interface for callers/tests that may want to
    /// surface it in a future disclosure hint (Finder shows the source
    /// path in a hover popover, not inline).
    in property <string> source-display: "";
    /// Full destination path/URI. Same shape as `source-display` — see
    /// note above.
    in property <string> dest-display: "";
    /// True when the source file mtime is newer than the dest mtime.
    in property <bool> source-is-newer: false;
    /// True when the source file mtime is older than the dest mtime.
    /// Only one of `source-is-newer` / `source-is-older` can be true;
    /// both false → neutral Finder phrasing.
    in property <bool> source-is-older: false;
    /// User-facing "apply to all" preference. The modal owns display;
    /// Rust owns the persistent flag.
    in-out property <bool> apply-to-all: false;
    // Kept as a property (not inlined into an `if`) so future gating —
    // "only show when a batch has more items pending" — has a single
    // hook.
    property <bool> apply-to-all-visible: true;

    // ── outputs ───────────────────────────────────────────────────────────
    callback keep-both();
    callback stop();
    callback replace();
    callback toggle-apply-to-all();

    width: 100%;
    height: 100%;

    // Finder text mapping (rendered as one wrapped sentence so the sheet
    // reads like a native macOS confirmation, not two stacked
    // paragraphs):
    //   source newer than dest → "An item named 'X' already exists in
    //                              this location. Do you want to replace
    //                              it with the newer one you're copying?"
    //   source older than dest → "A newer item named 'X' already exists
    //                              in this location. Do you want to
    //                              replace it with the older one you're
    //                              copying?"
    //   neither known          → "An item named 'X' already exists in
    //                              this location. Do you want to replace
    //                              it?"
    property <string> message-text:
        root.source-is-older
            ? "A newer item named \"" + root.item-name + "\" already exists in this location. Do you want to replace it with the older one you're copying?"
            : root.source-is-newer
                ? "An item named \"" + root.item-name + "\" already exists in this location. Do you want to replace it with the newer one you're copying?"
                : "An item named \"" + root.item-name + "\" already exists in this location. Do you want to replace it?";

    AtlasModal {
        width: 100%;
        height: 100%;
        visible-modal: root.visible-modal;
        title: "";
        // Compact Finder-parity dimensions: 460 px wide (packs the
        // single-paragraph body next to the icon without wrapping to
        // more than three lines for typical file names) × 172 px tall
        // (icon row + button row + generous padding). Matches
        // design.instructions.md §Confirmation modals.
        modal-width: 460px;
        modal-height: 172px;
        dismissed => { root.stop(); }

        // ── icon + body row ────────────────────────────────────────────
        //
        // Horizontal arrangement matching Finder's Sequoia layout: the
        // document glyph anchors the message on the left; the wrapped
        // sentence flows to its right and takes the remaining width.
        HorizontalLayout {
            spacing: Theme.space-3;
            alignment: start;

            // Icon column — 48-px document glyph with a small warning
            // badge overlaid at the bottom-right. The badge is drawn as
            // a rectangle in the parent (not a child of the icon Text)
            // so its z-order lands above the glyph.
            Rectangle {
                width: 48px;
                height: 48px;
                y: 0px;

                Text {
                    text: "\u{f016}";
                    font-family: Theme.icon-font-family;
                    color: Theme.fg-muted;
                    font-size: 44px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    width: 100%;
                    height: 100%;
                }

                // Warning-triangle badge (Nerd Font `nf-fa-warning`).
                // Sized ~18 px and offset into the bottom-right corner
                // of the icon square to mimic Finder's yellow download
                // badge.
                Rectangle {
                    x: parent.width - self.width + 4px;
                    y: parent.height - self.height + 4px;
                    width: 20px;
                    height: 20px;
                    border-radius: 10px;
                    background: Theme.modal-bg;

                    Text {
                        text: "\u{f071}";
                        font-family: Theme.icon-font-family;
                        color: Theme.warning;
                        font-size: 16px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: 100%;
                        height: 100%;
                    }
                }
            }

            // Message column — single wrapped sentence in `body` (13px).
            // Vertically centered against the icon square so short
            // messages sit at the icon's baseline; longer messages
            // grow downward.
            Text {
                text: root.message-text;
                color: Theme.fg;
                font-size: Theme.font-size;
                wrap: word-wrap;
                vertical-alignment: top;
                horizontal-stretch: 1;
            }
        }

        // ── button row ─────────────────────────────────────────────────
        //
        // Order (left → right): "Apply to all" checkbox at the far
        // left (progressive-disclosure hint), then Keep Both · Stop ·
        // Replace anchored to the right.
        //
        // Every button uses `AtlasSecondaryButton` (neutral fill,
        // 29 px). Apple's replace-item sheet never uses the accent
        // color on confirmation dialogs — none of these three actions
        // is unambiguously "the right one" (Stop is the safe default,
        // but Replace is legitimate; Keep Both is legitimate too), so
        // per design.instructions.md §Restrained accent we keep them
        // all neutral.
        HorizontalLayout {
            spacing: Theme.space-2;
            alignment: end;
            padding-top: Theme.space-1;

            // "Apply to all remaining conflicts" — recessive
            // caption-weight label; positioned at the far left of the
            // button row so it doesn't compete with the actions.
            if root.apply-to-all-visible : HorizontalLayout {
                spacing: Theme.space-1 + 2px;
                alignment: start;
                horizontal-stretch: 1;

                Rectangle {
                    width: 13px;
                    height: 13px;
                    y: (parent.height - self.height) / 2;
                    border-width: 1px;
                    border-color: Theme.field-border;
                    border-radius: 3px;
                    background: root.apply-to-all
                        ? Theme.segmented-selected-bg
                        : Theme.field-bg;

                    if root.apply-to-all : Text {
                        text: "✓";
                        color: Theme.fg;
                        font-size: 10px;
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: 100%;
                        height: 100%;
                    }

                    TouchArea {
                        width: 100%;
                        height: 100%;
                        clicked => { root.toggle-apply-to-all(); }
                    }
                }

                Text {
                    text: "Apply to all";
                    color: Theme.fg-muted;
                    font-size: 11px;
                    vertical-alignment: center;
                    TouchArea {
                        clicked => { root.toggle-apply-to-all(); }
                    }
                }
            }

            AtlasSecondaryButton {
                button-width: 84px;
                text: "Keep Both";
                clicked => { root.keep-both(); }
            }
            AtlasSecondaryButton {
                button-width: 64px;
                text: "Stop";
                clicked => { root.stop(); }
            }
            AtlasSecondaryButton {
                button-width: 76px;
                text: "Replace";
                clicked => { root.replace(); }
            }
        }
    }
}
