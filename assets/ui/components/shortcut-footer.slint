import { Theme } from "../theme.slint";

/// One shortcut chip: the pretty chord (e.g. `⌘⇧P` on macOS, `Ctrl+Shift+P`
/// on Linux/Windows) followed by a muted-label action name.
export struct ShortcutHint {
    /// Pre-formatted chord glyph string. Rust picks the platform-native
    /// symbols so we don't do any ⌘/Ctrl swapping in Slint.
    key: string,
    /// Human-readable action name (e.g. "Rename", "Palette").
    label: string,
}

// One key-hint chip: `key` in accent, `label` in muted foreground.
component KeyHint {
    in property <string> key;
    in property <string> label;

    HorizontalLayout {
        spacing: 4px;
        Text {
            text: key;
            color: Theme.accent;
            font-size: 11px;
            font-weight: 600;
            vertical-alignment: center;
        }
        Text {
            text: label;
            color: Theme.fg-muted;
            font-size: 11px;
            vertical-alignment: center;
        }
    }
}

// Marta/NC-style bottom footer that reminds the user which chord does what.
// Content is data-driven: Rust reads the live keymap, picks a curated set of
// actions to advertise, formats each chord with platform-native modifier
// symbols, and pushes the result via `hints`. This means user rebindings
// automatically show up in the footer.
export component ShortcutFooter {
    in property <[ShortcutHint]> hints: [];

    height: 26px;

    Rectangle {
        background: Theme.panel-bg;

        // Top border
        Rectangle {
            x: 0px; y: 0px;
            height: 1px;
            width: parent.width;
            background: Theme.border;
        }

        HorizontalLayout {
            padding-left: Theme.space-3;
            padding-right: Theme.space-3;
            spacing: Theme.space-4;
            alignment: center;

            for hint in hints : KeyHint {
                key: hint.key;
                label: hint.label;
            }
        }
    }
}
