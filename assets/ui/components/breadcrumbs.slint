import { Theme } from "../theme.slint";

// Path breadcrumb strip.
//
// For remote panes the first segment is a `sftp://user@host` (or
// equivalent) authority — sourced from `Location::breadcrumb_segments`.
// When `remote-root` is set the first chip is emphasised (accent
// colour + slightly larger font) so the reader visually anchors on
// which host they're currently browsing.
export component Breadcrumbs {
    in property <[string]> segments: [];
    /// True for panes rooted at a non-local backend (SFTP, S3, WebDAV,
    /// FTP). Controls the emphasis rendered on `segments[0]`.
    in property <bool> remote-root: false;
    callback clicked(int);

    height: 26px;

    Rectangle {
        background: Theme.panel-bg;

        HorizontalLayout {
            alignment: start;
            padding-left: Theme.space-3;
            spacing: 0px;

            for seg[i] in segments: HorizontalLayout {
                spacing: 0px;
                alignment: center;

                seg-ta := TouchArea {
                    width: seg-text.width + Theme.space-2 * 2;
                    height: parent.height;
                    clicked => { root.clicked(i); }

                    Rectangle {
                        background: seg-ta.has-hover ? Theme.hover-bg : transparent;
                        border-radius: Theme.radius-xs;
                        x: 0px; y: 0px;
                        width: parent.width;
                        height: parent.height;
                        animate background { duration: Theme.motion-quick; easing: ease-out; }
                    }

                    seg-text := Text {
                        x: Theme.space-2;
                        text: seg;
                        color: (root.remote-root && i == 0)
                            ? Theme.accent
                            : (i == segments.length - 1 ? Theme.fg : Theme.fg-muted);
                        font-size: (root.remote-root && i == 0) ? 13px : 12px;
                        font-weight: (root.remote-root && i == 0) ? 600 : 400;
                        vertical-alignment: center;
                        animate color { duration: Theme.motion-quick; easing: ease-out; }
                    }
                }

                // Separator › (not after the last segment)
                if i < segments.length - 1 : Text {
                    text: "›";
                    color: Theme.fg-faint;
                    font-size: 11px;
                    vertical-alignment: center;
                    width: 12px;
                    horizontal-alignment: center;
                }
            }
        }
    }
}
