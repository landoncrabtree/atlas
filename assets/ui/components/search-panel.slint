import { Theme } from "../theme.slint";
import { ListView } from "std-widgets.slint";

export struct SearchRow {
    path: string,
    label: string,
    snippet: string,
    kind: string,
}

export component SearchPanel inherits Rectangle {
    in property <bool> visible-panel;
    in property <string> query;
    in property <[SearchRow]> rows;
    in property <int> selected-index;
    in property <string> status-text;
    callback query-changed(string);
    callback confirm(int);
    callback close();

    if visible-panel : Rectangle {
        width: 100%;
        height: 100%;
        background: Theme.panel-bg;

        Rectangle {
            x: 0px;
            y: 0px;
            width: 1px;
            height: parent.height;
            background: Theme.border;
        }

        VerticalLayout {
            padding: Theme.space-4;
            spacing: Theme.space-3;

            HorizontalLayout {
                height: 32px;

                Text {
                    text: "Search";
                    color: Theme.fg;
                    font-size: 15px;
                    font-weight: 600;
                    vertical-alignment: center;
                }

                Rectangle { horizontal-stretch: 1; }

                close-ta := TouchArea {
                    width: 24px;
                    height: 24px;
                    clicked => { root.close(); }

                    Rectangle {
                        border-radius: Theme.radius-sm;
                        background: close-ta.has-hover ? Theme.hover-bg : transparent;
                        animate background { duration: Theme.motion-fast; easing: ease-out; }

                        Text {
                            text: "×";
                            color: Theme.fg-muted;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                    }
                }
            }

            Rectangle {
                height: 36px;
                border-width: 1px;
                border-color: Theme.accent;
                border-radius: Theme.radius-sm;
                background: Theme.panel-bg-elevated;

                TouchArea {
                    width: 100%;
                    height: 100%;
                    clicked => { search-input.focus(); }
                }

                HorizontalLayout {
                    padding-left: Theme.space-3;
                    padding-right: Theme.space-3;

                    search-input := TextInput {
                        // Auto-focus the input every time the panel becomes
                        // visible so users can start typing immediately.
                        // `if visible-panel` recreates this subtree on each
                        // open, so `init` fires per-open (not once per app
                        // lifetime).
                        init => { self.focus(); }
                        text: root.query;
                        color: Theme.fg;
                        font-size: 15px;
                        font-weight: 600;
                        vertical-alignment: center;
                        single-line: true;
                        edited => { root.query-changed(self.text); }
                        accepted => {
                            if rows.length > 0 {
                                root.confirm(selected-index);
                            }
                        }
                        key-pressed(event) => {
                            if event.text == Key.Escape {
                                root.close();
                                return accept;
                            }
                            reject;
                        }
                    }
                }
            }

            Rectangle { height: 1px; background: Theme.border; }

            Rectangle {
                vertical-stretch: 1;
                clip: true;

                if rows.length == 0 : Text {
                    // The status text ("Type ≥ 2 characters", "No results",
                    // "Searching…") is the source of truth for the empty
                    // state, so mirror it rather than showing a competing
                    // "Type to search…" placeholder.
                    text: status-text != "" ? status-text : "Type to search…";
                    color: Theme.fg-faint;
                    font-size: 13px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    height: 60px;
                }

                // Virtualised result list: ListView only mounts the visible
                // window of rows, so the panel stays responsive even when
                // the Rust controller has capped the list at 100.
                if rows.length > 0 : ListView {
                    width: parent.width;
                    height: parent.height;

                    for row[i] in rows : row-bg := Rectangle {
                        height: 30px;
                        background: i == selected-index
                            ? Theme.selection-bg
                            : (row-ta.has-hover ? Theme.hover-bg : transparent);
                        border-radius: Theme.radius-sm;

                        row-ta := TouchArea {
                            width: 100%;
                            height: 100%;
                            clicked => { root.confirm(i); }
                            double-clicked => { root.confirm(i); }
                        }

                        HorizontalLayout {
                            padding-left: Theme.space-2;
                            padding-right: Theme.space-2;
                            spacing: Theme.space-2;
                            alignment: center;

                            Text {
                                text: row.label;
                                color: i == selected-index ? Theme.selection-fg : Theme.fg;
                                font-size: 13px;
                                overflow: elide;
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                            }

                            Text {
                                text: row.snippet;
                                color: i == selected-index ? Theme.selection-fg : Theme.fg-muted;
                                font-size: 11px;
                                font-family: Theme.monospace;
                                overflow: elide;
                                horizontal-stretch: 1;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }

            Rectangle { height: 1px; background: Theme.border; }

            Text {
                text: status-text;
                color: Theme.fg-muted;
                font-size: 11px;
                height: 18px;
                vertical-alignment: center;
            }
        }
    }
}
