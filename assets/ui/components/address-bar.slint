import { Theme } from "../theme.slint";

// Editable path input. Shows a small ↵ icon on the right.
// Emits `submitted(path)` on Enter, `cancelled` on Escape.
export component AddressBar {
    in-out property <string> path: "";
    callback submitted(string);
    callback cancelled();

    height: Theme.addressbar-h;

    input-area := Rectangle {
        background: Theme.panel-bg-elevated;
        border-color: has-focus ? Theme.accent : Theme.border;
        border-width: 1px;
        border-radius: Theme.radius-sm;

        property <bool> has-focus: input.has-focus;

        animate border-color { duration: 120ms; easing: ease-out; }

        HorizontalLayout {
            padding-left: Theme.space-3;
            padding-right: Theme.space-3;
            spacing: Theme.space-2;

            input := TextInput {
                text <=> root.path;
                color: Theme.fg;
                font-size: Theme.font-size;
                vertical-alignment: center;
                single-line: true;
                horizontal-stretch: 1;

                accepted => { root.submitted(self.text); }
                key-pressed(event) => {
                    if event.text == Key.Escape {
                        root.cancelled();
                        return accept;
                    }
                    reject;
                }
            }

            jump-ta := TouchArea {
                width: 18px;
                Text {
                    text: "↵";
                    color: jump-ta.has-hover ? Theme.fg : Theme.fg-muted;
                    font-size: 13px;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                    width: parent.width;
                    height: parent.height;
                    animate color { duration: 120ms; easing: ease-out; }
                }
            }
        }
    }
}
