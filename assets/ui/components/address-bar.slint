import { Theme } from "../theme.slint";

// Editable path input. Shows a small ‚ÜĶ icon on the right.
// Emits `submitted(path)` on Enter, `cancelled` on Escape.
//
// Exposes `input-focused` so the root FocusScope can widen its
// `modal-active` gate to cover the address bar's TextInput ‚ÄĒ mirrors
// the `a3830bc` chord-routing pattern used for the palette / goto /
// search / bulk-rename modals so Cmd+A / Cmd+C / Cmd+V select and
// copy the query text instead of firing pane::SelectAll / fs::Copy /
// fs::Paste against the pane's list of entries.
export component AddressBar {
    in-out property <string> path: "";
    /// Optional backend glyph rendered before the path text.  Empty for
    /// local panes; `ūüĒź` / `ūüď°` / `ūüĆź` / `‚ėĀÔłŹ` for the remote backends.
    /// Sourced from `atlas_core::BackendKind::glyph()` via
    /// `PaneSlintData.backend-glyph`.
    in property <string> backend-glyph: "";
    /// True while the inner TextInput owns keyboard focus. Bubbled up by
    /// [`Pane`] as `text-input-focused` so the root can bypass Pane-context
    /// keymap chords in favour of the TextInput's native edit shortcuts.
    out property <bool> input-focused: input.has-focus;
    callback submitted(string);
    callback cancelled();

    height: Theme.addressbar-h;

    input-area := Rectangle {
        background: Theme.panel-bg-elevated;
        border-color: has-focus ? Theme.accent : Theme.border;
        border-width: 1px;
        border-radius: Theme.radius-sm;

        property <bool> has-focus: input.has-focus;

        animate border-color { duration: Theme.motion-quick; easing: ease-out; }

        // Whole cell delegates clicks to the TextInput so the padding
        // + glyph-icon column focus the input rather than swallowing
        // the click.
        TouchArea {
            width: 100%;
            height: 100%;
            clicked => { input.focus(); }
        }

        HorizontalLayout {
            padding-left: Theme.space-3;
            padding-right: Theme.space-3;
            spacing: Theme.space-2;

            if root.backend-glyph != "" : Text {
                text: root.backend-glyph;
                color: Theme.fg;
                font-size: 14px;
                vertical-alignment: center;
                horizontal-alignment: center;
                width: 20px;
            }

            input := TextInput {
                text <=> root.path;
                color: Theme.fg;
                font-size: Theme.font-size;
                vertical-alignment: center;
                single-line: true;
                horizontal-stretch: 1;

                accepted => { root.submitted(self.text); }
                key-pressed(event) => {
                    if event.text == Key.Escape {
                        root.cancelled();
                        return accept;
                    }
                    reject;
                }
            }

            jump-ta := TouchArea {
                width: 18px;
                Text {
                    text: "‚Üí";  // U+2192 covered by Inter + all system fonts
                    color: jump-ta.has-hover ? Theme.fg : Theme.fg-muted;
                    font-size: 13px;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                    width: parent.width;
                    height: parent.height;
                    animate color { duration: Theme.motion-quick; easing: ease-out; }
                }
            }
        }
    }
}
