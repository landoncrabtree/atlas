import { Theme } from "../theme.slint";
import { Pane } from "pane.slint";
import { TabEntry } from "tab-bar.slint";
import { EntryRowItem, ColumnSpec } from "../views/details/column.slint";
import { TreeNode } from "../views/tree/tree-view.slint";
import { MillerColData } from "../views/miller/miller-state.slint";

// Container for one or two Pane children with an optional vertical splitter.
export component Workspace {
    in property <bool> dual-pane: false;
    in property <int> focus-index: 0;

    in property <string> pane0-path: "";
    in property <[string]> pane0-segments: [];
    in property <string> pane0-view-mode: "Details";
    in property <[TabEntry]> pane0-tabs: [];
    in property <int> pane0-active-tab: 0;
    in property <[EntryRowItem]> pane0-details-rows: [];
    in property <[ColumnSpec]> pane0-details-columns: [];
    in property <[bool]> pane0-details-selected-mask: [];
    in property <int> pane0-details-selected-anchor: -1;
    in property <int> pane0-details-focused-index: -1;
    in property <[image]> pane0-grid-thumbnails: [];
    in property <[bool]> pane0-grid-has-thumbs: [];
    in property <[bool]> pane0-grid-selected-mask: [];
    in property <int> pane0-grid-focused-index: -1;
    in property <[TreeNode]> pane0-tree-nodes: [];
    in property <int> pane0-tree-focused-index: -1;
    in property <int> pane0-tree-selected-index: -1;
    in property <[MillerColData]> pane0-miller-columns: [];
    in property <int> pane0-miller-focused-col: 0;

    in property <string> pane1-path: "";
    in property <[string]> pane1-segments: [];
    in property <string> pane1-view-mode: "Details";
    in property <[TabEntry]> pane1-tabs: [];
    in property <int> pane1-active-tab: 0;
    in property <[EntryRowItem]> pane1-details-rows: [];
    in property <[ColumnSpec]> pane1-details-columns: [];
    in property <[bool]> pane1-details-selected-mask: [];
    in property <int> pane1-details-selected-anchor: -1;
    in property <int> pane1-details-focused-index: -1;
    in property <[image]> pane1-grid-thumbnails: [];
    in property <[bool]> pane1-grid-has-thumbs: [];
    in property <[bool]> pane1-grid-selected-mask: [];
    in property <int> pane1-grid-focused-index: -1;
    in property <[TreeNode]> pane1-tree-nodes: [];
    in property <int> pane1-tree-focused-index: -1;
    in property <int> pane1-tree-selected-index: -1;

    callback pane0-address-submitted(string);
    callback pane0-address-cancelled();
    callback pane0-breadcrumb-clicked(int);
    callback pane0-tab-selected(int);
    callback pane0-tab-closed(int);
    callback pane0-new-tab();
    callback pane0-clicked();
    callback pane0-details-row-clicked(int, bool, bool);
    callback pane0-details-row-double-clicked(int);
    callback pane0-details-row-context-menu(int, length, length);
    callback pane0-details-header-clicked(int);
    callback pane0-details-header-resize(int, float);
    callback pane0-grid-entry-clicked(int, bool, bool);
    callback pane0-grid-entry-double-clicked(int);
    callback pane0-grid-entry-context-menu(int, length, length);
    callback pane0-grid-thumbnail-visible(int);
    callback pane0-grid-columns-changed(int);
    callback pane0-tree-row-clicked(int, bool, bool);
    callback pane0-tree-row-double-clicked(int);
    callback pane0-tree-chevron-clicked(int);
    callback pane0-miller-row-clicked(int, int);
    callback pane0-miller-row-double-clicked(int, int);

    callback pane1-address-submitted(string);
    callback pane1-address-cancelled();
    callback pane1-breadcrumb-clicked(int);
    callback pane1-tab-selected(int);
    callback pane1-tab-closed(int);
    callback pane1-new-tab();
    callback pane1-clicked();
    callback pane1-details-row-clicked(int, bool, bool);
    callback pane1-details-row-double-clicked(int);
    callback pane1-details-row-context-menu(int, length, length);
    callback pane1-details-header-clicked(int);
    callback pane1-details-header-resize(int, float);
    callback pane1-grid-entry-clicked(int, bool, bool);
    callback pane1-grid-entry-double-clicked(int);
    callback pane1-grid-entry-context-menu(int, length, length);
    callback pane1-grid-thumbnail-visible(int);
    callback pane1-grid-columns-changed(int);
    callback pane1-tree-row-clicked(int, bool, bool);
    callback pane1-tree-row-double-clicked(int);
    callback pane1-tree-chevron-clicked(int);

    HorizontalLayout {
        spacing: 0px;

        Pane {
            horizontal-stretch: 1;
            focused: focus-index == 0;
            path: root.pane0-path;
            path-segments: root.pane0-segments;
            view-mode: root.pane0-view-mode;
            tabs: root.pane0-tabs;
            active-tab: root.pane0-active-tab;
            details-rows: root.pane0-details-rows;
            details-columns: root.pane0-details-columns;
            details-selected-mask: root.pane0-details-selected-mask;
            details-selected-anchor: root.pane0-details-selected-anchor;
            details-focused-index: root.pane0-details-focused-index;
            grid-thumbnails: root.pane0-grid-thumbnails;
            grid-has-thumbs: root.pane0-grid-has-thumbs;
            grid-selected-mask: root.pane0-grid-selected-mask;
            grid-focused-index: root.pane0-grid-focused-index;
            tree-nodes: root.pane0-tree-nodes;
            tree-focused-index: root.pane0-tree-focused-index;
            tree-selected-index: root.pane0-tree-selected-index;
            miller-columns: root.pane0-miller-columns;
            miller-focused-col: root.pane0-miller-focused-col;

            address-submitted(p) => { root.pane0-address-submitted(p); }
            address-cancelled => { root.pane0-address-cancelled(); }
            breadcrumb-clicked(i) => { root.pane0-breadcrumb-clicked(i); }
            tab-selected(i) => { root.pane0-tab-selected(i); }
            tab-closed(i) => { root.pane0-tab-closed(i); }
            new-tab => { root.pane0-new-tab(); }
            pane-clicked => { root.pane0-clicked(); }
            details-row-clicked(i, ctrl, shift) => { root.pane0-details-row-clicked(i, ctrl, shift); }
            details-row-double-clicked(i) => { root.pane0-details-row-double-clicked(i); }
            details-row-context-menu(i, x, y) => { root.pane0-details-row-context-menu(i, x, y); }
            details-header-clicked(i) => { root.pane0-details-header-clicked(i); }
            details-header-resize(i, w) => { root.pane0-details-header-resize(i, w); }
            grid-entry-clicked(i, ctrl, shift) => { root.pane0-grid-entry-clicked(i, ctrl, shift); }
            grid-entry-double-clicked(i) => { root.pane0-grid-entry-double-clicked(i); }
            grid-entry-context-menu(i, x, y) => { root.pane0-grid-entry-context-menu(i, x, y); }
            grid-thumbnail-visible(i) => { root.pane0-grid-thumbnail-visible(i); }
            grid-columns-changed(c) => { root.pane0-grid-columns-changed(c); }
            tree-row-clicked(i, ctrl, shift) => { root.pane0-tree-row-clicked(i, ctrl, shift); }
            tree-row-double-clicked(i) => { root.pane0-tree-row-double-clicked(i); }
            tree-chevron-clicked(i) => { root.pane0-tree-chevron-clicked(i); }
            miller-row-clicked(col, row) => { root.pane0-miller-row-clicked(col, row); }
            miller-row-double-clicked(col, row) => { root.pane0-miller-row-double-clicked(col, row); }
        }

        if dual-pane : Rectangle {
            width: 1px;
            background: Theme.border;
        }

        if dual-pane : Pane {
            horizontal-stretch: 1;
            focused: focus-index == 1;
            path: root.pane1-path;
            path-segments: root.pane1-segments;
            view-mode: root.pane1-view-mode;
            tabs: root.pane1-tabs;
            active-tab: root.pane1-active-tab;
            details-rows: root.pane1-details-rows;
            details-columns: root.pane1-details-columns;
            details-selected-mask: root.pane1-details-selected-mask;
            details-selected-anchor: root.pane1-details-selected-anchor;
            details-focused-index: root.pane1-details-focused-index;
            grid-thumbnails: root.pane1-grid-thumbnails;
            grid-has-thumbs: root.pane1-grid-has-thumbs;
            grid-selected-mask: root.pane1-grid-selected-mask;
            grid-focused-index: root.pane1-grid-focused-index;
            tree-nodes: root.pane1-tree-nodes;
            tree-focused-index: root.pane1-tree-focused-index;
            tree-selected-index: root.pane1-tree-selected-index;

            address-submitted(p) => { root.pane1-address-submitted(p); }
            address-cancelled => { root.pane1-address-cancelled(); }
            breadcrumb-clicked(i) => { root.pane1-breadcrumb-clicked(i); }
            tab-selected(i) => { root.pane1-tab-selected(i); }
            tab-closed(i) => { root.pane1-tab-closed(i); }
            new-tab => { root.pane1-new-tab(); }
            pane-clicked => { root.pane1-clicked(); }
            details-row-clicked(i, ctrl, shift) => { root.pane1-details-row-clicked(i, ctrl, shift); }
            details-row-double-clicked(i) => { root.pane1-details-row-double-clicked(i); }
            details-row-context-menu(i, x, y) => { root.pane1-details-row-context-menu(i, x, y); }
            details-header-clicked(i) => { root.pane1-details-header-clicked(i); }
            details-header-resize(i, w) => { root.pane1-details-header-resize(i, w); }
            grid-entry-clicked(i, ctrl, shift) => { root.pane1-grid-entry-clicked(i, ctrl, shift); }
            grid-entry-double-clicked(i) => { root.pane1-grid-entry-double-clicked(i); }
            grid-entry-context-menu(i, x, y) => { root.pane1-grid-entry-context-menu(i, x, y); }
            grid-thumbnail-visible(i) => { root.pane1-grid-thumbnail-visible(i); }
            grid-columns-changed(c) => { root.pane1-grid-columns-changed(c); }
            tree-row-clicked(i, ctrl, shift) => { root.pane1-tree-row-clicked(i, ctrl, shift); }
            tree-row-double-clicked(i) => { root.pane1-tree-row-double-clicked(i); }
            tree-chevron-clicked(i) => { root.pane1-tree-chevron-clicked(i); }
        }
    }
}
