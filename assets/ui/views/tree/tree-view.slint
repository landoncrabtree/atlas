// Virtualized lazy-expanded directory Tree view.
//
// The visible node set is a flat `[TreeNode]` list maintained by the Rust
// TreeController; this component merely renders it via ListView for
// virtualization. Indentation and chevrons are delegated to TreeRow.
import { ListView } from "std-widgets.slint";
import { Theme } from "../../theme.slint";
import { EntryRowItem } from "../details/column.slint";
import { TreeRow } from "tree-row.slint";

/// One visible row in the flat-flattened tree.
///
/// The Rust controller produces a `Vec<TreeNode>` by DFS-walking the
/// expand/collapse state and pushes it here for pure rendering.
export struct TreeNode {
    /// Display name (last path component).
    name: string,
    /// Shared row data (icon, hidden flag, symlink flags, …).
    entry: EntryRowItem,
    /// Nesting depth (0 = root).
    depth: int,
    /// Whether the entry can have children (is a directory).
    is-expandable: bool,
    /// Whether the node is currently expanded.
    is-expanded: bool,
    /// Whether a background fetch is currently in-flight.
    is-loading: bool,
    /// Stable identifier for the node — the path stringified.
    node-id: string,
}

// Virtualized Tree view driven by a flat visible-node list.
//
// The outer component is a `FocusScope` so keyboard events can be wired later.
// All selection and focus logic lives in the Rust `TreeController`; the
// component just forwards pointer events via callbacks.
export component TreeView inherits FocusScope {
    /// Flat list of currently-visible nodes (DFS order, respecting expand/collapse).
    in property <[TreeNode]> nodes: [];
    /// Focused row index (−1 = none).
    in property <int> focused-index: -1;
    /// Selected row index (−1 = none).
    in property <int> selected-index: -1;
    /// Horizontal indent per nesting level.
    in property <length> indent-per-level: 16px;
    /// Row height for every node.
    in property <length> row-height: 24px;

    callback row-clicked(int, bool /*ctrl*/, bool /*shift*/);
    callback row-double-clicked(int);
    /// Emitted when the user clicks the expand/collapse chevron on row `i`.
    callback chevron-clicked(int);
    /// Forwarded from a tree row when the 4-px drag threshold is exceeded.
    callback drag-start(int /*entry-index*/);

    Rectangle {
        background: Theme.bg;

        ListView {
            for node[i] in root.nodes : TreeRow {
                entry: node.entry;
                node-name: node.name;
                depth: node.depth;
                indent-per-level: root.indent-per-level;
                row-height: root.row-height;
                is-expandable: node.is-expandable;
                is-expanded: node.is-expanded;
                is-loading: node.is-loading;
                selected: root.selected-index == i;
                focused: root.focused-index == i;

                clicked(ctrl, shift) => { root.row-clicked(i, ctrl, shift); }
                double-clicked => { root.row-double-clicked(i); }
                chevron-clicked => { root.chevron-clicked(i); }
                drag-start => { root.drag-start(i); }
            }
        }
    }
}
