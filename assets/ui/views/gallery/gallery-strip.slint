import { ScrollView } from "std-widgets.slint";
import { Theme } from "../../theme.slint";
import { EntryRowItem } from "../details/column.slint";

export component GalleryStrip {
    in property <[EntryRowItem]> entries;
    in property <[image]> thumbnails;
    in property <int> focused-index: -1;
    in property <length> cell-width: 96px;
    in property <length> gap: Theme.space-2;

    callback entry-clicked(int);
    callback item-visible(int);
    /// Emitted from a strip cell when the 4-px drag threshold is exceeded.
    callback drag-start(int /*entry-index*/);

    ScrollView {
        width: parent.width;
        height: parent.height;
        viewport-width: max(parent.width, gap + entries.length * (cell-width + gap));

        HorizontalLayout {
            spacing: gap;
            padding-left: gap;
            padding-right: gap;
            padding-top: gap;
            padding-bottom: gap;

            for item[i] in root.entries : Rectangle {
                init => { root.item-visible(i); }
                width: cell-width;
                height: cell-width;
                background: Theme.panel-bg;
                border-width: root.focused-index == i ? 2px : 1px;
                border-color: root.focused-index == i ? Theme.accent : Theme.border;
                border-radius: Theme.radius-sm;
                opacity: item.is-hidden ? 0.6 : 1.0;
                clip: true;

                Text {
                    width: parent.width;
                    height: parent.height;
                    text: item.kind-icon;
                    color: Theme.fg-muted;
                    font-size: 34px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }

                Image {
                    width: parent.width;
                    height: parent.height;
                    source: root.thumbnails[i];
                    image-fit: cover;
                }

                TouchArea {
                    property <bool> drag-initiated: false;

                    pointer-event(pe) => {
                        if pe.kind == PointerEventKind.down {
                            self.drag-initiated = false;
                        }
                    }
                    moved => {
                        if !self.drag-initiated && self.pressed {
                            if abs(self.mouse-x - self.pressed-x) > 4px || abs(self.mouse-y - self.pressed-y) > 4px {
                                self.drag-initiated = true;
                                root.drag-start(i);
                            }
                        }
                    }
                    clicked => { root.entry-clicked(i); }
                }
            }
        }
    }
}
