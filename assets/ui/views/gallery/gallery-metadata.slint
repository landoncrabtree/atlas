import { Theme } from "../../theme.slint";
import { InlineRenameCell } from "../../components/inline-rename-cell.slint";

export struct MetadataFields {
    name: string,
    path: string,
    size-text: string,
    modified-text: string,
    kind: string,
    dimensions: string,
}

component MetaRow inherits HorizontalLayout {
    in property <string> label;
    in property <string> value;

    spacing: Theme.space-2;

    Text {
        text: label;
        color: Theme.fg-muted;
        font-size: 10px;
        font-weight: 600;
        width: 84px;
    }

    Text {
        text: value == "" ? "—" : value;
        color: Theme.fg;
        font-size: 13px;
        wrap: word-wrap;
        vertical-stretch: 1;
        horizontal-stretch: 1;
    }
}

export component GalleryMetadata {
    in property <MetadataFields> metadata;
    in property <bool> renaming: false;
    in property <string> rename-buffer: "";
    in property <int> rename-selection-start: 0;
    in property <int> rename-selection-end: 0;
    in property <int> rename-selection-tick: 0;
    callback rename-submit();
    callback rename-cancel();
    callback rename-blur-commit();
    callback rename-edited(string);
    out property <bool> rename-input-focused: false;

    Rectangle {
        background: Theme.panel-bg;
        border-width: 1px;
        border-color: Theme.border;
        border-radius: Theme.radius-md;

        VerticalLayout {
            padding: Theme.space-4;
            spacing: Theme.space-2;

            if root.renaming : InlineRenameCell {
                text: root.rename-buffer;
                initial-selection-start: root.rename-selection-start;
                initial-selection-end: root.rename-selection-end;
                selection-tick: root.rename-selection-tick;
                font-size: 15px;
                cell-height: 28px;
                submit => { root.rename-submit(); }
                cancel => { root.rename-cancel(); }
                blur-commit => { root.rename-blur-commit(); }
                edited(t) => { root.rename-edited(t); }
                changed input-focused => {
                    root.rename-input-focused = self.input-focused;
                }
            }

            if !root.renaming : Text {
                text: metadata.name == "" ? "No selection" : metadata.name;
                color: Theme.fg;
                font-size: 15px;
                font-weight: 600;
                wrap: word-wrap;
            }

            Rectangle { height: 1px; background: Theme.border; }

            MetaRow { label: "Path"; value: metadata.path; }
            MetaRow { label: "Size"; value: metadata.size-text; }
            MetaRow { label: "Modified"; value: metadata.modified-text; }
            MetaRow { label: "Kind"; value: metadata.kind; }
            MetaRow { label: "Dimensions"; value: metadata.dimensions; }
        }
    }
}
