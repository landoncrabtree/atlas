import { Theme } from "../../theme.slint";
import { EntryRowItem } from "../details/column.slint";
import { GalleryPreview } from "gallery-preview.slint";
import { GalleryStrip } from "gallery-strip.slint";
import { GalleryMetadata, MetadataFields } from "gallery-metadata.slint";

export { MetadataFields }

export component GalleryView inherits FocusScope {
    in property <[EntryRowItem]> entries;
    in property <[image]> strip-thumbnails;
    in property <image> preview-image;
    in property <bool> preview-loading;
    in property <string> preview-fallback-glyph;
    in property <int> focused-index;
    in property <MetadataFields> metadata;
    /// Rename state; when `rename-active-index == focused-index`,
    /// GalleryMetadata swaps its title Text for an InlineRenameCell.
    in property <int> rename-active-index: -1;
    in property <string> rename-buffer: "";
    in property <int> rename-selection-start: 0;
    in property <int> rename-selection-end: 0;
    in property <int> rename-selection-tick: 0;

    callback entry-clicked(int);
    /// Right-click on a strip cell.  Arguments: entry-index,
    /// window-absolute-x, window-absolute-y.  Bubbled up so the shared
    /// capability-aware context menu can act on the target entry.
    callback entry-context-menu(int, length, length);
    callback strip-visible(int);
    callback preview-visible(int);
    callback prev-image();
    callback next-image();
    /// Forwarded from the strip when the 4-px drag threshold is exceeded.
    callback drag-start(int /*entry-index*/);
    callback rename-submit();
    callback rename-cancel();
    callback rename-blur-commit();
    callback rename-edited(string);
    out property <bool> rename-input-focused: false;

    key-pressed(event) => {
        if event.text == Key.LeftArrow {
            root.prev-image();
            return accept;
        }
        if event.text == Key.RightArrow {
            root.next-image();
            return accept;
        }
        reject;
    }

    changed focused-index => {
        if root.focused-index >= 0 {
            root.preview-visible(root.focused-index);
        }
    }

    VerticalLayout {
        spacing: Theme.spacing-md;
        padding: Theme.spacing-md;

        HorizontalLayout {
            spacing: Theme.spacing-md;
            vertical-stretch: 1;

            GalleryPreview {
                horizontal-stretch: 1;
                preview-image: root.preview-image;
                preview-loading: root.preview-loading;
                preview-fallback-glyph: root.preview-fallback-glyph;
            }

            GalleryMetadata {
                width: 280px;
                metadata: root.metadata;
                renaming: root.rename-active-index >= 0 && root.rename-active-index == root.focused-index;
                rename-buffer: root.rename-buffer;
                rename-selection-start: root.rename-selection-start;
                rename-selection-end: root.rename-selection-end;
                rename-selection-tick: root.rename-selection-tick;
                rename-submit => { root.rename-submit(); }
                rename-cancel => { root.rename-cancel(); }
                rename-blur-commit => { root.rename-blur-commit(); }
                rename-edited(t) => { root.rename-edited(t); }
                changed rename-input-focused => {
                    root.rename-input-focused = self.rename-input-focused;
                }
            }
        }

        Rectangle {
            height: 120px;
            background: transparent;

            GalleryStrip {
                width: parent.width;
                height: parent.height;
                entries: root.entries;
                thumbnails: root.strip-thumbnails;
                focused-index: root.focused-index;
                entry-clicked(i) => { root.entry-clicked(i); }
                entry-context-menu(i, x, y) => { root.entry-context-menu(i, x, y); }
                item-visible(i) => { root.strip-visible(i); }
                drag-start(i) => { root.drag-start(i); }
            }
        }
    }
}
