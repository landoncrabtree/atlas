import { ListView } from "std-widgets.slint";
import { Theme } from "../../theme.slint";
import { EntryRowItem } from "../details/column.slint";

export component MillerColumnView inherits Rectangle {
    in property <string> title: "";
    in property <[EntryRowItem]> entries: [];
    in property <int> focused-index: -1;
    in property <bool> column-focused: false;

    callback row-clicked(int);
    callback row-double-clicked(int);
    /// Emitted from a row when the 4-px drag threshold is exceeded.
    callback drag-start(int /*entry-index*/);

    background: column-focused ? Theme.accent-soft : Theme.bg;

    Rectangle {
        x: parent.width - 1px;
        y: 0px;
        width: 1px;
        height: parent.height;
        background: column-focused ? Theme.accent : Theme.border;
    }

    VerticalLayout {
        spacing: 0px;

        Rectangle {
            height: 28px;
            background: Theme.panel-bg;

            Rectangle {
                y: parent.height - 1px;
                height: 1px;
                background: Theme.border;
            }

            Text {
                x: Theme.space-2;
                width: parent.width - Theme.space-4;
                text: root.title;
                color: Theme.fg-muted;
                font-size: 10px;
                font-weight: 600;
                overflow: elide;
                vertical-alignment: center;
                height: parent.height;
            }
        }

        ListView {
            vertical-stretch: 1;

            for entry[i] in root.entries : row-bg := Rectangle {
                height: 26px;
                background: i == root.focused-index
                    ? (root.column-focused ? Theme.selection-bg : Theme.selection-bg.with-alpha(0.6))
                    : (row-ta.has-hover ? Theme.hover-bg : transparent);
                border-radius: Theme.radius-sm;

                HorizontalLayout {
                    padding-left: Theme.space-2;
                    padding-right: Theme.space-1;
                    spacing: Theme.space-2;
                    alignment: start;

                    Text {
                        text: entry.kind-icon;
                        color: (i == root.focused-index) ? Theme.selection-fg
                             : entry.is-broken-symlink    ? Theme.error
                             : Theme.fg-muted;
                        font-size: 12px;
                        width: 16px;
                        vertical-alignment: center;
                    }

                    Text {
                        text: entry.name;
                        font-size: 12px;
                        color: (i == root.focused-index) ? Theme.selection-fg
                             : entry.is-hidden            ? Theme.fg-muted
                             : Theme.fg;
                        overflow: elide;
                        vertical-alignment: center;
                        horizontal-stretch: 1;
                    }

                    if entry.is-dir : Text {
                        text: "›";
                        color: (i == root.focused-index) ? Theme.selection-fg : Theme.fg-muted;
                        font-size: 11px;
                        vertical-alignment: center;
                        width: 10px;
                    }
                }

                row-ta := TouchArea {
                    width: 100%;
                    height: 100%;
                    property <bool> drag-initiated: false;

                    pointer-event(pe) => {
                        if pe.kind == PointerEventKind.down {
                            self.drag-initiated = false;
                        }
                    }
                    moved => {
                        if !self.drag-initiated && self.pressed {
                            if abs(self.mouse-x - self.pressed-x) > 4px || abs(self.mouse-y - self.pressed-y) > 4px {
                                self.drag-initiated = true;
                                root.drag-start(i);
                            }
                        }
                    }
                    clicked => { root.row-clicked(i); }
                    double-clicked => { root.row-double-clicked(i); }
                }
            }
        }
    }
}
