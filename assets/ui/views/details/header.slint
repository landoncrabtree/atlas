import { Theme } from "../../theme.slint";
import { ColumnSpec } from "column.slint";

export component Header {
    in property <[ColumnSpec]> columns: [];

    callback header-clicked(int);
    callback header-resize(int, float);

    height: 28px;

    Rectangle {
        background: Theme.panel-bg;

        // Bottom separator
        Rectangle {
            y: parent.height - 1px;
            height: 1px;
            background: Theme.border;
        }

        HorizontalLayout {
            spacing: 0px;

            for col[i] in root.columns : Rectangle {
                width: col.width;
                horizontal-stretch: 0;
                clip: true;

                col-ta := TouchArea {
                    width: parent.width - 4px;
                    clicked => { root.header-clicked(i); }
                }

                HorizontalLayout {
                    padding-left: Theme.space-2;
                    padding-right: Theme.space-2;
                    alignment: col.align-right ? end : start;
                    spacing: Theme.space-1;

                    Text {
                        text: col.title;
                        color: Theme.fg-muted;
                        vertical-alignment: center;
                        font-size: 10px;
                        font-weight: 600;
                    }

                    if col.sort-dir != 0 : Text {
                        text: col.sort-dir == 1 ? "↑" : "↓";
                        color: Theme.accent;
                        vertical-alignment: center;
                        font-size: 10px;
                    }
                }

                resize-ta := TouchArea {
                    x: parent.width - 4px;
                    width: 4px;
                    mouse-cursor: col-resize;
                }
            }
        }
    }
}
