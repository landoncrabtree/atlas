import { ListView } from "std-widgets.slint";
import { Theme } from "../../theme.slint";
import { EntryRowItem, ColumnSpec } from "column.slint";
import { Header } from "header.slint";
import { EntryRow } from "row.slint";

// Virtualized Details view.
//
// Uses Slint's ListView for vertical virtualization — the outer container
// renders only the rows that are visible in the scroll viewport, making it
// suitable for 100,000+ entries.
export component DetailsView {
    in property <[EntryRowItem]> rows: [];
    in property <[ColumnSpec]> columns: [];
    in property <int> selected-anchor: -1;
    in property <[bool]> selected-mask: [];
    in property <int> focused-index: -1;
    in property <bool> show-hidden: false;
    /// -1 when no rename is active; otherwise the row index in `rows`
    /// that should render an `InlineRenameCell` in place of the
    /// filename Text.
    in property <int> rename-active-index: -1;
    in property <string> rename-buffer: "";
    in property <int> rename-selection-start: 0;
    in property <int> rename-selection-end: 0;
    in property <int> rename-selection-tick: 0;

    callback row-clicked(int, bool, bool);
    callback row-double-clicked(int);
    callback row-context-menu(int, length, length);
    callback header-clicked(int);
    callback header-resize(int, float);
    /// Forwarded from the focused row when the 4-px drag threshold is exceeded.
    callback drag-start(int /*entry-index*/);
    callback rename-submit();
    callback rename-cancel();
    callback rename-blur-commit();
    callback rename-edited(string);
    out property <bool> rename-input-focused: false;

    VerticalLayout {
        spacing: 0px;

        Header {
            columns: root.columns;
            header-clicked(i) => { root.header-clicked(i); }
            header-resize(i, w) => { root.header-resize(i, w); }
        }

        Rectangle {
            vertical-stretch: 1;
            background: Theme.bg;

            ListView {
                for row_item[i] in root.rows : EntryRow {
                    item: row_item;
                    columns: root.columns;
                    index: i;
                    selected: root.selected-mask[i];
                    focused: root.focused-index == i;
                    renaming: root.rename-active-index == i;
                    rename-buffer: root.rename-buffer;
                    rename-selection-start: root.rename-selection-start;
                    rename-selection-end: root.rename-selection-end;
                    rename-selection-tick: root.rename-selection-tick;

                    clicked(ctrl, shift) => { root.row-clicked(i, ctrl, shift); }
                    double-clicked => { root.row-double-clicked(i); }
                    context-menu(x, y) => { root.row-context-menu(i, x, y); }
                    drag-start => { root.drag-start(i); }
                    rename-submit => { root.rename-submit(); }
                    rename-cancel => { root.rename-cancel(); }
                    rename-blur-commit => { root.rename-blur-commit(); }
                    rename-edited(t) => { root.rename-edited(t); }
                    changed rename-input-focused => {
                        if self.rename-input-focused {
                            root.rename-input-focused = true;
                        } else if root.rename-input-focused {
                            // Only clear when the currently-focused row loses
                            // focus (not when a stale row's changed handler
                            // fires with false for a row that never had it).
                            root.rename-input-focused = false;
                        }
                    }
                }
            }
        }
    }
}
