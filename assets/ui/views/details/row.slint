import { Theme } from "../../theme.slint";
import { EntryRowItem, ColumnSpec } from "column.slint";

export component EntryRow {
    in property <EntryRowItem> item;
    in property <[ColumnSpec]> columns: [];
    in property <int> index: 0;
    in property <bool> selected: false;
    in property <bool> focused: false;

    callback clicked(bool, bool);
    callback double-clicked();
    callback context-menu(length, length);
    /// Emitted once after the pointer has moved ≥ 4 px while pressed —
    /// signals to the parent that a drag should begin for this row.
    callback drag-start();

    height: Theme.row-h-default;

    bg := Rectangle {
        background: root.selected
            ? Theme.selection-bg
            : (ta.has-hover ? Theme.hover-bg : transparent);
        border-radius: Theme.radius-sm;
        border-width: root.focused && !root.selected ? 1px : 0px;
        border-color: Theme.accent;

        animate background { duration: Theme.motion-quick; easing: ease-out; }

        HorizontalLayout {
            spacing: 0px;

            for col[ci] in root.columns : Rectangle {
                width: col.width;
                horizontal-stretch: 0;
                clip: true;

                if col.kind == "name" : HorizontalLayout {
                    padding-left: Theme.space-2;
                    spacing: Theme.space-2;
                    alignment: start;

                    Text {
                        text: item.kind-icon;
                        color: root.selected ? Theme.selection-fg : Theme.fg-muted;
                        vertical-alignment: center;
                        width: 16px;
                        font-size: 13px;
                    }

                    Text {
                        text: item.name + (item.is-symlink ? " →" : "");
                        color: item.is-broken-symlink
                            ? Theme.error
                            : (item.is-hidden
                                ? (root.selected ? Theme.selection-fg : Theme.fg-muted)
                                : (root.selected ? Theme.selection-fg : Theme.fg));
                        vertical-alignment: center;
                        overflow: elide;
                        horizontal-stretch: 1;
                        font-size: 13px;
                    }
                }

                if col.kind == "size" : Text {
                    text: item.size-text;
                    color: root.selected ? Theme.selection-fg : Theme.fg-muted;
                    horizontal-alignment: right;
                    vertical-alignment: center;
                    width: parent.width - Theme.space-2;
                    font-size: 12px;
                }

                if col.kind == "modified" : Text {
                    text: item.modified-text;
                    color: root.selected ? Theme.selection-fg : Theme.fg-muted;
                    horizontal-alignment: left;
                    vertical-alignment: center;
                    width: parent.width - Theme.space-2;
                    x: Theme.space-2;
                    font-size: 12px;
                }

                if col.kind == "kind" : Text {
                    text: item.is-dir ? "Directory"
                        : (item.is-symlink ? "Symlink" : "File");
                    color: root.selected ? Theme.selection-fg : Theme.fg-muted;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    width: parent.width;
                    font-size: 12px;
                }

                if col.kind == "extension" : Text {
                    text: item.name;
                    color: root.selected ? Theme.selection-fg : Theme.fg-muted;
                    horizontal-alignment: left;
                    vertical-alignment: center;
                    width: parent.width - Theme.space-2;
                    x: Theme.space-2;
                    font-size: 12px;
                }
            }
        }

        ta := TouchArea {
            property <bool> mod-ctrl: false;
            property <bool> mod-shift: false;
            // Set to true once the drag threshold has fired so we only emit
            // drag-start once per press; reset on the next pointer-down.
            property <bool> drag-initiated: false;

            pointer-event(pe) => {
                if pe.kind == PointerEventKind.down {
                    self.mod-ctrl = pe.modifiers.control;
                    self.mod-shift = pe.modifiers.shift;
                    self.drag-initiated = false;
                }
                if pe.kind == PointerEventKind.up && pe.button == PointerEventButton.right {
                    // Translate TouchArea-relative (mouse-x, mouse-y) up
                    // to window coordinates so ContextMenuArea.show() at
                    // the root paints the menu at the pointer, not at
                    // the top-left of the window.
                    root.context-menu(
                        self.absolute-position.x + self.mouse-x,
                        self.absolute-position.y + self.mouse-y,
                    );
                }
            }

            moved => {
                // Escalate to a drag once the pointer has moved ≥ 4 px from the
                // press point, but only once per press (drag-initiated guard).
                if !self.drag-initiated && self.pressed {
                    if abs(self.mouse-x - self.pressed-x) > 4px || abs(self.mouse-y - self.pressed-y) > 4px {
                        self.drag-initiated = true;
                        root.drag-start();
                    }
                }
            }

            clicked => { root.clicked(ta.mod-ctrl, ta.mod-shift); }
            double-clicked => { root.double-clicked(); }
        }
    }
}
